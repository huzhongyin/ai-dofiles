- (NSString * _Nullable)encyptedAuthrizationWithSignatureDictionary:(NSDictionary *_Nullable)signatureDictionary isNeedToken:(BOOL)isNeedToken {
    NSString *authorization = nil;
    if(XPCoreSessionAppLaunch.sharedInstance.encryptionType == HttpRequestEncryptionTypeTee) {
        authorization = [[XPTeeSecurityManager instance] encode4Network:[signatureDictionary dictionaryToJson] isNeedToken:isNeedToken];
    }
    return authorization;
}

