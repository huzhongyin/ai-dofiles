}
- (NSString *)authorizationHttpRequestHeaderWithPath:(NSString *)path {
    NSString *authorization;
    if ([path isEqualToString:self.refreshTokenHelperRefreshPath]) {
        NSString *refreshToken = self.refreshTokenInHttpRequestHeader;
        if (refreshToken.length > 0) {
            authorization = refreshToken;
        }
    } else {
        NSString *accessToken = self.accessTokenInHttpRequestHeader;
        if (accessToken.length > 0) {
            authorization = accessToken;
        }
    }
    return authorization;
}
