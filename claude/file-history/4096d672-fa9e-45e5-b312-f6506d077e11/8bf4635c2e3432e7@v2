@implementation XPCoreSessionAppLaunch

+ (instancetype)sharedInstance
{
    static id instance = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        instance = [[self alloc] init];
    });
    
    return instance;
}

- (void)run {
    // HttpRequestHeader
    HttpRequestHeader.sharedManager.params = self;
    
    // AsyncHttpClient
    AsyncHttpClient.client.params = self;
    
    // XPAPIRequestManager
    XPAPIRequestManager.sharedManager.params = self;
    XPAPIRequestManager.sharedManager.appWhiteLogUrlList = XPAPIConfig.getAppWhiteLogUrlList;
    
    //Response
    Response.sharedManager.params = self;
    
    // ResponseHandler
    ResponseHandler.sharedInstance.delegate = self;
    
    // RefreshTokenHelper
    RefreshTokenHelper.shareInstance.delegate = self;

#if __has_include(<XPNetwork/CronetManager.h>)
    [CronetManager setupCronet];

#if __has_include(<XPResolver/XPResolver.h>)
    if (XPResolver.enable) {
        NSString *VIN = CTMediator.vin;
        NSInteger uid = CTMediator.uid;
        if (VIN.length == 0 && uid != 0) {
            VIN = [KeyValueStore stringForObjectId:@"com.xiaopeng.defaultCarVinLocal" userId:[NSString stringWithFormat:@"%ld", uid]];
        }

        NSString *UID = [NSString stringWithFormat:@"%ld", (long)uid];

        XPResolverDataProvider *provider = [[XPResolverDataProvider alloc] init];
        provider.VIN = VIN ?: @"";
        provider.UID = UID;
        provider.appname = @"xiaopeng";

        [XPResolver setupProvider:provider];
    }
#endif // __has_include(<XPResolver/XPResolver.h>)
#endif // __has_include(<XPNetwork/CronetManager.h>)
}

- (void)encryptionReady:(HttpRequestEncryptionType)encryptionType {
    assert(EncryptionOpen);
    _httpRequestEncryptionType = encryptionType;
    DLogTagInfo(@"XPCoreSessionAppLaunch", @"encryptionReady %ld", (long)encryptionType);
}


