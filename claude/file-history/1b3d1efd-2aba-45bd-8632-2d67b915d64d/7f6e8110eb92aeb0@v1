- (CGFloat)tableView:(UITableView *)tableView heightForHeaderInSection:(NSInteger)section{
    switch (section) {
        case XPKeyManageSectionBleHeader:
            return 0;
            break;
        case XPKeyManageSectionCardList:
            return self.cardList.count>0?10:0;
            break;
        case XPKeyManageSectionOtherDeviceList:
            return self.otherDeviceList.count>0?10:0;
            break;
        case XPKeyManageSectionPollingSetting:
            if ([self showPollingSetting]) {
                if ([self getPollingShowStyle] == PollingSettingStyleSwitch) {//v3
                    if ([CTMediator isMona]) {
                        return 52;
                    } else {
                        NSInteger num = [self numberOfPollingSettings];
                        return num == 0 ? 0 : 52;
                    }
                } else {
                    return 52;
                }
            }else{
                return 0;
            }
            break;
        case XPKeyManageSectionBleLocation:
            if (self.isShowBleLocation) {
                CGFloat calHeight = [[self footerText] boundingRectWithSize:CGSizeMake(kScreenWidth - 2 * kKeyThreeManageSideSpace, CGFLOAT_MAX) options:NSStringDrawingUsesLineFragmentOrigin attributes:@{NSFontAttributeName:[self footerFont]} context:nil].size.height;
                return kFooterAdditionalHeight + (calHeight < kFooterMinTextHeight? kFooterMinTextHeight : calHeight);
            }else {
                return 0;
            }
            break;
        case XPKeyManageSectionNFCCarkey:
            return [XPCarKeyHelp.shared localCarKeyIsExist] ? 10 : 0;
            break;
        case XPKeyManageSectionLoginScreen:
            if ([self showLoginScreen]) {
                return 10;
            }else{
                return 0;
            }
            break;
        case XPKeyManageSectionInstruction:
            return 10;
            break;
        default:
            return 0;
            break;
    }
    return 0;

}

