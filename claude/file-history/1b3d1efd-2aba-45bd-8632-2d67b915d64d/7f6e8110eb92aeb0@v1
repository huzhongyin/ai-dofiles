- (void)refreshData{
    DLogTagInfo(kBLECarKeyTag, @"carkey refreshData");
    [self getPollingSetting];
    //获取数据
    if ([CTMediator isSDK2ndCar]) {
        [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager refreshRemoteKeyList];
        [self updateCardsData];
    } else {
        [self.keyViewModel refeshList];
    }
    [self.tableView reloadData];
}

- (void)getPollingSetting {
    PollingRunMode pollingModel = [[XPMultiBleManager sharedManager] getPollingSettingFromMMKV];
    if (pollingModel != PollingRunModeLockAndUnlock ) {
        self.isPollingOn = NO;
    }else{
        self.isPollingOn = YES;
    }
    
    self.doorHandleLockUnlockOn = [[XPMultiBleManager sharedManager] getCurrentKeyPollingEnable];
    self.autoLockOn = [[XPMultiBleManager sharedManager] getCurrentKeyLock];
    self.autoUnlockOn = [[XPMultiBleManager sharedManager] getCurrentKeyUnlock];
}

- (void)getLocalKeyPhone {
    @weakify(self);
    [[[XPAPIRequestManager sharedManager] getLocalWalletKeyPhoneNumber:[XPCarKeyHelp.shared localCarKeyId] withVin:CTMediator.vin] subscribeNext:^(Response * _Nullable x) {
        @strongify(self);
        NSDictionary *data = x.data;
        if ([data.allKeys containsObject:@"tel"]) {
            NSString *tel = [data valueForKey:@"tel"];
            for (XPBLEKeyCard *appleCard in self.cardList) {
                if ([appleCard.cardNo isEqualToString:[XPCarKeyHelp.shared localCarKeyId]]) {
                    appleCard.tel = tel;
                    DLogTagInfo(kBLECarKeyTag, @"有绑定电话:%@",tel);
                    break;
                }
            }
        }
        if ([data.allKeys containsObject:@"uid"]) {
            NSNumber *uid = [data valueForKey:@"uid"];
            if (uid.intValue > 0) {
                //绑定过用户
                DLogTagInfo(kBLECarKeyTag, @"绑定过用户");
                XPCarKeyHelp.shared.bindType = XPCarKeyBindTypeBinded;
                for (XPBLEKeyCard *appleCard in self.cardList) {
                    if ([appleCard.cardNo isEqualToString:[XPCarKeyHelp.shared localCarKeyId]]) {
                        appleCard.uid = uid.intValue;
                        DLogTagInfo(kBLECarKeyTag, @"有绑定uid:%d",uid.intValue);
                        break;
                    }
                }
            } else {
                DLogTagInfo(kBLECarKeyTag, @"没绑定过用户");
                XPCarKeyHelp.shared.bindType = XPCarKeyBindTypeNotBinded;
            }
        }
        [self.tableView reloadData];
    }];
}

- (void)getAuthList {
    if ([CTMediator defaultCarInfo].releationType == ReleationType_Owner) {
        @weakify(self);
        self.isPendingAuthList = YES;
        [[[XPAPIRequestManager sharedManager] getVehicleDriversListWithVin:CTMediator.vin] subscribeNext:^(Response * _Nullable x) {
            @strongify(self);
            if (x.isSuccess) {
                NewAuthListModel *model = [NewAuthListModel yy_modelWithJSON:x.data];
                self.authListCount = model.driverCount.grantedNum;
            }
            self.isPendingAuthList = NO;
            [self.tableView reloadData];
        }];
    }
}

