- (XPBLEKeyCard *)findBLECard {
    XPBLEKeyCard *bleMonaCard = [self findCardWithType:XPBLEKeyCardType_BLEMonaKey];
    if (bleMonaCard) {
        return bleMonaCard;
    }

    XPBLEKeyCard *bleCard = [self findCardWithType:XPBLEKeyCardType_BLEKey];
    XPBLEKeyCard *bleCertKeyCard = [self findCardWithType:XPBLEKeyCardType_BLECertKey];
    if(!bleCertKeyCard) {
        bleCertKeyCard = [self findCardWithType:XPBLEKeyCardType_BLESelfKey];
    }
    
    XPBLEKeyCard *mergeBleCard = nil;
    if(bleCard && bleCertKeyCard) {
        DLogTagInfo(kBLEKeyTag, @"服务器的安全和证书钥匙都存在, 安全钥匙：%@, 证书钥匙：%@", bleCard, bleCertKeyCard);
        if(bleCard.isValid){
            mergeBleCard = bleCard;
        }else{
            mergeBleCard = bleCertKeyCard;
        }
    } else if(bleCard) {
        DLogTagInfo(kBLEKeyTag, @"只存在安全钥匙：%@", bleCard);
        mergeBleCard = bleCard;
    } else if(bleCertKeyCard) {
        DLogTagInfo(kBLEKeyTag, @"只存在证书钥匙：%@", bleCertKeyCard);
        mergeBleCard = bleCertKeyCard;
    } else {
        DLogTagInfo(kBLEKeyTag, @"安全和证书钥匙都不存在");
    }

    return mergeBleCard;
}

