- (void)cellActiveButtonClickWithCard:(XPBLEKeyCard *)card{
    if (![[NetworkMonitorManager sharedManager] isReachable]) {
        [XPToast showMessage:@"网络未连接，请检查手机网络"];
        return;
    }
    
    //1,私有钥匙创建
    if (card.cardType == XPBLEKeyCardType_BLESelfKey || card.cardType == XPBLEKeyCardType_BLEKey || card.cardType == XPBLEKeyCardType_BLECertKey || card.cardType == XPBLEKeyCardType_BLEMonaKey){
        [self createKeyButtonDidClick];
        return;
    }
    //2,手表nfc
    if (card.cardType == XPBLEKeyCardType_NFCWatchKey) {
        [self createWatchKeyButtonDidClick];
        return;
    }
    //3,手表钥匙
    if (card.cardType == XPBLEKeyCardType_WatchCertKey){
        XPBLEKeyCard *bleCard = [self findBLECard];
        if (!bleCard) {
            [XPToast showMessage:@"请先激活手机钥匙"];
            return;
        }
        XPCreateAppleWatchKeyViewController *vc = [XPCreateAppleWatchKeyViewController new];
        vc.carInfo = CTMediator.defaultCarInfo;
        vc.idfv = card.deviceId;
        [self safePushViewController:vc animated:YES];
        return;
    }
}

