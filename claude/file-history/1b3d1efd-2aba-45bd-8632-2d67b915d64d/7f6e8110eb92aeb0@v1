- (void)deleteKeyButtonDidClickWithCard:(XPBLEKeyCard *)card{
    [XPStatisticsMgr sendEvent:XP_DELETE_BLE_KEY module:XP_DIGITAL_KEY_MANAGER_MODULE];
    
    MyCarInfo *carInfo = CTMediator.defaultCarInfo;
    if(carInfo.isE28) {
        DLogTagInfo(kBLEKeyTag, @"是e28，跳到原来钥匙删除流程");
        BOOL existSafeOld = ![CTMediator isSDK2ndCar] && XPBLEKeyManager.instance.defaultCard;
        BOOL existSafeNew = [CTMediator isSDK2ndCar] && [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager digitalKeyWithKeyCardType:XPKeyCardTypeSAFE];
        BOOL existCertOld = ![CTMediator isSDK2ndCar] && [XPBLEKeyManager.instance checkIsCertKeyCreatedWithVin:carInfo.vin uid:CTMediator.uid];
        BOOL existCertNew = [CTMediator isSDK2ndCar] && [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager digitalKeyWithKeyCardType:XPKeyCardTypeCERT];
        if(existSafeOld || existSafeNew) {
            DLogTagInfo(kBLEKeyTag, @"存在安全钥匙，走删除安全钥匙流程（可能存在证书钥匙）");
            JRDeleteKeyViewController *deleteKeyViewController = [[JRDeleteKeyViewController alloc] init];
            deleteKeyViewController.vin = carInfo.vin;
            deleteKeyViewController.card = XPBLEKeyManager.instance.defaultCard;
            [self safePushViewController:deleteKeyViewController animated:YES];
        } else if(existCertOld || existCertNew) {
            DLogTagInfo(kBLEKeyTag, @"不存在安全钥匙，走删除证书钥匙流程");
            JRDeleteCertKeyViewController *deleteCertKeyViewController = [[JRDeleteCertKeyViewController alloc] init];
            deleteCertKeyViewController.vin = carInfo.vin;
            [self safePushViewController:deleteCertKeyViewController animated:YES];
        } else {
            DLogTagInfo(kBLEKeyTag, @"很奇怪钥匙不存在，走删除安全钥匙流程");
            JRDeleteKeyViewController *deleteKeyViewController = [[JRDeleteKeyViewController alloc] init];
            deleteKeyViewController.vin = carInfo.vin;
            deleteKeyViewController.card = card;
            [self safePushViewController:deleteKeyViewController animated:YES];
        }
    } else {
        DLogTagInfo(kBLEKeyTag, @"是新车型，跳到自研钥匙删除流程");
        if (![CTMediator isMona]) {
            JRDeleteCertKeyViewController *deleteCertKeyViewController = [[JRDeleteCertKeyViewController alloc] init];
            deleteCertKeyViewController.vin = carInfo.vin;
            [self safePushViewController:deleteCertKeyViewController animated:YES];
        } else {
            XPDeleteMonaKeyViewController *deleteMonaKeyViewController = [[XPDeleteMonaKeyViewController alloc] init];
            deleteMonaKeyViewController.vin = carInfo.vin;
            [self safePushViewController:deleteMonaKeyViewController animated:YES];
        }
    }
}

