- (void)carKeyActiveClick:(XPBLEKeyCard *)card {
    //看有没有预知证书，看本地是不是有钥匙
    @weakify(self);
    [[XPAPIRequestManager.sharedManager requestMyOwnBLEKeyListUid:[XPLoginSDKBridge sharedInstance].loginHandle.uid vin:CTMediator.vin].deliverOnMainThread subscribeNext:^(Response * _Nullable x) {
        @strongify(self);
        if (x.isSuccess) {
            DLogTagInfo(kBLECarKeyTag, @"成功，继续下一步");
            NSArray<XPBLEKeyCard*>* cardList = [NSArray yy_modelArrayWithClass:XPBLEKeyCard.class json:[x.data objectForKey:@"ownList"]];
            BOOL hasBind = NO;
            for (XPBLEKeyCard *card in cardList) {
                if (card.cardType == XPBLEKeyCardType_V3_Phone_CCCKey && card.uid == CTMediator.uid) {
                    hasBind = YES;
                }
            }
            if (hasBind) {
                //弹窗
                [self showGuide];
            } else {
                DLogTagInfo(kBLECarKeyTag, @"真正的升级");
                [XPCarKeyHelp.shared startCarKeyPairWithDelegate:self complete:^(enum XPCarKeyPassEventError error, UIViewController * _Nonnull pairController) {
                    if (error == XPCarKeyPassEventErrorNone) {
                        [self.navigationController presentViewController:pairController animated:YES completion:nil];
                    } else if (error == XPCarKeyPassEventErrorSystemNotSupport) {
                        [QMUIAlertController showAlertWithTitle:@""
                                                        message:@"开通钥匙需将系统更新至iOS18及以上，建议前往“系统设置>通用>软件更新”"
                                               leftButtionTitle:@""
                                                 leftButtonType:QMUIAlertActionStyleCancel
                                                     leftAction:^(__kindof QMUIAlertController * _Nonnull alertVC, QMUIAlertAction * _Nonnull action) {
                        }
                                               rightButtonTitle:@"好的"
                                                rightButtonType:QMUIAlertActionStyleDefault
                                                    rightAction:^(__kindof QMUIAlertController * _Nonnull alertVC, QMUIAlertAction * _Nonnull action) {
                        }];
                    } else {
                        [self handleCarKeyPassError:error];
                        DLogTagInfo(kBLEKeyTag, @"error: %ld", (long)error);
                    }
                }];
            }
        } else {
            if (x.code == 1005) {
                DLogTagInfo(kBLECarKeyTag, @"失败，Game Over");
                [self showError];
            }
        }
    } error:^(NSError * _Nullable error) {
    } completed:^{
    }];
    
}


