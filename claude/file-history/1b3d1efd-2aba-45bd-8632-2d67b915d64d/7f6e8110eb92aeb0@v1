- (void)createKey{
    if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
        if ([XPCarKeyHelp.shared localCarKeyIsVaild] && ![self isBLECardValid]) {
            DLogTagInfo(kBLECarKeyTag, @"钱包钥匙生效，没私有钥匙，需要静默激活");
            //静默激活
            @weakify(self);
            if (CTMediator.isSDK2ndCar) {
                [[XPVehicleSDK.shared.vehicleManager currentVehicle].digitalKeyManager createKeyWithSuccess:^{
                    @strongify(self);
                    DLogTagInfo(kBLECarKeyTag, @"3.0车型走SDK，创建钥匙成功");
                    [XPToast showMessage:@"已激活钥匙"];
                    [self refreshData];
                } failed:^(XPVehicleError * _Nonnull error) {
                    DLogTagInfo(kBLECarKeyTag, @"3.0车型走SDK，创建钥匙失败%@", error.description);
                    [XPToast showMessage:@"激活失败，请在有网环境重试"];
                }];
            } else {
                [[XPAPIRequestManager.sharedManager createBleKeyV3PrivateKey:CTMediator.vin deviceType:XPBLEKeyDeviceTypePhone] subscribeNext:^(Response * _Nullable x) {
                    if(x.isSuccess){
                        XPBLEKeyCard *card = [XPBLEKeyCard yy_modelWithJSON:x.data[@"keyInfo"]];
                        [XPBLEKeyManager.instance deleteCertKeyWithVin:CTMediator.vin];
                        [XPBLEHandlerManager.manager deleteMyBleKeyEvent];
                        [XPBLEKeyManager.instance saveIsCertKeyCreatedWithVin:CTMediator.vin isCreated:YES];
                        [self refreshData];
                        [NSNotificationCenter.defaultCenter postNotificationName:BLEKeyButtonUpdateNotification object:nil];
                        [XPToast showMessage:@"已激活钥匙"];
                        
                        
                        [XPBLEKeyManager.instance requestGetCertKeyAuthDataWithVin:CTMediator.vin cardNo:card.cardNo successBlock:^{
                                DLogTagInfo(kBLECarKeyTag, @"获取证书钥匙报文成功:%@",x);
                        } failBlock:^(NSError * _Nullable error) {
                            DLogTagInfo(kBLECarKeyTag, @"获取证书钥匙报文失败:%@", error);
                        }];
                        
                        DLogTagInfo(kBLECarKeyTag, @"创建私有钥匙成功:%@", x);
                    } else {
                        [XPToast showMessage:@"激活失败，请在有网环境重试"];
                    }
                }];
            }
        }
    }
}

- (void)checkForStatic{
    if ([XPBLEHandlerManager.manager getCommuicateBLEConnectState] == XPBLEHanderConnectStateAuthorized) {
        NSDictionary *data = @{@"connect_status":@(1)};
        [XPStatisticsMgr sendEvent:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_CONNECT module:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_MODULE data:data];
    }else{
        NSDictionary *data = @{@"connect_status":@(0)};
        [XPStatisticsMgr sendEvent:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_CONNECT module:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_MODULE data:data];
    }
    
    //标定值埋点
    if (CTMediator.isDigitalKeySecondVersion || XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
        NSInteger type = 0;
        if ([[PollingEffectDataManager sharedManager].keySettingTool getSelfCalibrationIsUse]) {
            type = 2;
        } else {
            if ([PollingEffectDataManager sharedManager].isGuanfangConfig) {
                type = 0;
            } else {
                type = 1;
            }
        }
        if (type == 1 && XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
            type = 3;
            NSDictionary *data = @{@"type":@(type)};
            [XPStatisticsMgr sendEvent:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_POLLING_VALUE_STYLE module:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_MODULE data:data];
        } else {
             NSDictionary *data = @{@"type":@(type)};
            [XPStatisticsMgr sendEvent:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_POLLING_VALUE_STYLE module:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_MODULE data:data];
        }
    }
    
    if (CTMediator.isMona) {
        NSInteger type = 0;
        if (![XPMonaSDKSpecialManager.shared getOfficial]) {
            type = 1;
        }
        NSDictionary *data = @{@"type":@(type)};
        [XPStatisticsMgr sendEvent:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_POLLING_VALUE_STYLE module:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_MODULE data:data];
    }
}

- (void)addObserver{
    @weakify(self)
    [self.rac_deallocDisposable addDisposable:[RACObserve(self.keyViewModel, myCardList).deliverOnMainThread subscribeNext:^(id  _Nullable x) {
        @strongify(self)
        self.downloadCardList = x;
        [self updateCardsData];
        
    }]];
    
    [self.rac_deallocDisposable addDisposable:[RACObserve(self.keyViewModel, sharedCardList).deliverOnMainThread subscribeNext:^(id  _Nullable x) {
        @strongify(self)
        
        // 4，处理其他设备的钥匙：过滤条件是不是私有，不是本地的keyid
        [self updateCardsData];
        
    }]];
    
    
    [self.rac_deallocDisposable addDisposable:[[NSNotificationCenter.defaultCenter rac_addObserverForName:XPVehicleNotification.DigitalKeyStateChanged object:nil].deliverOnMainThread subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self)
        [self updateCardsData];
    }]];
    
    [[XPBLEHandlerManager.manager.sendBleConnectStateSingal.deliverOnMainThread takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNumber*  _Nullable x) {
        @strongify(self);
        [self.tableView reloadData];
    }];
    
    [self.rac_deallocDisposable addDisposable:[[NSNotificationCenter.defaultCenter rac_addObserverForName:UIApplicationWillEnterForegroundNotification object:nil].deliverOnMainThread subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self)
        
        DLogTagInfo(kBLECarKeyTag, @"回到前台刷新");
        [self refreshData];
    }]];
    
    //监听车辆能力变更通知，是否拥有数字钥匙3.0能力
    RACSignal *notificationSignal = [[NSNotificationCenter defaultCenter]
                                     rac_addObserverForName:CarCapabilitiesUpdateNotification
                                     object:nil];
    [self.rac_deallocDisposable addDisposable:[[notificationSignal deliverOnMainThread]
                                               subscribeNext:^(NSNotification * _Nullable notification) {
        @strongify(self);
        self.isDK3 = [CTMediator.defaultCarInfo.capabilities containsObject:KCarDK3LockAndUnlockSetting] ? true : false;
        DLogTagInfo(kBLECarKeyTag,[NSString stringWithFormat:@"车辆能力变更通知:%@",notification.userInfo]);
    }error:^(NSError * _Nullable error) {
        DLogTagInfo(kBLECarKeyTag,[NSString stringWithFormat:@"车辆能力变更通知error:%@",error]);
    }]];
    
    [[XPVehicleSDK.shared.vehicleManager.carkeyEntryStateChangedEvent onImmediately:^(id _Nonnull value ) {
        @strongify(self);
        XPCarKeyPollingSwitchState state = [value integerValue];
        self.state = state;
        DLogTagInfo(kBLECarKeyTag, @"舒适进入状态改变:%ld",self.state);
        [self.tableView reloadData];
    }] bind:self];
}

