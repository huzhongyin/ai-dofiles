- (RACCommand *)transferBigScreenLoginCodeCommand{
    if(_transferBigScreenLoginCodeCommand == nil){
        _transferBigScreenLoginCodeCommand = [[RACCommand alloc] initWithSignalBlock:^RACSignal * _Nonnull(id  _Nullable input) {
            return [RACSignal createSignal:^RACDisposable * _Nullable(id<RACSubscriber>  _Nonnull subscriber) {
                RACDisposable *disposable = [[XPAPIRequestManager.sharedManager transferBigScreenLoginCodeWithVin:input[@"vin"]] subscribeNext:^(Response * _Nullable x) {
                    if(x.isSuccess) {
                        [subscriber sendNext:x];
                        [subscriber sendCompleted];
                    } else {
                        [subscriber sendError:x.error];
                    }
                } error:^(NSError * _Nullable error) {
                    [subscriber sendError:error];
                }];
                return disposable;
            }];
        }];
    }
    return _transferBigScreenLoginCodeCommand;
}
- (void)transferBigScreenLoginCode{
    [[self.transferBigScreenLoginCodeCommand execute:@{@"vin": CTMediator.defaultCarVin}].deliverOnMainThread subscribeNext:^(id  _Nullable x) {
        
    } error:^(NSError * _Nullable error) {
        DLogTagInfo(kBLEKeyTag, @"联登大屏Code推送失败 domain=%@ code=%ld", error.domain, error.code);
    } completed:^{
        DLogTagInfo(kBLEKeyTag, @"联登大屏Code推送成功");
    }];
}

