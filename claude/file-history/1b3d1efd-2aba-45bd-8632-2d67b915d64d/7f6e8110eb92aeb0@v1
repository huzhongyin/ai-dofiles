- (BOOL)cardIsValid:(XPBLEKeyCard *)card{
    if(!card) return NO;
    
    //安全钥匙需要判断设备，证书钥匙没那么多状态，安全钥匙（一砂）才需要检测各种状态
    if(card.cardType == XPBLEKeyCardType_BLEKey || card.cardType == XPBLEKeyCardType_BLEMonaKey) return card.isValid;
    
    return card.status == XPBLEKeyCardStatusNormal;
}

- (void)getOtherDeviceList {
    [self.otherDeviceList removeAllObjects];
    NSArray *targetCardTypeArrray = @[@(XPKeyCardTypeCCC), @(XPKeyCardTypeCCC_WATCH), @(XPKeyCardTypeICCOA), @(XPKeyCardTypeICCE)];
    NSArray *cardList = [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager digitalMultiKeyListWithKeyCardTypeArray:targetCardTypeArrray];
    if (cardList.count > 0) {
        for (NSDictionary *dic in cardList) {
            XPBLEKeyCard *card = [XPBLEKeyCard yy_modelWithDictionary:dic];
            if (![card.cardNo isEqualToString:[XPCarKeyHelp.shared localCarKeyId]]) {
                [self.otherDeviceList addObject:card];
            }
        }
    }
    DLogTagInfo(kBLEKeyTag, @"SDK其他设备钥匙%@",self.otherDeviceList);
}


