- (void)cellPollingSwitchButtonClick {
    //靠近自动解锁
    if(!self.isPollingOn){
        @weakify(self)
        [XPCarStatisticsManager.sharedInstance addEvent:[XPCarStatisticsEvent eventWithPageId:XP_DIGITAL_KEY_MANAGER_MODULE buttonId:XP_DIGITAL_KEY_MANAGER_AUTO_UNLOCK data:@{@"operation": @(1)}]];
        
        //打开，先检查白名单
        if(CTMediator.isPollingFirst && !PollingEffectDataManager.sharedManager.getPollingWhitelistFromMMKV && ![CTMediator isMona]) {
            [QMUIAlertController showAlertWithTitle:@"自动解闭锁设置"
                                            message:@"为保证使用体验，正在进行机型适配，请点击查看已适配机型"
                                   leftButtionTitle:@"好的"
                                     leftButtonType:QMUIAlertActionStyleCancel
                                         leftAction:nil
                                   rightButtonTitle:@"查看机型"
                                    rightButtonType:QMUIAlertActionStyleDefault
                                        rightAction:^(__kindof QMUIAlertController * _Nonnull alertVC, QMUIAlertAction * _Nonnull action) {
                @strongify(self)
                [self showPollingDetails:YES];
            }];
            return;
        }
        
        BOOL showPermissionPopup = ![MMKV.defaultMMKV getBoolForKey:kPermissionPopup];
        XPPrivacyPermissionAgreeBlock openPollingBlock = ^{
            [QMUIAlertController showAlertWithTitle:[CTMediator isMona]?@"自动解锁功能须知":@"自动解闭锁功能须知"
                                            message:[CTMediator isMona]?@"信号受环境影响，解锁距离可能不稳定":@"信号受环境影响，解闭锁距离可能不稳定"
                                   leftButtionTitle:nil
                                     leftButtonType:QMUIAlertActionStyleCancel
                                         leftAction:nil
                                   rightButtonTitle:@"好的"
                                    rightButtonType:QMUIAlertActionStyleDefault
                                        rightAction:^(__kindof QMUIAlertController * _Nonnull alertVC, QMUIAlertAction * _Nonnull action) {
                @strongify(self)
                if([XPMultiBleManager checkIfPermissionGranted]){
                    if ([self monaSwitchUnlock:YES]) {
                        return;
                    }
                    
                    self.isPollingOn = !self.isPollingOn;
                    [[XPMultiBleManager sharedManager] switchPollingUnLockAndLock:self.isPollingOn];
                    [self.tableView reloadData];
                    [XPToast showMessage:@"开启成功"];
                    if (!self.vcHandler.allowTurnOnLockWithSelfConfig){
                        [XPSelfConfigPollingViewController enterSelfConfigWithAnimated:YES currentVC:self delegate:nil];
                    }
                    
                }else{
                    self.trySwitchAutoUnlock = YES;
                    [self showPermissionView];
                }
            }];
        };
        if(showPermissionPopup){
            [MMKV.defaultMMKV setBool:YES forKey:kPermissionPopup];
            [self showPopupViewWithAgreeBlock:openPollingBlock];
        }else{
            openPollingBlock();
        }
    }else{
        //关闭
        [XPCarStatisticsManager.sharedInstance addEvent:[XPCarStatisticsEvent eventWithPageId:XP_DIGITAL_KEY_MANAGER_MODULE buttonId:XP_DIGITAL_KEY_MANAGER_AUTO_UNLOCK data:@{@"operation": @(0)}]];
        if ([self monaSwitchUnlock:NO]) {
            return;
        }
        self.isPollingOn = !self.isPollingOn;
        [[XPMultiBleManager sharedManager] switchPollingUnLockAndLock:self.isPollingOn];
        [self.tableView reloadData];
    }
}

- (void)cellPolling:(XPCardKeySwitchCell *)cell {
    if (self.currentCard.cardType == XPBLEKeyCardType_V3_Phone_CCCKey) {
        //1.钱包钥匙
        if ([self bleIsConnected]) {
            [XPUITips showLoading:@"设置生效中"];
            if ([[XPCarKeyHelp shared] supportCarKeyPairType] == XPCarKeyPairTypeNfc) {
                [QMUITips hideAllTips];
                [self switchCurrentKeyByBleWithType:cell.switchStyle];
                return;
            }
            [QMUITips hideAllTips];
            if (self.state == XPCarKeyPollingSwitchStateOn) {
                //舒适进入开 >直接设置
                [self switchCurrentKeyByBleWithType:cell.switchStyle];
            } else if (self.state == XPCarKeyPollingSwitchStateClose) {
                //舒适进入关 >弹框提示
                [self showOpenWalletAlertViewWithTitle:@"设置失败"];
            }
        }else {
            //蓝牙未连接>走网络设置通道
            [self switchWalletKeyByNetworkWithType:cell.switchStyle];
        }
    }else {
        //2.蓝牙钥匙
        [self switchCurrentKeyByBleWithType:cell.switchStyle];
    }
}

- (void)switchCurrentKeyByBleWithType:(SwitchStyle)type {
    if (type == SwitchStyleAutoUnlock) {
        self.autoUnlockOn = !self.autoUnlockOn;
        DLogTagInfo(kBLEKeyTag, [NSString stringWithFormat:@"设置自动解锁开关:%d", self.autoUnlockOn]);
        [[XPMultiBleManager sharedManager] switchPollingUnlock:self.autoUnlockOn];
    } else if (type == SwitchStyleAutoLock) {
        self.autoLockOn = !self.autoLockOn;
        DLogTagInfo(kBLEKeyTag, [NSString stringWithFormat:@"设置自动落锁开关:%d", self.autoLockOn]);
        [[XPMultiBleManager sharedManager] switchPollingLock:self.autoLockOn];
    } else if (type == SwitchStyleDoorHandleLockUnlock) {
        self.doorHandleLockUnlockOn = !self.doorHandleLockUnlockOn;
        DLogTagInfo(kBLEKeyTag, [NSString stringWithFormat:@"设置门把手锁开关:%d", self.doorHandleLockUnlockOn]);
        [[XPMultiBleManager sharedManager] setCurrentKeyPollingEnable:self.doorHandleLockUnlockOn];
    }
    [self.tableView reloadData];
}

- (void)showOpenWalletAlertViewWithTitle:(NSString *)title {
    XPUIAlertController *controller = [XPUIAlertController alertControllerWithTitle:title message:nil imageURLString:nil localImage:nil configuration:^(XPUIAlertControllerConfig * _Nonnull config) {
        NSString *t = [title stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceCharacterSet]];
        if (t.length <= 0) {
            config.titleLabelEdgeInsets = UIEdgeInsetsMake(0, 0, 0, 0);
        }else {
            config.titleLabelEdgeInsets = UIEdgeInsetsMake(20, 0, 0, 0);
        }
        config.messageTextView = ({
            
            QMUITextView *textView = [QMUITextView new];
            textView.editable = NO;
            textView.selectable = YES;
            textView.userInteractionEnabled = YES;
            textView.layoutManager.allowsNonContiguousLayout=NO; //为解决iOS16获取高度异常问题
            textView.backgroundColor = UIColor.xp_popupBackgroundColor;
            //设置行高
            NSMutableParagraphStyle *paragraphStyle = [NSMutableParagraphStyle new];
            paragraphStyle.minimumLineHeight = 25;
            paragraphStyle.maximumLineHeight = 25;
            NSMutableDictionary *attributes = [NSMutableDictionary dictionary];
            [attributes setObject:paragraphStyle forKey:NSParagraphStyleAttributeName];
            [attributes setObject:UIColor.xp_primaryTextColor forKey:NSForegroundColorAttributeName];
            
            NSMutableAttributedString *message = [[NSMutableAttributedString alloc] initWithString:@"请点击开启将跳转系统钱包App>小鹏车钥匙>点击右上角\"i\">开启舒适进入后重试" attributes: attributes];
            NSRange range = [message.string rangeOfString:@"开启"];
            [message addAttribute:NSForegroundColorAttributeName value:UIColor.xp_brandTextColor range:range];
            NSRange keyRange = [message.string rangeOfString:@"小鹏车钥匙"];
            [message addAttribute:NSForegroundColorAttributeName value:UIColor.xp_brandTextColor range:keyRange];
            NSRange infoRange = [message.string rangeOfString:@"i"];
            [message addAttribute:NSForegroundColorAttributeName value:UIColor.xp_brandTextColor range:infoRange];
            NSRange okRange = [message.string rangeOfString:@"舒适进入"];
            [message addAttribute:NSForegroundColorAttributeName value:UIColor.xp_brandTextColor range:okRange];
            [message addAttribute:NSFontAttributeName value:[UIFont systemFontOfSize:16] range:NSMakeRange(0, message.length)];
            textView.attributedText = message;
            
            textView;
        });
    }];
    
    XPUIAlertAction *cancelAction = [XPUIAlertAction actionWithTitle:@"取消" style:UIAlertActionStyleCancel actionHandler:^(XPUIAlertAction * _Nonnull action) {
        
    } configuration:nil];
    [controller addAction:cancelAction];
    
    XPUIAlertAction *confirmAction = [XPUIAlertAction actionWithTitle:@"开启" style:UIAlertActionStyleDefault actionHandler:^(XPUIAlertAction * _Nonnull action) {
        [self openWalletApp];
    } configuration:nil];
    [controller addAction:confirmAction];
    
    [self presentViewController:controller animated:YES completion:nil];
}

- (void)openWalletApp {
    //跳转到钱包app
    NSURL *url = [NSURL URLWithString:@"wallet://"];
    if ([[UIApplication sharedApplication] canOpenURL:url]) {
        [[UIApplication sharedApplication] openURL:url options:@{} completionHandler:^(BOOL success) {
            if (success) {
                DLogTagInfo(kBLEKeyTag, @"跳转到钱包App成功");
            } else {
                DLogTagInfo(kBLEKeyTag, @"跳转到钱包App失败");
            }
        }];
    }
}

- (void)switchWalletKeyByNetworkWithType:(SwitchStyle)type {
    [XPUITips showLoading:@"设置生效中"];
    BOOL autoUnlockOn = self.autoUnlockOn;
    BOOL autoLockOn = self.autoLockOn;
    BOOL doorHandleLockUnlockOn = self.doorHandleLockUnlockOn;
    float unlockDistance = [PollingEffectDataManager.sharedManager.keySettingTool getUnlockDistance];
    if (type == SwitchStyleAutoUnlock) {
        autoUnlockOn = !autoUnlockOn;
    } else if (type == SwitchStyleAutoLock) {
        autoLockOn = !autoLockOn;
    } else if (type == SwitchStyleDoorHandleLockUnlock) {
        doorHandleLockUnlockOn = !doorHandleLockUnlockOn;
    }
    NSString *keyId = [XPCarKeyHelp.shared localCarKeyId];

    @weakify(self);
    CarKeyAutoLockRequestParam *param = [[CarKeyAutoLockRequestParam alloc]
                                         initWithKeyIds:@[keyId]
                                         pe:doorHandleLockUnlockOn
                                         pollingLock:autoLockOn
                                         pollingUnLock:autoUnlockOn
                                         lockDistance:kDeafultLockDistance
                                         unLockDistance:unlockDistance];
    DLogTagInfo(kBLEKeyTag, [NSString stringWithFormat:@"设置云端解闭锁request param:%@ uid:%llu vin:%@", param.toDictionary, CTMediator.uid,CTMediator.vin]);
    [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager setDigitalKeySwitchWithLockParam:param vin:CTMediator.vin uid:CTMediator.uid success:^(BOOL success) {
        @strongify(self);
        DLogTagInfo(kBLEKeyTag, [NSString stringWithFormat:@"设置云端解闭锁成功vin:%@",CTMediator.vin]);
        [QMUITips hideAllTips];
        //同步本地设置
        [self switchCurrentKeyByBleWithType:type];
    } failed:^(XPVehicleError *error) {
        [QMUITips hideAllTips];
        if(![NetworkMonitorManager sharedManager].isReachable) {
            [XPToast showMessage:@"请检查手机网络" delay:2];
        }else {
            [XPToast showMessage:@"车辆离线，设置失败" delay:2];
        }
        DLogTagError(kBLEKeyTag, [NSString stringWithFormat:@"设置云端解闭锁code:%ld,error:%@", (long)error.code, error.msg]);
    }];
}
    

