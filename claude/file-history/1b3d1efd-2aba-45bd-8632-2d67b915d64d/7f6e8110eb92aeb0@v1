- (BOOL)isBLECardValid{
    
    self.bleKeyCard = [self findBLECard];
    if ([CTMediator isMona]) {
        if ([XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager existValidBlePrivateKey]) {
            return YES;
        }
        return NO;
    }
    return [CTMediator isSDK2ndCar]?[XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager existValidBlePrivateKey]:[self cardIsValid:self.bleKeyCard];
}

- (BOOL)monaWaitToActive{
    BOOL waitToActive = NO;
    
    NSString *keyWithVin = [NSString stringWithFormat:@"com.xiaopeng.XPCreateMonaKeyViewController.waitNearCar.%@.%lld", XPVehicleSDK.shared.vehicleManager.currentVehicle.vehiclePreference.vin,[CTMediator uid]];
    if (CTMediator.isMona) {
        if (![XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager existValidBlePrivateKey] && [MMKV.defaultMMKV getBoolForKey:keyWithVin] && [XPVehicleSDK existToBeActivateBLEKey]) {
            waitToActive = YES;
