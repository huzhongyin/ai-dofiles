- (BOOL)showPollingSetting {
    if (CTMediator.defaultCarInfo.carFunction.BIG_CUSTOMER) {
        return NO;
    }
    if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
        if (XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager.vaildBleKeyCategory == XPDigitalKeyCategoryPHONE_UWB_KEY) {
            return YES;
        }else if ([XPBLEKeyManager.instance isSafeKeyOrCertKeyExisted]) {
            return YES;
        }else{
            return NO;
        }
    }
    if (CTMediator.isMona && ([self isBLECardValid] || [self monaWaitToActive])) {
        return YES;
    }
    if ([XPKeyManageHelp supportPolling] && [self isBLECardValid]) {
        return YES;
    }
    return NO;
}

- (NSInteger)numberOfPollingSettings {
    if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
        if (XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager.vaildBleKeyCategory == XPDigitalKeyCategoryPHONE_UWB_KEY) {
            return self.isDK3 ? 3 : 0;
        }else if ([XPBLEKeyManager.instance isSafeKeyOrCertKeyExisted]) {
            return self.isDK3 ? 3 : 2;
        }else{
            return 0;
        }
    }
    return 0;
}

//因为Mona奇怪，所以要用这个方法转化
- (PollingRunMode)getPollingStatus{
    if (CTMediator.isMona) {
        if([XPMonaSDKSpecialManager.shared getUnlock] || [XPMonaSDKSpecialManager.shared getLock]){
            if ([XPMonaSDKSpecialManager.shared getUnlock] && [XPMonaSDKSpecialManager.shared getLock]) {
                return PollingRunModeLockAndUnlock;
            }else if([XPMonaSDKSpecialManager.shared getUnlock]){
                return PollingRunModeUnLock;
            }else {
                return PollingRunModeLock;
            }
        }else{
            return PollingRunModeNone;
        }
    }else{
        return [[XPMultiBleManager sharedManager] getPollingSettingFromMMKV];
    }
    
}

- (void)handleCarKeyPassError:(XPCarKeyPassEventError)error {
    if (error == XPCarKeyPassEventErrorNone) {
        DLogTagInfo(kBLEKeyTag, @"car key no error");
    } else if (error == XPCarKeyPassEventErrorNoPassword) {
        [XPToast showMessage:@"carkey_pass_password_not_found".xpString];
    } else if (error == XPCarKeyPassEventErrorCarKeyIsExist) {
        [XPToast showMessage:@"carkey_pass_password_is_exist".xpString];
    } else if (error == XPCarKeyPassEventErrorSystemNotSupport) {
        [XPToast showMessage:@"carkey_pass_system_not_support".xpString];
    } else if (error == XPCarKeyPassEventErrorConfigNotSupport) {
        [XPToast showMessage:@"carkey_pass_vehicle_not_support".xpString];
    } else if (error == XPCarKeyPassEventErrorHadPaired) {
        [XPToast showMessage:@"carkey_pass_had_paired".xpString];
    } else if (error == XPCarKeyPassEventErrorLocalPassNotFound) {
        [XPToast showMessage:@"carkey_pass_local_pass_not_found".xpString];
    } else if (error == XPCarKeyPassEventErrorRequiresActivation) {
        [XPToast showMessage:@"carkey_pass_local_pass_require_active".xpString];
    } else if (error == XPCarKeyPassEventErrorActivating) {
        [XPToast showMessage:@"carkey_pass_local_pass_activing".xpString];
    } else if (error == XPCarKeyPassEventErrorSuspended) {
        [XPToast showMessage:@"carkey_pass_local_pass_suspended".xpString];
    } else if (error == XPCarKeyPassEventErrorDeactivated) {
        [XPToast showMessage:@"carkey_pass_local_pass_deactivated".xpString];
    } else if (error == XPCarKeyPassEventErrorShareCanceled) {
        [XPToast showMessage:@"carkey_pass_local_pass_share_cancel".xpString];
    } else if (error == XPCarKeyPassEventErrorShareFailed) {
        [XPToast showMessage:@"carkey_pass_local_pass_share_failed".xpString];
    } else {
        [XPToast showMessage:@"carkey_pass_unknown_error".xpString];
    }
}

