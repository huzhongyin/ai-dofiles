- (void)updateCardsData{
    DLogTagInfo(kBLECarKeyTag, @"刷新卡片信息");
    [self getPollingSetting];
    //寻找其他设备钥匙
    [self getOtherDeviceList];
    [self.cardList removeAllObjects];
    XPBLEKeyCard *bleCard = [self findBLECard];
    if (!bleCard) {
        XPBLEKeyCard *activeCard = [XPBLEKeyCard new];
        if (CTMediator.isMona) {
            activeCard.cardType = XPBLEKeyCardType_BLEMonaKey;
        }else{
            activeCard.cardType = XPBLEKeyCardType_BLESelfKey;
        }
        activeCard.status = XPBLEKeyCardStatusInvalid;
        if ([self isBLECardValid]) {
            activeCard.status = XPBLEKeyCardStatusNormal;
        }
        
        if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
            XPBLEKeyCard *carKeyCard = [self findLocalCarkeyCard];
            if (carKeyCard) {
                XPCarKeyHelp.shared.bindType = XPCarKeyBindTypeBinded;
                [self.cardList addObject:carKeyCard];
                if ([XPDigitalKeyManageViewModel remoteCurrentDeviceCarKeyCard] == nil) {
                    [self getLocalKeyPhone];
                }
            } else {
                [self.cardList addObject:activeCard];
            }
            [self.tableView reloadData];
            return;
        }
        [self.cardList addObject:activeCard];
    }else{
        //数字钥匙3.0 Carkey特殊处理：有carkey卡就没有私有钥匙卡
        if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
            XPBLEKeyCard *carKeyCard = [self findLocalCarkeyCard];
            if (carKeyCard) {
                XPCarKeyHelp.shared.bindType = XPCarKeyBindTypeBinded;
                [self.cardList addObject:carKeyCard];
                if ([XPDigitalKeyManageViewModel remoteCurrentDeviceCarKeyCard] == nil) {
                    [self getLocalKeyPhone];
                }
            } else {
                [self.cardList addObject:bleCard];
            }
        }else{
            [self.cardList addObject:bleCard];
        }
    }
    self.appleWatchKeyCard = [self findAppleWatchCard];
    
    MyCarInfo *carInfo = CTMediator.defaultCarInfo;
    if(carInfo.watchSupported && carInfo.hasBleAbility && carInfo.carAbilityConfig.bleKeyVersion < BleKeyProtocolVesionV3) {
        NSString *watchIdfv = [XPWatchManager.sharedInstance watchIdfv];
        if(watchIdfv.length > 0 && ![self.appleWatchKeyCard.deviceId isEqualToString:watchIdfv]){
            XPBLEKeyCard *activeWatchCard = [XPBLEKeyCard new];
            activeWatchCard.cardType = XPBLEKeyCardType_WatchCertKey;
            activeWatchCard.status = XPBLEKeyCardStatusInvalid;
            activeWatchCard.deviceId = watchIdfv;
            [self.cardList addObject:activeWatchCard];
        }
    }
    
    if (self.appleWatchKeyCard) {
        [self.cardList addObject:self.appleWatchKeyCard];
    }
    
    BOOL nfcOld = ![CTMediator isSDK2ndCar] && (CTMediator.defaultCarInfo.isE28 && CTMediator.defaultCarInfo.isSupportNFCKey == XPNFCKeySupportState_Support && CTMediator.defaultCarInfo.isMyOwnerCar);
    BOOL nfcNew = [CTMediator isSDK2ndCar] && XPVehicleSDK.shared.vehicleManager.currentVehicle.vehiclePreference.function.NFC_WATCH_KEY && XPVehicleSDK.shared.vehicleManager.currentVehicle.vehiclePreference.extInfo.nfcKeyFunState == XPNFCKeyFunctionStateSupported && XPVehicleSDK.shared.vehicleManager.currentVehicle.vehiclePreference.hasOwnerPermissions;
    if (nfcOld || nfcNew) {
        self.nfcWatchKeyCard = [self findCardWithType:XPBLEKeyCardType_NFCWatchKey];
        if (self.nfcWatchKeyCard) {
            [self.cardList addObject:self.nfcWatchKeyCard];
        }else{
            self.nfcWatchKeyCard = [XPBLEKeyCard new];
            self.nfcWatchKeyCard.cardType = XPBLEKeyCardType_NFCWatchKey;
            self.nfcWatchKeyCard.status = XPBLEKeyCardStatusInvalid;
            [self.cardList addObject:self.nfcWatchKeyCard];
        }
    }
    

    [self.tableView reloadData];
}

