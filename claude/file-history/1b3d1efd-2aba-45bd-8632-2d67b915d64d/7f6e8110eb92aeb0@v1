- (NSInteger)tableView:(UITableView *)tableView numberOfRowsInSection:(NSInteger)section{
    switch (section) {
        case XPKeyManageSectionBleHeader:
            return 1;
            break;
        case XPKeyManageSectionCardList:
            return self.cardList.count;
            break;
        case XPKeyManageSectionOtherDeviceList:
            return self.otherDeviceList.count>0?1:0;
            break;
        case XPKeyManageSectionPollingSetting:
            if ([self showPollingSetting]) {
                if ([self getPollingShowStyle] == PollingSettingStyleSwitch) {//v3
                    if ([CTMediator isMona]) {
                        return 1;
                    } else {
                        return [self numberOfPollingSettings];
                    }
                } else {
                    if ([self notSupportPassengerMode]) {
                        return 1;
                    }
                    if ([self getIsDriverMode]) {
                        return 2;
                    } else {
                        return 1;
                    }
                }
            } else {
                return 0;
            }
            
            break;
        case XPKeyManageSectionBleLocation:
            return self.isShowBleLocation ? 1 : 0;
            break;
            
        case XPKeyManageSectionNFCCarkey:
            return [XPCarKeyHelp.shared localCarKeyIsExist] ? 1 : 0;
            break;
        case XPKeyManageSectionLoginScreen:
            if ([self showLoginScreen]) {
                return 1;
            }else{
                return 0;
            }
            break;
        case XPKeyManageSectionInstruction:
            return 1;
        default:
            return 0;
            break;
    }
    return 0;
}

