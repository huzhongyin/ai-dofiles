// notify
BleKeyV3NotifyRequestCreateResult createBleKeyV3NotifyRequestWithInput(BleKeyV3NotifyParams *notifyParams,int isSecure,uint8_t *notifyEncodeData,size_t *notifyEncodeDataSize) {
    __CHECK_RET(notifyParams != NULL, BleKeyV3NotifyRequestCreateNotifyParamsIsNull)
    __CHECK_RET(notifyParams->notifyData != NULL && notifyParams->notifyDataSize != 0, BleKeyV3NotifyRequestCreateNotifyDataIsNull)
    if (isSecure) {
        __CHECK_RET(notifyParams->sessionKey != NULL && notifyParams->sessionKeySize != 0, BleKeyV3NotifyRequestCreateSessionKeyIsNull)
        size_t xorResultSize = 0;
        uint8_t * sessionXorResult = getXorResult((unsigned int *)&xorResultSize, notifyParams->notifyData, notifyParams->notifyDataSize, notifyParams->sessionKey, notifyParams->sessionKeySize);
        uint16_t checkSum = calc_crc16_ccitt(sessionXorResult,xorResultSize);
        uint16_t checkSumLittleEndian = host_int16_to_little_endian(checkSum);
        BLEKeyV3Message v3Message;
        v3Message.msgId = BLEKeyV3MessageTypeNotification;
        v3Message.msgLength = xorResultSize;
        v3Message.messageData = (uint8_t *)malloc(xorResultSize);
        memcpy(v3Message.messageData, sessionXorResult, xorResultSize);
        v3Message.checkSum = checkSumLittleEndian;
        copyBleV3MessageRawData(&v3Message,notifyEncodeData);
        *notifyEncodeDataSize = sizeOfBLEKeyV3Message(&v3Message);
        return BleKeyV3NotifyRequestCreateSuccess;
    } else {
        uint16_t checkSum = calc_crc16_ccitt(notifyParams->notifyData,notifyParams->notifyDataSize);
        uint16_t checkSumLittleEndian = host_int16_to_little_endian(checkSum);
        BLEKeyV3Message v3Message;
        v3Message.msgId = BLEKeyV3MessageTypeNotification;
        v3Message.msgLength = notifyParams->notifyDataSize;
        v3Message.messageData = (uint8_t *)malloc(notifyParams->notifyDataSize);
        memcpy(v3Message.messageData, notifyParams->notifyData, notifyParams->notifyDataSize);
        v3Message.checkSum = checkSumLittleEndian;
        copyBleV3MessageRawData(&v3Message,notifyEncodeData);
        *notifyEncodeDataSize = sizeOfBLEKeyV3Message(&v3Message);
        return BleKeyV3NotifyRequestCreateSuccess;
    }
}

BleKeyV3NotifyRequestCreateResult generateBleKeyV3NotifyRequestContent(BleKeyV3NotifyParams *notifyParams,int isSecure,uint8_t *notifyEncodeData,size_t *notifyEncodeDataSize) {
    __CHECK_RET(notifyParams != NULL, BleKeyV3NotifyRequestCreateNotifyParamsIsNull)
    __CHECK_RET(notifyParams->notifyData != NULL && notifyParams->notifyDataSize != 0, BleKeyV3NotifyRequestCreateNotifyDataIsNull)
    if (isSecure) {
        __CHECK_RET(notifyParams->sessionKey != NULL && notifyParams->sessionKeySize != 0, BleKeyV3NotifyRequestCreateSessionKeyIsNull)
        size_t xorResultSize = 0;
        uint8_t * sessionXorResult = getXorResult((unsigned int *)&xorResultSize, notifyParams->notifyData, notifyParams->notifyDataSize, notifyParams->sessionKey, notifyParams->sessionKeySize);
        *notifyEncodeDataSize = xorResultSize;
        return BleKeyV3NotifyRequestCreateSuccess;
    } else {
        uint16_t checkSum = calc_crc16_ccitt(notifyParams->notifyData,notifyParams->notifyDataSize);
        uint16_t checkSumLittleEndian = host_int16_to_little_endian(checkSum);
        BLEKeyV3Message v3Message;
        v3Message.msgId = BLEKeyV3MessageTypeNotification;
        v3Message.msgLength = notifyParams->notifyDataSize;
        v3Message.messageData = (uint8_t *)malloc(notifyParams->notifyDataSize);
        memcpy(v3Message.messageData, notifyParams->notifyData, notifyParams->notifyDataSize);
        v3Message.checkSum = checkSumLittleEndian;
        copyBleV3MessageRawData(&v3Message,notifyEncodeData);
        *notifyEncodeDataSize = sizeOfBLEKeyV3Message(&v3Message);
        return BleKeyV3NotifyRequestCreateSuccess;
    }
}

