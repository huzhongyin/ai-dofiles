import Foundation

enum BLECppParserDataType: String, Codable {
    case vehicleState = "vehicleState"
    case canEvent = "canEvent"
    case other = "OTHER"
    
    init(rawValue: String) {
        switch rawValue {
        case "vehicleState":
            self = .vehicleState
        case "canEvent":
            self = .canEvent
        default:
            // 如果没有匹配的值，返回一个默认值
            self = .other
        }
    }
}

enum BLECppParserCanEventType: String, Codable {
    case carControlResult = "carControlResult"
    case exceptionHandle = "exceptionHandle"
    case CDUAccountLoginState = "CDUAccountLoginState"
    case requestDisconnect = "requestDisconnect"
    case startRequestBleLocation = "startRequestBleLocation"
    case parking = "parking"
    case parkingCollision = "parkingCollision"
    case authResult = "authResult"
    case authRandom = "authRandom"
    case doublesidedAuth = "doublesidedAuth"
    case selfCalibration = "selfCalirationData"
    case rssiCollect = "rssiCollectData"
    case parkingControl = "parkingControl"
    case commonResponse = "commonResponse"
    case tboxRunState = "tboxRunState"
    case other = "other"
    
    init(rawValue: String) {
        switch rawValue {
        case "carControlResult":
            self = .carControlResult
        case "exceptionHandle":
            self = .exceptionHandle
        case "CDUAccountLoginState":
            self = .CDUAccountLoginState
        case "requestDisconnect":
            self = .requestDisconnect
        case "startRequestBleLocation":
            self = .startRequestBleLocation
        case "parking":
            self = .parking
        case "authResult":
            self = .authResult
        case "authRandom":
            self = .authRandom
        case "doublesidedAuth":
            self = .doublesidedAuth
        case "selfCalirationData":
            self = .selfCalibration
        case "rssiCollectData":
            self = .rssiCollect
        case "parkingControl":
            self = .parkingControl
        case "commonResponse":
            self = .commonResponse
        case "parkingCollision":
            self = .parkingCollision
        case "tboxRunState":
            self = .tboxRunState
        default:
            // 如果没有匹配的值，返回一个默认值
            self = .other
        }
    }
}

