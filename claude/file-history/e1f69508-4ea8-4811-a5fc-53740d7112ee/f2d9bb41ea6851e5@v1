- (BOOL)bleKeyExist{
    if ([CTMediator isSDK2ndCar]){
        return [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager existValidBlePrivateKey];
    }
    return [XPBLEKeyManager.instance isSafeKeyOrCertKeyExisted];
}

- (BOOL)monaWaitToActive {
    BOOL waitToActive = NO;
    
    NSString *keyWithVin = [NSString stringWithFormat:@"com.xiaopeng.XPCreateMonaKeyViewController.waitNearCar.%@.%lld", XPVehicleSDK.shared.vehicleManager.currentVehicle.vehiclePreference.vin, [CTMediator uid]];
    
    if (CTMediator.isMona) {
        if (![XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager existValidBleKey] && [MMKV.defaultMMKV getBoolForKey:keyWithVin] && [XPVehicleSDK existToBeActivateBLEKey]) {
            waitToActive = YES;
        }
    }
    return waitToActive;
}

- (BOOL)allowTurnOnLockWithSelfConfig{
    if ([CTMediator isPollingSecond]) {
        return YES;
    } else if ([CTMediator isPollingFirst]){
        if ([PollingEffectDataManager sharedManager].isGuanfangConfig) {
            return YES;
        } else {
            return [[PollingEffectDataManager sharedManager].keySettingTool getSelfCalibrationIsUse];
        }
    }
    return YES;
}

- (PollingRunMode)getPollingStatus{
    if (CTMediator.isMona) {
        if([XPMonaSDKSpecialManager.shared getUnlock] || [XPMonaSDKSpecialManager.shared getLock]){
            if ([XPMonaSDKSpecialManager.shared getUnlock] && [XPMonaSDKSpecialManager.shared getLock]) {
                return PollingRunModeLockAndUnlock;
            }else if([XPMonaSDKSpecialManager.shared getUnlock]){
                return PollingRunModeUnLock;
            }else {
                return PollingRunModeLock;
            }
        }else{
            return PollingRunModeNone;
        }
    }else{
        return [[XPMultiBleManager sharedManager] getPollingSettingFromMMKV];
    }
    
}

- (NSInteger)getMonaUnlockType {
    return [XPMonaSDKSpecialManager.shared getUnlockType];
}
    

