- (BOOL)showDriverModelNewFeatureNoteView {
    NSString *keyWithVin = [NSString stringWithFormat:@"%@.%@.%lld", kDidCloseDriverModeGuide, [CTMediator defaultCarVin], [CTMediator uid]];
    return
    XPVehicleSDK.currentAbilityConfig.bleKeyVersion != BleKeyProtocolVesionV3 &&
    [[XPMultiBleManager sharedManager] supportPassengerMode] &&
    ![CTMediator isE28] &&
    ![CTMediator isMona] &&
    [self bleKeyExist] && // 钥匙已激活
    ![MMKV.defaultMMKV getBoolForKey:keyWithVin] && // 未关闭引导
    (([CTMediator defaultCarInfo].releationType == ReleationType_Owner && !self.isPendingAuthList && self.authListCount > 0) || [CTMediator defaultCarInfo].releationType != ReleationType_Owner); // 当前车的授权人数量大于0
}

