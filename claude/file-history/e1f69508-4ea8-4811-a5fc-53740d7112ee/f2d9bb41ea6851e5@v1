#pragma mark - 逻辑

- (void)configStatus{
    self.tipView.hidden = YES;
    if(XPCarStateViewModel.sharedInstance.bleConnectState == XPCarConnectStateConnected){
       DLogTagInfo(kBLEKeyTag, @"蓝牙连接上");
        self.bleIcon.image = [UIImage imageNamed:@"dk_ble_status_online"];
       [self refreshConnectStatus];
   }else if(self.state != CBManagerStatePoweredOn){
        DLogTagInfo(kBLEKeyTag, @"没打开蓝牙开关");
       self.bleIcon.image = [UIImage imageNamed:@"dk_ble_status_offline"];
        [self refreshNotOpenBleStatus];
    }else{
        DLogTagInfo(kBLEKeyTag, @"蓝牙开关已经打开但是没连上");
        self.bleIcon.image = [UIImage imageNamed:@"dk_ble_status_offline"];
        [self refreshBleDisConnectStatus];
    }
//    if ([self showDriverModelNewFeatureNoteView]) {
//        self.noteBgView.hidden = NO;
//    } else {
//        self.noteBgView.hidden = YES;
//    }
    self.noteBgView.hidden = YES;
}

- (void)addObservers{
    @weakify(self);
    [self.rac_deallocDisposable addDisposable:[[NSNotificationCenter.defaultCenter rac_addObserverForName:XPVehicleNotification.DigitalKeyStateChanged object:nil].deliverOnMainThread subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self)
        [self configStatus];
    }]];
    
    [self.noteHitBtn bk_whenTapped:^{
//        @strongify(self);
//        [XPToast showMessage:@"点击了解详情"];
        [XPRouterUtil openURL:@"xiaopeng://bbs/article?tid=3313223"];
    }];
    
    [self.closeNoteBtn bk_whenTapped:^{
        @strongify(self);
        [UIView animateWithDuration:0.3 animations:^{
            self.noteBgView.alpha = 0;
        } completion:^(BOOL finished) {
            self.noteBgView.hidden = YES;
            self.noteBgView.alpha = 1;
            NSString *keyWithVin = [NSString stringWithFormat:@"%@.%@.%lld", kDidCloseDriverModeGuide, [CTMediator defaultCarVin], [CTMediator uid]];
            [MMKV.defaultMMKV setBool:YES forKey:keyWithVin];
        }];
    }];
    
    [self.rac_deallocDisposable addDisposable:[XWCentralManager.shared.stateSignal subscribeNext:^(NSNumber * _Nullable x) {
        //DLogTagError(kBluetoothPileTag, @"XWCentralManager state %ld", [x integerValue]);
        @strongify(self);
        self.state = [x integerValue];
        [self configStatus];
    }]];
    self.centralManager = [[CBCentralManager alloc] initWithDelegate:self
                                                               queue:dispatch_get_main_queue()
                                                             options:@{CBCentralManagerOptionShowPowerAlertKey:@NO}];
}

#pragma mark CBCentralManagerDelegate
- (void)centralManagerDidUpdateState:(CBCentralManager *)central{
    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(0.5 * NSEC_PER_SEC)), dispatch_get_main_queue(), ^{
        [self configStatus];
    });
    
}

#pragma mark - 复杂逻辑-https://xiaopeng.feishu.cn/docx/FVtddRIacoSP3PxvHupclVG3nmF
- (void)refreshConnectStatus{
    self.checkButton.hidden = YES;
    self.turnOnButton.hidden = YES;
    //条件1 polling开关
    PollingRunMode pollingModel = [self getPollingStatus];
    if ([XPKeyManageHelp notSupportPolling]) {
        DLogTagInfo(kBLEKeyTag, @"P7&数字钥匙1.0不支持Polling");
        self.bleDes.text = @"蓝牙钥匙已连接";
    }else if ([XPKeyManageHelp supportPolling] || [CTMediator isMona]) {
        DLogTagInfo(kBLEKeyTag, @"数字钥匙1.0支持Polling 或 数字钥匙2.0 或 mona mode:%lu", (unsigned long)pollingModel);
        if (pollingModel == PollingRunModeLockAndUnlock) {
            self.bleDes.text = @"靠近自动解锁,离开自动闭锁";
        }else if (pollingModel == PollingRunModeUnLock) {
            self.bleDes.text = @"靠近自动解锁";
            if ([CTMediator isMona] && [self getMonaUnlockType] == 1) {
                self.bleDes.text = @"触摸把手按键解锁车辆";
            }
        }else if (pollingModel == PollingRunModeLock) {
            self.bleDes.text = @"离开自动闭锁";
        }else {
            self.bleDes.text = @"点击“车锁”解锁启动或闭锁车辆";
        }
    }else if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
        BOOL isUWBKey = XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager.vaildBleKeyCategory == XPDigitalKeyCategoryPHONE_UWB_KEY;
        DLogTagInfo(kBLEKeyTag, @"数字钥匙3.0 isUWBKey:%d passEntryState:%ld", isUWBKey,(long)self.passEntryState);
        if (isUWBKey) {
            BOOL doorHandleLockUnlockOn = [[XPMultiBleManager sharedManager] getCurrentKeyPollingEnable];
            if (self.passEntryState == XPCarKeyPollingSwitchStateOn|| self.passEntryState == XPCarKeyPollingSwitchStateUnknown) {
                 self.bleDes.text = @"蓝牙已连接";
             } else {
                 if (doorHandleLockUnlockOn || pollingModel != PollingRunModeNone) {
                     self.tipView.hidden = NO;
                 }
                 self.turnOnButton.hidden = NO;
                 [self.turnOnButton setTitle:@"立即开启" forState:UIControlStateNormal];
                 self.bleDes.text = @"开启“舒适进入”以恢复钥匙定位";
                 
             }
        }else {
            self.bleDes.text = @"蓝牙已连接";
        }
    }
}

- (void)refreshNotOpenBleStatus{
    if(![self bleKeyExist]){
        [self refreshBleDisConnectStatus];
        return;
    }
    if ([XPCarKeyHelp.shared localCarKeyIsVaild] && ![self hasBindedCarkey]) {
        DLogTagInfo(kBLEKeyTag, @"钱包钥匙生效但是没绑定");
        self.bleDes.text = @"请绑定帐号解锁将自动登录";
        [self.turnOnButton setTitle:@"立即绑定" forState:UIControlStateNormal];
        self.turnOnButton.hidden = NO;
        return;
    }
    self.turnOnButton.hidden = NO;
    self.checkButton.hidden = YES;
    self.bleDes.text = @"蓝牙未开启";
    [self.turnOnButton setTitle:@"立即开启" forState:UIControlStateNormal];
}

- (void)refreshBleDisConnectStatus{
    self.checkButton.hidden = YES;
    self.turnOnButton.hidden = YES;
    
    if ([XPKeyManageHelp notSupportPolling]) {
        DLogTagInfo(kBLEKeyTag, @"P7&数字钥匙1.0不支持Polling");
        if (![self bleKeyExist]) {
            DLogTagInfo(kBLEKeyTag, @"没私有钥匙");
            self.bleDes.text = @"蓝牙钥匙未激活";
            [self.turnOnButton setTitle:@"立即激活" forState:UIControlStateNormal];
            self.turnOnButton.hidden = NO;
            return;
        }
        self.bleDes.text = @"请靠近车辆连接蓝牙";
        //self.checkButton.hidden = NO;
    }else if([XPKeyManageHelp supportPolling] || CTMediator.isMona || (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3 && [XPCarKeyHelp.shared supportCarKeyPairType] == XPCarKeyPairTypeNfc)){
        DLogTagInfo(kBLEKeyTag, @"数字钥匙1.0支持Polling 或 数字钥匙2.0 或 mona 或数字钥匙3.0的SE");
        if (![self bleKeyExist]) {
            DLogTagInfo(kBLEKeyTag, @"没私有钥匙");
            self.bleDes.text = @"蓝牙钥匙未激活";
            [self.turnOnButton setTitle:@"立即激活" forState:UIControlStateNormal];
            self.turnOnButton.hidden = NO;
            return;
        }
        
        [self privateKeyCheck];
        
    }else if(XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3){
        DLogTagInfo(kBLEKeyTag, @"数字钥匙3.0");
        if (XPCarKeyHelp.shared.localCarKeyIsVaild) {
            if (![self hasBindedCarkey]) {
                DLogTagInfo(kBLEKeyTag, @"钱包钥匙生效但是没绑定");
                self.bleDes.text = @"请绑定帐号解锁将自动登录";
                [self.turnOnButton setTitle:@"立即绑定" forState:UIControlStateNormal];
                self.turnOnButton.hidden = NO;
            } else {
                DLogTagInfo(kBLEKeyTag, @"钱包钥匙生效");
                self.bleDes.text = @"请靠近车辆连接蓝牙";
                self.turnOnButton.hidden = YES;
                PollingRunMode mode = [[XPMultiBleManager sharedManager] getPollingSettingFromMMKV];
                BOOL doorHandleLockUnlockOn = [[XPMultiBleManager sharedManager] getCurrentKeyPollingEnable];

                if (self.passEntryState == XPCarKeyPollingSwitchStateOn || self.passEntryState == XPCarKeyPollingSwitchStateUnknown) {
                     self.bleDes.text = @"请靠近车辆连接蓝牙";
                    self.turnOnButton.hidden = YES;
                 } else {
                     if (doorHandleLockUnlockOn || mode != PollingRunModeNone) {
                         self.tipView.hidden = NO;
                     }
                     self.turnOnButton.hidden = NO;
                     [self.turnOnButton setTitle:@"立即开启" forState:UIControlStateNormal];
                     self.bleDes.text = @"开启“舒适进入”以恢复钥匙定位";
                 }
            }
        }else{
            if (![self bleKeyExist]) {
                DLogTagInfo(kBLEKeyTag, @"没私有钥匙");
                self.bleDes.text = @"蓝牙钥匙未激活";
                [self.turnOnButton setTitle:@"立即激活" forState:UIControlStateNormal];
                self.turnOnButton.hidden = NO;
                return;
            }else{
                [self privateKeyCheck];
            }
        }
    }
}

- (BOOL)hasBindedCarkey{
    return XPCarKeyHelp.shared.bindType == XPCarKeyBindTypeBinded;
}

//私有钥匙检查
- (void)privateKeyCheck{
    PollingRunMode pollingModel = [self getPollingStatus];
    BOOL peEnable = [[XPMultiBleManager sharedManager] getCurrentKeyPollingEnable];
    //判断条件区分（1.0&2.0）和 3.0
    BOOL enable = XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3 ? pollingModel == PollingRunModeNone && !peEnable : pollingModel == PollingRunModeNone;
    if (([CTMediator isMona] && pollingModel == PollingRunModeNone) || (enable)) {
        DLogTagInfo(kBLEKeyTag, @"没开polling");
        if (([XPMultiBleManager checkIfAccuracyLocationPermissionGranted] && [XPMultiBleManager checkIfLocationPermissionGranted] && [XPMultiBleManager checkIfBackgroundPermissionGranted]) || ![[XPMultiBleManager sharedManager] getIsDriverMode]){
            DLogTagInfo(kBLEKeyTag, @"已经都有三个权限了");
            self.bleDes.text = @"请靠近车辆连接蓝牙";
            //self.checkButton.hidden = NO;
        }else{
            // 这里必定支持Polling，不需要再判断
//            XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV2 ||
//            XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3
            // https://xiaopeng.feishu.cn/docx/P0Msd4uV1ok6SGxs9TMcVlein1b
            self.bleDes.text = @"提升启动稳定性";
            [self.turnOnButton setTitle:@"立即优化" forState:UIControlStateNormal];
            self.turnOnButton.hidden = NO;
        }
    }else{
        DLogTagInfo(kBLEKeyTag, @"开了polling");
        if ([XPMultiBleManager checkIfAccuracyLocationPermissionGranted] && [XPMultiBleManager checkIfLocationPermissionGranted] && [XPMultiBleManager checkIfBackgroundPermissionGranted]) {
            DLogTagInfo(kBLEKeyTag, @"已经都有三个权限了");
            self.bleDes.text = @"请靠近车辆连接蓝牙";
            //self.checkButton.hidden = NO;
        }else{
            //只有位置不满足
            if ([XPMultiBleManager checkIfAccuracyLocationPermissionGranted] && [XPMultiBleManager checkIfBackgroundPermissionGranted]) {
                DLogTagInfo(kBLEKeyTag, @"没始终允许");
                self.bleDes.text = @"请选择“始终”允许访问位置信息";
                [self.turnOnButton setTitle:@"立即设置" forState:UIControlStateNormal];
                self.setUpType = XPKeyManageSetUpTypeNotAlways;
                self.turnOnButton.hidden = NO;
            }else{
                DLogTagInfo(kBLEKeyTag, @"除没始终允许，其他");
                self.bleDes.text = @"权限未开启";
                [self.turnOnButton setTitle:@"立即设置" forState:UIControlStateNormal];
                self.turnOnButton.hidden = NO;
                self.setUpType = XPKeyManageSetUpTypeOthers;
            }
        }
    }
}
    
- (void)clickTurnOn{
    NSInteger errorStyle = 0;
    if ([self.turnOnButton.titleLabel.text isEqualToString:@"立即开启"]) {
        errorStyle = 3;
        if (self.state == CBManagerStateUnauthorized) {
            DLogTagInfo(kBLEKeyTag, @"蓝牙没授权");
            [[UIApplication sharedApplication] openURL:[NSURL URLWithString:UIApplicationOpenSettingsURLString] options:@{} completionHandler:nil];
        }else if(self.state != CBManagerStatePoweredOn) {
            DLogTagInfo(kBLEKeyTag, @"蓝牙没开");
            XPBleGuideViewController *vc = [XPBleGuideViewController new];
            [vc showInViewController:[UIViewController currentFrontViewController]];
        }else {
            if (self.passEntryState == XPCarKeyPollingSwitchStateClose) {
                DLogTagInfo(kBLEKeyTag, @"启用舒适进入");
                if (self.delegate && [self.delegate respondsToSelector:@selector(activateComfortEnterWithTitle:)]) {
                    [self.delegate activateComfortEnterWithTitle:@" "];
                }
            }
        }
    }else if([self.turnOnButton.titleLabel.text isEqualToString:@"立即激活"]){
        errorStyle = 1;
        if (![[NetworkMonitorManager sharedManager] isReachable]) {
            [XPToast showMessage:@"网络未连接，请检查手机网络"];
            return;
        }
        if (CTMediator.isMona) {
            
            if (XPVehicleSDK.shared.vehicleManager.bleSysState != XPBLESysStatePoweredOn) {
                [QMUIAlertController showAlertWithTitle:nil
                                                message:@"激活钥匙需先开启手机蓝牙，请前往系统设置"
                                       leftButtionTitle:@"取消"
                                         leftButtonType:QMUIAlertActionStyleCancel
                                             leftAction:nil
                                       rightButtonTitle:@"设置"
                                        rightButtonType:QMUIAlertActionStyleDefault
                                            rightAction:^(__kindof QMUIAlertController * _Nonnull alertVC, QMUIAlertAction * _Nonnull action) {
                    NSURL *url = [NSURL URLWithString:UIApplicationOpenSettingsURLString];
                    if ([[UIApplication sharedApplication] canOpenURL:url])
                    {
                        [[UIApplication sharedApplication] openURL:url options:@{} completionHandler:nil];
                    }
                }];
                return;
            }
            
            if ([self monaWaitToActive]) {
                [XPToast showMessage:@"请先靠近车辆激活钥匙"];
                return;
            }
        }
        DLogTagInfo(kBLEKeyTag, @"创建蓝牙钥匙");
        XPCreateDigitalKeyViewModel *createViewModel = [[XPCreateDigitalKeyViewModel alloc] init];
        [createViewModel createKeyWithViewController:[UIViewController currentFrontViewController] andCarInfo:CTMediator.defaultCarInfo preventPopToRootViewController:NO];
        
//        XPCreateSelfKeyViewController *keyViewController = [XPCreateSelfKeyViewController new];
//        keyViewController.carInfo = CTMediator.defaultCarInfo;
//        keyViewController.preventPopToRootViewController = self;
//        [[UIViewController currentFrontViewController].navigationController pushViewController:keyViewController animated:YES];
    }else if([self.turnOnButton.titleLabel.text isEqualToString:@"立即优化"]){
        errorStyle = 4;
        DLogTagInfo(kBLEKeyTag, @"立即优化");
        DLogTagInfo(kBLEKeyTag, @"保活页");
        JRPermissionViewController *permissionVC = [[JRPermissionViewController alloc] init];
        [[UIViewController currentFrontViewController].navigationController pushViewController:permissionVC animated:YES];
        
    }else if([self.turnOnButton.titleLabel.text isEqualToString:@"立即设置"]){
        errorStyle = 5;
        if (self.setUpType == XPKeyManageSetUpTypeNotAlways) {
            PrivacyPermissionAuthorizationStatus locationAuthorizationStatus = [[PrivacyPermission sharedInstance] authorizationStatus:PrivacyPermissionTypeLocation];
            DLogTagInfo(kBLEKeyTag, @"始终允许跳转：%d", (int)locationAuthorizationStatus);
            if (locationAuthorizationStatus == PrivacyPermissionAuthorizationStatusNotDetermined ||
                locationAuthorizationStatus == PrivacyPermissionAuthorizationStatusUnkonwn) {
                JRPermissionViewController *permissionVC = [[JRPermissionViewController alloc] init];
                [[UIViewController currentFrontViewController].navigationController pushViewController:permissionVC animated:YES];
            }else {
                [[UIApplication sharedApplication] openURL:[NSURL URLWithString:UIApplicationOpenSettingsURLString] options:@{} completionHandler:nil];
            }
        }else if(self.setUpType == XPKeyManageSetUpTypeOthers){
            DLogTagInfo(kBLEKeyTag, @"保活页");
            JRPermissionViewController *permissionVC = [[JRPermissionViewController alloc] init];
            [[UIViewController currentFrontViewController].navigationController pushViewController:permissionVC animated:YES];
            //[self.navigationController pushViewController:permissionVC animated:YES];
            //[XPSelfConfigPollingViewController enterSelfConfigWithAnimated:YES currentVC:[UIViewController currentFrontViewController] delegate:nil];
        }
    }else if([self.turnOnButton.titleLabel.text containsString:@"点此解决"]){
        errorStyle = 6;
        UIViewController *vc = [CTMediator createBleCheckViewController:@{}];
        [[UIViewController currentFrontViewController] safePushViewController:vc animated:YES];
    }else if([self.turnOnButton.titleLabel.text containsString:@"查看钥匙状态"]){
        errorStyle = 2;
        DLogTagInfo(kBLEKeyTag, @"跳转钱包钥匙");
        [XPCarKeyHelp.shared openCarKeyPass];
    } else if ([self.turnOnButton.titleLabel.text containsString:@"立即绑定"]) {
        DLogTagInfo(kBLEKeyTag, @"绑定钱包钥匙");
        if (self.delegate && [self.delegate respondsToSelector:@selector(bindCarkeyAction)]) {
            [self.delegate bindCarkeyAction];
        }
    }
    NSDictionary *data = @{@"type":@(errorStyle)};
    [XPStatisticsMgr sendEvent:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_CONNECT_CLICK module:XP_CAR_CONTROL_KEY_MANAGEMENT_PAGE_MODULE data:data];
}

