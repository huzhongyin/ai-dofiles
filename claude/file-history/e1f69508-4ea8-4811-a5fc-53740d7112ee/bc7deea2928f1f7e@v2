#pragma mark rke
+ (NSData *_Nullable)generateQueryStateRequestData:(BOOL)isEncrypt
                                         controlId:(uint8_t)controlId
                                       controlData:(NSArray * _Nonnull)controlData
                                        sessionKey:(NSData * _Nullable)sessionKey
                                           hmacKey:(NSData * _Nullable)hmacKey {
    if (![controlData isKindOfClass:[NSArray class]]) {
        NSLog(@"controlData 不是 NSArray 类型");
        return nil;
    }
    NSUInteger count = [controlData count];
    uint8_t *bytes = (uint8_t *)malloc(sizeof(uint8_t) * count);
    if (bytes == NULL) {
        NSLog(@"内存分配失败");
        return nil;
    }
    // 遍历 controlData 数组，将其元素转换为 uint8_t 类型
    for (NSUInteger i = 0; i < count; i++) {
        NSNumber *number = controlData[i];
        if ([number isKindOfClass:[NSNumber class]]) {
            bytes[i] = (uint8_t)[number unsignedCharValue];
        } else {
            NSLog(@"controlData 中的元素不是 NSNumber 类型");
            free(bytes);
            return nil;
        }
    }
    BleKeyV3QueryStateParams queryStateParams = {
        controlId,(BLEKeyV3CarStateRKEType *)bytes,(uint8_t)count,(uint8_t *)sessionKey.bytes,(int)sessionKey.length,(uint8_t *)hmacKey.bytes,(uint8_t)hmacKey.length
    };
    uint8_t *queryStateEncodeData = (uint8_t *)malloc(most_trans_count_size);
    size_t queryStateEncodeDataSize = most_trans_count_size;
    BleKeyV3RkeRequestCreateResult result = createBleKeyV3QueryStateRequestWithInput(&queryStateParams, isEncrypt,  queryStateEncodeData, &queryStateEncodeDataSize);
    NSData *resultData = [NSData dataWithBytes:queryStateEncodeData length:queryStateEncodeDataSize];
    if (queryStateEncodeData != NULL) {
        free(queryStateEncodeData);
    }
    free(bytes);
    if (result == BleKeyV3RkeRequestCreateSuccess) {
        DLogTagInfo(@"XPBLEDataMake", @"提取单元测试：\nNSData *result = [XPBleKeyV3DataProcessor generateQueryStateRequestData:%@ controlId:%@ controlData:%@ sessionKey:[NSData dataWithHexString:@\"%@\"] hmacKey:[NSData dataWithHexString:@\"%@\"]];\n"
                    "NSString * testResultToHexStr = [result hexString];\n"
                    "NSString * testResultHexRight = @\"%@\"; // 当次执行结果 \n"
                    "XCTAssertTrue([testResultToHexStr isEqualToString:testResultHexRight]);\n",
                    @(isEncrypt), @(controlId), [self cmdArrayToOCCode:controlData], [sessionKey hexString], [hmacKey hexString], [resultData hexString]);
        return resultData;
    } else {
        DLogTagInfo(@"XPBLEDataMake", @"generateRkeControlRequestData result:<nil> [XPBleKeyV3DataProcessor generateQueryStateRequestData:%@ controlId:%@ controlData:%@ sessionKey:[NSData dataWithHexString:@\"%@\"] hmacKey:[NSData dataWithHexString:@\"%@\"]]", @(isEncrypt), @(controlId), [self cmdArrayToOCCode:controlData], [sessionKey hexString], [hmacKey hexString]);
        return nil;
    }
}

