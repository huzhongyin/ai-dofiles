unsigned char* bleHexStringToBytes(const char* hexString, size_t* length) {
    size_t hexStringLength = strlen(hexString);
    if (hexStringLength % 2 != 0) {
        // 如果字符串长度不是偶数，则返回NULL
        return NULL;
    }
    
    size_t byteLength = hexStringLength / 2;
    unsigned char* bytes = (unsigned char*)malloc(byteLength);
    if (bytes == NULL) {
        // 内存分配失败
        return NULL;
    }
    
    for (size_t i = 0, j = 0; i < hexStringLength; i += 2, j++) {
        // 将两个16进制字符转换为一个字节
        // 注意：这里假设输入的字符串是大写或小写，并通过tolower统一转换为小写
        unsigned char byte = 0;
        char byteString[3] = {0};
        strncpy(byteString, hexString + i, 2); // 复制两个字符
        sscanf(byteString, "%2hhx", &byte); // 读取两个十六进制字符并转换
        
        bytes[j] = byte;
    }
    
    if (length != NULL) {
        *length = byteLength;
    }
    
    return bytes;
}


@implementation XPBleKeyV3DataProcessor

+ (NSString *)compactJsonString:(NSString *)str {
    NSString * compactResult = [str stringByReplacingOccurrencesOfString:@"\r" withString:@""];
    compactResult = [compactResult stringByReplacingOccurrencesOfString:@"\n" withString:@""];
    compactResult = [compactResult stringByReplacingOccurrencesOfString:@"\t" withString:@""];
    compactResult = [compactResult stringByReplacingOccurrencesOfString:@"\"" withString:@"\\\""];
    return compactResult;
}

+ (NSString *)cmdArrayToOCCode:(NSArray * _Nonnull)array {
    
    __block NSString * codeStr = @"@[";
    [array enumerateObjectsUsingBlock:^(id  _Nonnull obj, NSUInteger idx, BOOL * _Nonnull stop) {
        NSNumber * number = (NSNumber *)obj;
        if ([number isKindOfClass:[NSNumber class]]) {
            codeStr = [codeStr stringByAppendingFormat:@"@(%@), ", number];
        }
    }];
    
    codeStr = [codeStr stringByAppendingString:@"]"];
    
    return codeStr;
}

+ (NSString *)dataArrayToOCCode:(NSArray * _Nonnull)array {
    
    __block NSString * codeStr = @"@[";
    [array enumerateObjectsUsingBlock:^(id  _Nonnull obj, NSUInteger idx, BOOL * _Nonnull stop) {
        NSData *diretionData = (NSData *)obj;
        if ([diretionData isKindOfClass:[NSData class]]) {
            codeStr = [codeStr stringByAppendingFormat:@"[NSData dataWithHexString:@\"%@\"], ", [diretionData hexString]];
        }
    }];
    
    codeStr = [codeStr stringByAppendingString:@"]"];
    
    return codeStr;
}

+ (NSString *)parseBleKeyV3MessageWithVehicleCode:(NSString *)vehicleCode bleData:(NSData *)bleData sessionKey:(NSData *)sessionKey authKey:(NSData *)authKey isEncrypted:(BOOL)isEncrypted {
    DLogTagInfo(@"receive ble data", @"bleData:[NSData dataWithHexString:@\"%@\"] sessionKey:[NSData dataWithHexString:@\"%@\"] authKey:[NSData dataWithHexString:@\"%@\"] isEncrypted:%@];\n"
        , [bleData hexString], [sessionKey hexString], [authKey hexString], @(isEncrypted));
    try {
        uint8_t *dataPointer = (uint8_t *)bleData.bytes;
        const char *vehicleTypeCode = [vehicleCode UTF8String];
        const char *cString = parseBleKeyV3Protocol(vehicleTypeCode, (const uint8_t *)dataPointer, bleData.length, (uint8_t *)sessionKey.bytes, (int)sessionKey.length, (uint8_t *)authKey.bytes, authKey.length, (int)isEncrypted);
        if (cString == NULL) {
            return NULL;
        }
        NSString *result = [NSString stringWithUTF8String:cString];
        releaseBluetoothBuffer(cString);

    //    DLogTagInfo(@"XPBLEDataMake", @"单元测试：NSString *result = [XPBleKeyV3DataProcessor parseBleKeyV3MessageWithVehicleCode:@\"%@\" bleData:[NSData dataWithHexString:@\"%@\"] sessionKey:[NSData dataWithHexString:@\"%@\"] authKey:[NSData dataWithHexString:@\"%@\"] isEncrypted:%@];\r\nresult:%@", vehicleCode, [bleData hexString], [sessionKey hexString], [authKey hexString], @(isEncrypted), result);
        NSString * compactResult = [self compactJsonString:result];
        DLogTagInfo(@"XPBLEDataMake", @"parseBleKeyV3MessageWithVehicleCode result:%@", result);
        DLogTagInfo(@"XPBLEDataMake", @"提取单元测试：\nNSString *result = [XPBleKeyV3DataProcessor parseBleKeyV3MessageWithVehicleCode:@\"%@\" bleData:[NSData dataWithHexString:@\"%@\"] sessionKey:[NSData dataWithHexString:@\"%@\"] authKey:[NSData dataWithHexString:@\"%@\"] isEncrypted:%@];\n"
            "NSDictionary * testMergedDict = [self mergedDictFromParsedStr:result];\n"
            "NSDictionary * testMergedDictRight = [self mergedDictFromParsedStr:@\"%@\"]; // 当次执行结果 \n"
            "XCTAssertTrue([testMergedDict isEqualToDictionary:testMergedDictRight]);\n",
            vehicleCode, [bleData hexString], [sessionKey hexString], [authKey hexString], @(isEncrypted), compactResult);
        
        return result;
    } catch (const std::exception& ) {
        DLogTagInfo(@"XPBLEDataMake", @"parseBleKeyV3MessageWithVehicleCode result:<nil> [XPBleKeyV3DataProcessor parseBleKeyV3MessageWithVehicleCode:@\"%@\" bleData:[NSData dataWithHexString:@\"%@\"] sessionKey:[NSData dataWithHexString:@\"%@\"] authKey:[NSData dataWithHexString:@\"%@\"] isEncrypted:%@];\n"
            , vehicleCode, [bleData hexString], [sessionKey hexString], [authKey hexString], @(isEncrypted));
    }
    return nil;

}

#pragma mark auth0
+ (NSData *_Nullable)generateAuth0DataIndictor:(NSString * _Nonnull)hexIndictor
                                           uid:(uint64_t)uid
                                      hexKeyId:(NSString * _Nonnull)hexKeyId
                                         rand0:(uint32_t)rand0
                                     timeStamp:(uint64_t)timeStamp
                                     isWelcome:(BOOL)isWelcome
                                 pollingSwitch:(uint8_t)pollingSwitch
                           pollingEnableSwitch:(BOOL)pollingEnableSwitch
                                unlockDistance:(float)unlockDistance
                                  lockDistance:(float)lockDistance
                            selfCalibrationLen:(uint8_t)selfCalibrationLen
                          selfCalibrationArray:(NSArray * _Nullable)selfCalibrationArray
                                   deviceModel:(NSString * _Nonnull)deviceModel
                                       bleName:(NSString * _Nonnull)bleName
                                    hexAuthKey:(NSString * _Nonnull)hexAuthKey
{
    size_t indicatorSize = 0;
    unsigned char * indictor = bleHexStringToBytes([hexIndictor cString], &indicatorSize);
    size_t keyIdSize = 0;
    unsigned char * keyId = bleHexStringToBytes([hexKeyId cString], &keyIdSize);
    uint8_t pollingUnlockDistance = (uint8_t)(unlockDistance + 0.5);
    uint8_t pollingLockDistance = (uint8_t)(lockDistance + 0.5);
    uint8_t *selfCalibrationData = NULL;
    if (selfCalibrationLen) {
        uint8_t len = 0;
        for (NSData *diretionData in selfCalibrationArray) {
            len += diretionData.length;
        }
        selfCalibrationData = (uint8_t *)malloc(len);
        uint8_t dataLen = 0;
        for (NSData *diretionData in selfCalibrationArray) {
            memcpy(selfCalibrationData+dataLen, diretionData.bytes, diretionData.length);
            dataLen += diretionData.length;
        }
    }
    NSData *deviceModelData = [deviceModel dataUsingEncoding:NSUTF8StringEncoding];
    NSData *bleNameData = [bleName dataUsingEncoding:NSUTF8StringEncoding];
    size_t authKeySize = 0;
    unsigned char * authKey = bleHexStringToBytes([hexAuthKey cString],&authKeySize);
    BleKeyV3PollingConfigParams pollingConfigParams = {
      isWelcome, pollingSwitch, pollingUnlockDistance, pollingLockDistance, selfCalibrationLen, selfCalibrationData
    };
    BleKeyV3Auth0Params auth0Params = {
        (uint8_t *)indictor, (uint8_t)indicatorSize, uid, keyId, (uint8_t)keyIdSize, rand0, timeStamp,
         pollingConfigParams,
         (uint8_t *)deviceModelData.bytes, (uint8_t)deviceModelData.length,
         (uint8_t *)bleNameData.bytes, (uint8_t)bleNameData.length,
         authKey, (uint8_t)authKeySize
    };
    uint8_t *auth0EncodeData = (uint8_t *)malloc(most_trans_count_size);
    size_t auth0EncodeDataSize = most_trans_count_size;
    BleKeyV3Auth0RequestCreateResult result = createBleKeyV3Auth0RequestWithInput(&auth0Params, pollingEnableSwitch, auth0EncodeData, &auth0EncodeDataSize);
    if (selfCalibrationData != NULL) {
        free(selfCalibrationData);
    }
    if (indictor != NULL) {
        free(indictor);
    }
    if (keyId != NULL) {
        free(keyId);
    }
    if (authKey != NULL) {
        free(authKey);
    }
    NSData *resultData = [NSData dataWithBytes:auth0EncodeData length:auth0EncodeDataSize];
    if (auth0EncodeData != NULL) {
        free(auth0EncodeData);
    }
    if (result == BleKeyV3Auth0RequestCreateSuccess) {
        DLogTagInfo(@"XPBLEDataMake", @"提取单元测试：\nNSData *result = [XPBleKeyV3DataProcessor generateAuth0DataIndictor:@\"%@\" uid:%@ hexKeyId:@\"%@\" rand0:%@ timeStamp:%@ isWelcome:%@ pollingSwitch:%@ pollingEnableSwitch:%@ unlockDistance:%@ lockDistance:%@ selfCalibrationLen:%@ selfCalibrationArray:%@ deviceModel:@\"%@\" bleName:@\"%@\" hexAuthKey:@\"%@\"];\n"
                    "NSString * testResultToHexStr = [result hexString];\n"
                    "NSString * testResultHexRight = @\"%@\"; // 当次执行结果 \n"
                    "XCTAssertTrue([testResultToHexStr isEqualToString:testResultHexRight]);\n", hexIndictor, @(uid), hexKeyId, @(rand0), @(timeStamp), @(isWelcome), @(pollingSwitch), @(pollingEnableSwitch), @(unlockDistance), @(lockDistance), @(selfCalibrationLen), [self dataArrayToOCCode:selfCalibrationArray], deviceModel, bleName, hexAuthKey, [resultData hexString]);
        return resultData;
    } else {
        DLogTagInfo(@"XPBLEDataMake", @"generateAuth0DataIndictor result:<nil> [XPBleKeyV3DataProcessor generateAuth0DataIndictor:@\"%@\" uid:%@ hexKeyId:@\"%@\" rand0:%@ timeStamp:%@ isWelcome:%@ pollingSwitch:%@ pollingEnableSwitch:%@ unlockDistance:%@ lockDistance:%@ selfCalibrationLen:%@ selfCalibrationArray:%@ deviceModel:@\"%@\" bleName:@\"%@\" hexAuthKey:@\"%@\"]", hexIndictor, @(uid), hexKeyId, @(rand0), @(timeStamp), @(isWelcome), @(pollingSwitch), @(pollingEnableSwitch), @(unlockDistance), @(lockDistance), @(selfCalibrationLen), [self dataArrayToOCCode:selfCalibrationArray], deviceModel, bleName, hexAuthKey);
        return nil;
    }
}

+ (NSData *)generateAuthKey:(NSString *)authKey {
    size_t authKeySize = 0;
    unsigned char * authKeyPtr = bleHexStringToBytes([authKey UTF8String],&authKeySize);
    NSData *authKeyData = [NSData dataWithBytes:authKeyPtr length:authKeySize];
    free(authKeyPtr);
    return authKeyData;
}

+ (NSData *)generateSessionKey:(NSString * _Nonnull)hexAuthKey
                      hexKeyId:(NSString * _Nonnull)hexKeyId
                         rand0:(uint32_t)rand0
                         rand1:(uint32_t)rand1 {
    size_t authKeySize = 0;
    unsigned char * authKey = bleHexStringToBytes([hexAuthKey cString],&authKeySize);
    size_t keyIdSize = 0;
    unsigned char * keyId = bleHexStringToBytes([hexKeyId cString],&keyIdSize);
    uint8_t *sessionKey = (uint8_t *)malloc(hKdfSha256Size);
    size_t sessionKeySize = hKdfSha256Size;
    getSessionKey(sessionKey,sessionKeySize, rand0, rand1, authKey, authKeySize, keyId,keyIdSize);
    NSData *sessionKeyData = [NSData dataWithBytes:sessionKey length:sessionKeySize];
    free(authKey);
    free(keyId);
    free(sessionKey);
    
    DLogTagInfo(@"XPBLEDataMake", @"提取单元测试：\nNSData *result = [XPBleKeyV3DataProcessor generateSessionKey:@\"%@\" hexKeyId:@\"%@\" rand0:%@ rand1:%@];\n"
        "NSString * testResultToHexStr = [result hexString];\n"
        "NSString * testResultHexRight = @\"%@\"; // 当次执行结果 \n"
        "XCTAssertTrue([testResultToHexStr isEqualToString:testResultHexRight]);\n",
                hexAuthKey, hexKeyId, @(rand0), @(rand1), [sessionKeyData hexString]);

    return sessionKeyData;
}

+ (NSData *)generateHmacKey:(NSString * _Nonnull)hexAuthKey
                     rand01:(uint32_t)rand01
                     rand12:(uint32_t)rand12 {
    size_t authKeySize = 0;
    unsigned char * authKey = bleHexStringToBytes([hexAuthKey cString],&authKeySize);
    unsigned int hmacKeySize;
    unsigned char iv_copy[16];
    memcpy(iv_copy, bleKeyV3IvData, 16);
    unsigned char *hmacKey = getHmacKey((const uint8_t *)authKey, authKeySize, rand01, rand12, iv_copy, &hmacKeySize);
    NSData *hmacKeyData = [NSData dataWithBytes:hmacKey length:hmacKeySize];
    free(authKey);
    free(hmacKey);
    
    DLogTagInfo(@"XPBLEDataMake", @"提取单元测试：\nNSData *result = [XPBleKeyV3DataProcessor generateHmacKey:@\"%@\" rand01:%@ rand12:%@];\n"
        "NSString * testResultToHexStr = [result hexString];\n"
        "NSString * testResultHexRight = @\"%@\"; // 当次执行结果 \n"
        "XCTAssertTrue([testResultToHexStr isEqualToString:testResultHexRight]);\n",
                hexAuthKey, @(rand01), @(rand12), [hmacKeyData hexString]);
    return hmacKeyData;
}

