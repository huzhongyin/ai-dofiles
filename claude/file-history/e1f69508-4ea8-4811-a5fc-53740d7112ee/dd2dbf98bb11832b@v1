public class ParkStateChangedNotiObject : NSObject {
    let parkState: Int? // 泊车状态
    let speed: Int? // 泊车过程实时车速
    let gear: Int? // 档位
    let animation: Int? // 泊车动画
    let progress: Int? // 泊车进度
    let failCode: Int? // 泊车失败活暂停原因
    let leaveParkState: Int? // 离车泊入可用状态
    let welcomeParkOutState: Int? // 迎宾出库可用状态
    let parkOutAvailableDirection: Int? // 泊车可用方向
    let parkOutCurrentDirection: Int? // 当前车辆泊出方向
    let parkOutDirectionIfOk: Int? // 当前选定的泊出方向是否可用
    let parkOutRecommendDirection: Int? // 推荐泊出方向
    let parkOutState: Int? // 迎宾出库状态
    let parkInState: Int? // 离车泊入状态

    public init(parkState: Int?, speed: Int?, gear: Int?, animation: Int?, progress: Int?, failCode: Int?, leaveParkState: Int?, welcomeParkOutState: Int?, parkOutAvailableDirection: Int?, parkOutCurrentDirection: Int?, parkOutDirectionIfOk: Int?, parkOutRecommendDirection: Int?, parkOutState: Int?, parkInState: Int?) {
        self.parkState = parkState;
        self.speed = speed;
        self.gear = gear;
        self.animation = animation;
        self.progress = progress;
        self.failCode = failCode;
        self.leaveParkState = leaveParkState;
        self.welcomeParkOutState = welcomeParkOutState;
        self.parkOutDirectionIfOk = parkOutDirectionIfOk;
        self.parkOutAvailableDirection = parkOutAvailableDirection;
        self.parkOutCurrentDirection = parkOutCurrentDirection;
        self.parkOutRecommendDirection = parkOutRecommendDirection;
        self.parkOutState = parkOutState;
        self.parkInState = parkInState;
    }
    
    public override var description: String {
        return "ParkStateChangedNotiObject:<parkState:\(parkState), animation:\(animation), progress:\(progress), gear:\(gear), failCode:\(failCode)>"
    }
}

