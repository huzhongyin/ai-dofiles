- (void)configPollingRunMode:(PollingRunMode)pollingRunMode {
    NSString *keyWithVin = [XPCSecondPollingDataHandler appendVinToKey];
    DLogTagInfo(kBLEKeyPollingTag, @"Polling设置 mode: %d keyWithVin:%@", pollingRunMode, keyWithVin);
    if(pollingRunMode == PollingRunModeNone){
        if (CTMediator.isSDK2ndCar && [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager vaildBleKeyCategory] == XPDigitalKeyCategoryPHONE_UWB_KEY) {
            [PollingEffectDataManager.sharedManager.keySettingTool setWalletKeyLock:@(NO)];
            [PollingEffectDataManager.sharedManager.keySettingTool setWalletKeyUnlock:@(NO)];
        }else {
            [PollingEffectDataManager.sharedManager.keySettingTool setPollingLock:@(NO)];
            [PollingEffectDataManager.sharedManager.keySettingTool setPollingUnlock:@(NO)];
        }
    } else {
        BOOL lock = (pollingRunMode == PollingRunModeLock || pollingRunMode == PollingRunModeLockAndUnlock);
        BOOL unlock = (pollingRunMode == PollingRunModeUnLock || pollingRunMode == PollingRunModeLockAndUnlock);
        if (CTMediator.isSDK2ndCar && [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager vaildBleKeyCategory] == XPDigitalKeyCategoryPHONE_UWB_KEY) {
            [PollingEffectDataManager.sharedManager.keySettingTool setWalletKeyLock:@(lock)];
            [PollingEffectDataManager.sharedManager.keySettingTool setWalletKeyUnlock:@(unlock)];
        }else {
            [PollingEffectDataManager.sharedManager.keySettingTool setPollingLock:@(lock)];
            [PollingEffectDataManager.sharedManager.keySettingTool setPollingUnlock:@(unlock)];
        }
    }
}

- (PollingRunMode)pollingRunMode {
    if (CTMediator.isSDK2ndCar && [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager vaildBleKeyCategory] == XPDigitalKeyCategoryPHONE_UWB_KEY) {
        BOOL lock = [PollingEffectDataManager.sharedManager.keySettingTool getWalletKeyLockWithDefaultValue:kWalletKeyDefaultLock];
        BOOL unlock = [PollingEffectDataManager.sharedManager.keySettingTool getWalletKeyUnlockWithDefaultValue:kWalletKeyDefaultUnLock];
        return [XPCSecondPollingDataHandler modeWithPollingUnlock:@(unlock) pollingLock:@(lock)];
    }else {
        BOOL lock = [PollingEffectDataManager.sharedManager.keySettingTool getPollingLockWithDefaultValue:kPrivateKeyDefaultLock];
        BOOL unlock = [PollingEffectDataManager.sharedManager.keySettingTool getPollingUnlockWithDefaultValue:kPrivateKeyDefaultUnLock];
        return [XPCSecondPollingDataHandler modeWithPollingUnlock:@(unlock) pollingLock:@(lock)];
    }
}

