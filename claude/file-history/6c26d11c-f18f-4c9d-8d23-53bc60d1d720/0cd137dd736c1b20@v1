+ (XPMultiBleManager *)sharedManager {
    static id sharedManager = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        sharedManager = [[self alloc] init];
    });
    
    return sharedManager;
}

- (instancetype)init {
    if (self = [super init]) {
        _bleEventTool = [[XPMultiBleEventTool alloc]init];
        _bleLocationTool = [[XPMultiBleLocationResultTool alloc]init];
    }
    return self;
}

- (void)start {
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        @weakify(self);
        [[CTMediator.defaultCarSwitchedSignal.deliverOnMainThread takeUntil:self.rac_willDeallocSignal] subscribeNext:^(id  _Nullable x) {
            @strongify(self)
            NSString *vin = [CTMediator defaultCarVin];
            if ([CTMediator isLogin]) {
                if ([NSString isEmptyWithString:vin]) {
                    [self switchDiffCar:vin];
                } else {
                    PollingEffectDataManager.sharedManager.keySettingTool = [[XPKeySettingSyncTool alloc]initWithVin:vin uid:CTMediator.uid deviceModel:[XPUtility deviceModelName] delegate:PollingEffectDataManager.sharedManager];
                    PollingEffectDataManager.sharedManager.keySettingTool.remoteDataDelegate = self;
                    if (CTMediator.isPollingFirst || CTMediator.isPollingSecond) {
                        if (!self.currentVin) {
                            DLogTagInfo(kBLEKeyPollingTag, @"<PA> 第一次获取vin，初始化polling与定位资源");
                            [self switchDiffCar:vin];
                        } else {
                            if (![self.currentVin isEqualToString:vin]) {
                                DLogTagInfo(kBLEKeyPollingTag, @"<PA> vin不相同，重新初始化polling与定位资源");
                                [self switchDiffCar:vin];
                            } else {
                                DLogTagInfo(kBLEKeyPollingTag, @"<PA> vin相同，不初始化polling资源");
                            }
                        }
                    } else {
                        [self switchDiffCar:nil];
                    }
                }
            } else {
                [self switchDiffCar:nil];
            }
        }];
        
        [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:LogInOutNotification object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
            @strongify(self);
            if (!CTMediator.isLogin) {
                [self switchDiffCar:nil];
            } else {
                [self switchDiffCar:self.currentVin];
            }
        }];
        
    });
}

#pragma mark - Permission
+ (BOOL)checkIfPermissionGranted{
    return [self checkIfLocationPermissionGranted] && [self checkIfAccuracyLocationPermissionGranted] && [self checkIfBackgroundPermissionGranted];
}

+ (BOOL)checkIfLocationPermissionGranted{
    PrivacyPermissionAuthorizationStatus locationAuthorizationStatus = [[PrivacyPermission sharedInstance] authorizationStatus:PrivacyPermissionTypeLocation];
    if(locationAuthorizationStatus != PrivacyPermissionAuthorizationStatusLocationAlways) {
        return NO;
    }
    return YES;
}

+ (BOOL)checkIfAccuracyLocationPermissionGranted{
    PrivacyPermissionAuthorizationStatus accuracyAuthorizationStatus = [[PrivacyPermission sharedInstance] authorizationStatus:PrivacyPermissionTypeAccuracy];
    if(accuracyAuthorizationStatus != PrivacyPermissionAuthorizationStatusAuthorized){
        return NO;
    }
    return YES;
}

+ (BOOL)checkIfBackgroundPermissionGranted{
    PrivacyPermissionAuthorizationStatus backgroundAuthorizationStatus = [[PrivacyPermission sharedInstance] authorizationStatus:PrivacyPermissionTypeBackgroundRefresh];
    if(backgroundAuthorizationStatus == PrivacyPermissionAuthorizationStatusDenied){
        return NO;
    }
    return YES;
}

#pragma mark — pollingRunModeSetting
- (PollingRunMode)getPollingSettingFromMMKV {
    if (CTMediator.isSDK2ndCar && [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager vaildBleKeyCategory] == XPDigitalKeyCategoryPHONE_UWB_KEY) {
        BOOL lock = [PollingEffectDataManager.sharedManager.keySettingTool getWalletKeyLockWithDefaultValue:kWalletKeyDefaultLock];
        BOOL unLock = [PollingEffectDataManager.sharedManager.keySettingTool getWalletKeyUnlockWithDefaultValue:kWalletKeyDefaultUnLock];
        return [XPCSecondPollingDataHandler modeWithPollingUnlock:@(unLock) pollingLock:@(lock)];
    }else {
        BOOL lock = [PollingEffectDataManager.sharedManager.keySettingTool getPollingLockWithDefaultValue:kPrivateKeyDefaultLock];
        BOOL unLock = [PollingEffectDataManager.sharedManager.keySettingTool getPollingUnlockWithDefaultValue:kPrivateKeyDefaultUnLock];
        return [XPCSecondPollingDataHandler modeWithPollingUnlock:@(unLock) pollingLock:@(lock)];
    }
}

- (void)switchPollingOff {
    [self configPollingRunMode:PollingRunModeNone];
    if ([CTMediator isSDK2ndCar]) {
        [XPPollingSDK configPollingMode:self.pollingRunMode];
    }
}

- (void)switchPollingUnlock:(BOOL)on {
    if (on) {
        if (self.pollingRunMode == PollingRunModeNone){
            [self configPollingRunMode:PollingRunModeUnLock];
        } else if (self.pollingRunMode == PollingRunModeLock) {
            [self configPollingRunMode:PollingRunModeLockAndUnlock];
        }
    } else {
        if (self.pollingRunMode == PollingRunModeUnLock) {
            [self configPollingRunMode:PollingRunModeNone];
        } else if (self.pollingRunMode == PollingRunModeLockAndUnlock) {
            if (CTMediator.isPollingSecond) {
                [self configPollingRunMode:PollingRunModeLock];
            } else {
                [self configPollingRunMode:PollingRunModeNone];
            }
        }
    }
    if ([CTMediator isSDK2ndCar]) {
        [XPPollingSDK configPollingMode:self.pollingRunMode];
    }
}

- (void)switchPollingUnLockAndLock:(BOOL)on{
    if (on) {
        [self configPollingRunMode:PollingRunModeLockAndUnlock];
    } else {
        [self configPollingRunMode:PollingRunModeNone];
    }
    if ([CTMediator isSDK2ndCar]) {
        [XPPollingSDK configPollingMode:self.pollingRunMode];
    }
}

- (void)switchPollingLock:(BOOL)on {
    if (on) {
        if (self.pollingRunMode == PollingRunModeNone){
            if (CTMediator.isPollingSecond) {
                [self configPollingRunMode:PollingRunModeLock];
            }
        } else if (self.pollingRunMode == PollingRunModeUnLock) {
            [self configPollingRunMode:PollingRunModeLockAndUnlock];
        }
    } else {
        if (self.pollingRunMode == PollingRunModeLock) {
            [self configPollingRunMode:PollingRunModeNone];
        } else if (self.pollingRunMode == PollingRunModeLockAndUnlock) {
            [self configPollingRunMode:PollingRunModeUnLock];
        }
    }
    if ([CTMediator isSDK2ndCar]) {
        [XPPollingSDK configPollingMode:self.pollingRunMode];
    }
}

