-(void)switchIsDriverMode:(BOOL)on {
    [self syncPollingRunMode:on];
    [PollingEffectDataManager.sharedManager.keySettingTool switchIsDriverMode:on];
}

-(BOOL)getIsDriverMode {
    if (![self supportPassengerMode]) {
        DLogTagInfo(kBLEKeySettingTag, @"不支持乘客模式，默认是主驾");
        return YES; // 不支持乘客模式，默认是主驾
    }
    MyCarInfo *carInfo = CTMediator.defaultCarInfo;

    // 剔除车型
    if ([carInfo isMona]) {
        return YES;
    }
    // 剔除钥匙类型
    if ([carInfo isE28] || XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
        return YES;
    }
    return [PollingEffectDataManager.sharedManager.keySettingTool getIsDriverMode];
}

// 如果设置了乘客模式，同步修改PollingRunMode
- (void)syncPollingRunMode:(BOOL)on {
    if (on) {
        // 恢复polling的原始值
        [self configPollingRunMode:[XPCSecondPollingDataHandler getPreviousPollingMode]];
    } else {
        // 保存polling的上一次的值
        [self saveOldPollingMode];
        [self configPollingRunMode:PollingRunModeNone];
    }
}

- (void)saveOldPollingMode {
    [XPCSecondPollingDataHandler savePreviousPollingMode:self.pollingRunMode];
}

- (BOOL)supportPassengerMode {
    static BOOL enabled = NO;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        id obj = [CloudConfig configForKeyPath:@"carcontrol.digitalKey.supportPassengerMode"];
        if ([obj isKindOfClass:NSNumber.class]) {
            enabled = ((NSNumber *)obj).boolValue;
        }
    });
    return enabled;
}

