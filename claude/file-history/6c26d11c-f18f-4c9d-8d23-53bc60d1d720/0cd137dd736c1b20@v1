- (void)keySettingTool:(XPKeySettingSyncTool *)keySettingTool didFetchRemoteData:(XPKeySettingDataV2Model *)model {
    DLogTagInfo(kBLEKeySettingTag, @"polling setting remote lock:%@,unlock:%@,enablePE:%@", model.pollingLock, model.pollingUnlock, model.enablePE);
    if ([model isKindOfClass:[XPKeySettingDataV2Model class]]) {
        // 本地未修改，而且获取到远端的值是False，同步修改PollingRunMode
        if (![keySettingTool localIsDriverModeIsModify] &&
            model.isDriverMode == NO &&
            self.pollingRunMode != PollingRunModeNone) {
            [self syncPollingRunMode:NO];
        }
    }
}

- (void)keySettingTool:(XPKeySettingSyncTool *)keySettingTool updatePollingMode:(PollingRunMode)mode {
    if (CTMediator.isSDK2ndCar && [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager vaildBleKeyCategory] == XPDigitalKeyCategoryPHONE_UWB_KEY) {
        return;
    }
    DLogTagInfo(kBLEKeyPollingTag, @"Polling设置 mode polling: %d", mode);
    self.pollingRunMode = mode;
    if(mode == PollingRunModeNone){
        [self endPollingSDK];
    } else {
        [self endPollingSDK];
        [self startPollingSDK];
        [self judgeBleLocationIsPaused];
    }
}

- (void)keySettingTool:(XPKeySettingSyncTool *)keySettingTool updateWalletMode:(PollingRunMode)mode {
    if (!CTMediator.isSDK2ndCar || [XPVehicleSDK.shared.vehicleManager.currentVehicle.digitalKeyManager vaildBleKeyCategory] != XPDigitalKeyCategoryPHONE_UWB_KEY) {
        return;
    }
    DLogTagInfo(kBLEKeyPollingTag, @"Polling设置 mode wallet: %d", mode);
    self.pollingRunMode = mode;
}

