- (void)startPollingSDK {

    if ([CTMediator isSDK2ndCar]) {
        [self configV3Manager];
        DLogTagInfo(kMultiBleOptTag, @"触发Polling，禁止旧polling");
        return;
    }
    DLogTagInfo(kMultiBleOptTag, @"即将启动PollingSDK");
    [self configV3Manager];
    if (self.currentCarIsPollingStart) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>已经初始化过pollingSDK");
        return;
    }
    
    if(![XPBLEKeyManager.instance isSafeKeyOrCertKeyExisted]) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>用户不存在钥匙，初始化polling失败，返回");
        return;
    }
    
    if (self.pollingRunMode == PollingRunModeNone) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>self.pollingRunMode == PollingRunModeNone，返回");
        return;
    }
    
    NSString *mainBleMacAddress = [XPBLEKeyManager getCurrentBleMacAddress];
    if(mainBleMacAddress.length <= 0) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>主蓝牙为空，初始化polling失败，返回");
        return;
    }
    
    if(!(CTMediator.isPollingFirst || CTMediator.isPollingSecond)) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>不是多蓝牙车型，没有polling功能");
        return;
    }
    if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion != BleKeyProtocolVesionV3) {
        self.blePollingLifeManager = [XPPollingManager sharedManager];
        PollingEffectDataManager.sharedManager.blePollingUpdateDataManager = [XPPollingManager sharedManager];
        [self.bleEventTool addBleCarEventManager:[XPPollingManager sharedManager]];
        [self.bleEventTool addBleConnectEventManager:[XPPollingManager sharedManager]];
        [self.bleLocationTool addBleLocationResultManager:[XPPollingManager sharedManager]];
        if ([self.blePollingLifeManager respondsToSelector:@selector(initBlePolling:unlockDistance:isWelcome:isConverient:isRemedy:isPollingLockSoundOn:)]) {
            [self.blePollingLifeManager initBlePolling:self.pollingRunMode unlockDistance:[PollingEffectDataManager.sharedManager.keySettingTool getUnlockDistance] isWelcome:[PollingEffectDataManager.sharedManager.keySettingTool getWelcomeMode] isConverient:[PollingEffectDataManager.sharedManager.keySettingTool getBleAutoSensitivity] isRemedy:self.carStateIsRemedy isPollingLockSoundOn:[PollingEffectDataManager.sharedManager.keySettingTool getLockSound]];
        }
    }
    [self.bleEventTool syncCachedEvent];
    [self judgePollingIsPaused];
    self.currentCarIsPollingStart = YES;
}

- (void)configV3Manager{
    if (XPVehicleSDK.currentAbilityConfig.bleKeyVersion == BleKeyProtocolVesionV3) {
        PollingEffectDataManager.sharedManager.blePollingUpdateDataManager = [XPBLEHandlerManager manager];
    }
}

- (void)endPollingSDK {
    DLogTagInfo(kMultiBleOptTag, @"结束PollingSDK");
    if (self.currentCarIsPollingStart) {
        if ([self.blePollingLifeManager respondsToSelector:@selector(deinitBlePolling:)]) {
            [self.blePollingLifeManager deinitBlePolling:self.pollingRunMode];
        }
        self.blePollingLifeManager = nil;
        PollingEffectDataManager.sharedManager.blePollingUpdateDataManager = nil;
        [self.bleEventTool removeCarBleEventManager:[XPPollingManager sharedManager]];
        [self.bleEventTool removeBleConnectEventManager:[XPPollingManager sharedManager]];
        [self.bleLocationTool removeBleLocationResultManager:[XPPollingManager sharedManager]];
        
        self.currentCarIsPollingStart = NO;
    }
}

- (void)startBleLocationSDK {
    if ([CTMediator isSDK2ndCar]) {
        DLogTagInfo(kMultiBleOptTag, @"触发定位SDK，禁止旧定位逻辑");
        return;
    }
    DLogTagInfo(kMultiBleOptTag, @"即将启动定位SDK");
    if (self.currentCarIsBleLocationStart) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>已经初始化过定位SDK");
        return;
    }
    if(![XPBLEKeyManager.instance isSafeKeyOrCertKeyExisted]) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>用户不存在钥匙，初始化定位SDK失败，返回");
        return;
    }
    
    NSString *mainBleMacAddress = [XPBLEKeyManager getCurrentBleMacAddress];
    if(mainBleMacAddress.length <= 0) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>主蓝牙为空，初始化定位SDK失败，返回");
        return;
    }
    
    if(XPVehicleSDK.currentAbilityConfig.pollingLocationVersion == BleLocationVersionNotSupport && XPVehicleSDK.currentAbilityConfig.parkingLocationVersion == BleLocationVersionNotSupport) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>不是多蓝牙车型，没有定位功能");
        return;
    }
    if (self.currentBleHardWare.length <= 0) {
        DLogTagInfo(kMultiBleOptTag, @"<PA>多蓝牙硬件版本号位空，返回");
        return;
    }
    
    self.bleLocationLifeManager = [XPBleLocationManager sharedManager];
    PollingEffectDataManager.sharedManager.bleLocationUpdateDataManager = [XPBleLocationManager sharedManager];
    [self.bleEventTool addBleCarEventManager:[XPBleLocationManager sharedManager]];
    [self.bleEventTool addBleConnectEventManager:[XPBleLocationManager sharedManager]];
    if ([self.bleLocationLifeManager respondsToSelector:@selector(initBleLocation:bleHardWare:thresholdData:customeUnlockDistance:)]) {
        if (self.isInParkingController && self.mobileParkingNeedLocation) {
            [self.bleLocationLifeManager initBleLocation:XPVehicleSDK.currentAbilityConfig.parkingLocationVersion bleHardWare:self.currentBleHardWare thresholdData:[[PollingEffectDataManager sharedManager] getPollingThreshold:XPVehicleSDK.currentAbilityConfig.parkingLocationVersion] customeUnlockDistance:[PollingEffectDataManager.sharedManager.keySettingTool getUnlockDistance]];
        } else {
            [self.bleLocationLifeManager initBleLocation:XPVehicleSDK.currentAbilityConfig.pollingLocationVersion bleHardWare:self.currentBleHardWare thresholdData:[[PollingEffectDataManager sharedManager] getPollingThreshold:XPVehicleSDK.currentAbilityConfig.pollingLocationVersion] customeUnlockDistance:[PollingEffectDataManager.sharedManager.keySettingTool getUnlockDistance]];
        }
    }
    [self judgeBleLocationIsPaused];
    self.currentCarIsBleLocationStart = YES;
}

- (void)endBleLocationSDK {
    DLogTagInfo(kMultiBleOptTag, @"结束定位SDK");
    if (self.currentCarIsBleLocationStart) {
        if ([self.bleLocationLifeManager respondsToSelector:@selector(deinitBleLocation)]) {
            [self.bleLocationLifeManager deinitBleLocation];
        }
        self.bleLocationLifeManager = nil;
        PollingEffectDataManager.sharedManager.bleLocationUpdateDataManager = nil;
        [self.bleEventTool removeCarBleEventManager:[XPBleLocationManager sharedManager]];
        [self.bleEventTool removeBleConnectEventManager:[XPBleLocationManager sharedManager]];
        self.currentCarIsBleLocationStart = NO;
    }
}

- (void)addObserver {
    @weakify(self)
    self.certKeyUpdateDisposable = [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:XP_CERTKEY_UPDATE_COMPLETE object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self);
        [self startBleLocationSDK];
        [self startPollingSDK];
    }];
    
    self.bleAddressUpdateDisposable = [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:XP_BLE_ADDRESS_UPDATE_COMPLETE object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self);
        [self startBleLocationSDK];
        [self startPollingSDK];
    }];
    
    self.deleteBleKeySuccessDisposable = [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:XPDeletingBleKeyNotification object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self);
        [self endPollingSDK];
        [self endBleLocationSDK];
    }];
    
    
    self.createBleKeySuccessDisposable = [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:XPCreatingBleKeyNotification object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self);
        [self startBleLocationSDK];
        [self startPollingSDK];
    }];
    
    self.bleHardWareDisposable = [[RACObserve(XPBLEInfoManager.manager, bleHardWare) distinctUntilChanged] subscribeNext:^(id  _Nullable x) {
        DLogTagInfo(kPollingSelfDefinedTag, @"监测到整车BLE版本变化:%@",x);
        @strongify(self);
        if (x && [x length] > 0){
            if ([NSString isEmptyWithString:x]) {
                self.currentBleHardWare = x;
                [self endPollingSDK];
                [self endBleLocationSDK];
                [self startBleLocationSDK];
                [self startPollingSDK];
            } else {
                if (![self.currentBleHardWare isEqualToString:x]) {
                    self.currentBleHardWare = x;
                    [self endPollingSDK];
                    [self endBleLocationSDK];
                    [self startBleLocationSDK];
                    [self startPollingSDK];
                }
            }
        } else {
            self.currentBleHardWare = nil;
            [self endPollingSDK];
            [self endBleLocationSDK];
        }
    }];
    
    self.pollingCalibrationDisposable = [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:kNotificationNamePollingIsCalibration object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self);
        BOOL isCalibration = [x.object boolValue];
        DLogTagInfo(kMultiBleOptTag, @"Polling是否校准中:%d",isCalibration);
        self.isPollingCalibration = isCalibration;
        [self judgePollingIsPaused];
        [self judgeBleLocationIsPaused];
    }];
    
    self.isMobileParkingDisposable = [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:XPMobileParkingNotification object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self);
        int parkingValue = [x.object intValue];
        if (parkingValue == 0) {
            self.isInParkingController = NO;
            self.isInParkingProcess = NO;
        } else if (parkingValue == 1) {
            self.isInParkingController = YES;
            self.isInParkingProcess = YES;
        } else {
            self.isInParkingProcess = NO;
        }
        [self judgePollingIsPaused];
        [self judgeBleLocationIsPaused];
        if (self.mobileParkingNeedLocation) {
            [self resetLocationParking];
        }
    }];
    
    self.isAutoParkingDisposable = [XPBLEDataHanderManager.instance.appBleAutoParkingSubject.deliverOnMainThread subscribeNext:^(NSDictionary * _Nullable x) {
        @strongify(self)
        if ([x.allKeys containsObject:PARKING_STATE_KEY]) {
            XPAppAutoParkingState parkingState = (XPAppAutoParkingState)[x[PARKING_STATE_KEY] unsignedIntValue];
            if (parkingState != XPAppAutoParkingStateQuit && parkingState != XPAppAutoParkingStateChecking && parkingState != XPAppAutoParkingStateNotAvariable) {
                DLogTagInfo(kBLEKeyPredictTag, @"车辆正在自动泊车，不执行polling");
                self.isAutoParking = YES;
                [self judgePollingIsPaused];
                [self judgeBleLocationIsPaused];
            } else {
                self.isAutoParking = NO;
                [self judgeBleLocationIsPaused];
                [self judgePollingIsPaused];
            }
        }
    }];
    
    self.isGearPDisposable = [RACObserve(XPBleKeyCarStates.instance, gearValue).distinctUntilChanged subscribeNext:^(id  _Nullable x) {
        @strongify(self);
        XPBLEKeyCarGearValue gearValue = (XPBLEKeyCarGearValue)[x intValue];
        if (gearValue == XPBLEKeyCarGearValueP || gearValue == XPBLEKeyCarGearValueInvaild) {
            DLogTagInfo(kBLEKeyPredictTag, @"车辆是P档，可以执行predict");
            self.gearValueIsSupportPolling = YES;
            self.gearValueIsSupportLocation = YES;
            [self judgeBleLocationIsPaused];
            [self judgePollingIsPaused];
        } else if (gearValue == XPBLEKeyCarGearValueN) {
            DLogTagInfo(kBLEKeyPredictTag, @"车辆是N档，可以执行predict,但不支持Polling");
            self.gearValueIsSupportPolling = NO;
            self.gearValueIsSupportLocation = YES;
            [self judgeBleLocationIsPaused];
            [self judgePollingIsPaused];
        } else {
            if (self.carStateIsRemedy && gearValue == XPBLEKeyCarGearValueNotAvailable) {
                self.gearValueIsSupportPolling = YES;
                self.gearValueIsSupportLocation = YES;
                [self judgeBleLocationIsPaused];
                [self judgePollingIsPaused];
            } else {
                DLogTagInfo(kBLEKeyPredictTag, @"车辆不是P档或N档，同时不执行predict与Polling");
                self.gearValueIsSupportPolling = NO;
                self.gearValueIsSupportLocation = NO;
                [self judgePollingIsPaused];
                [self judgeBleLocationIsPaused];
            }
        }
    }];
    
    self.carStateIsRemedyDisposable = [[[[NSNotificationCenter defaultCenter] rac_addObserverForName:RefreshSystemConfigSuccessNotificaiton object:nil] takeUntil:self.rac_willDeallocSignal] subscribeNext:^(NSNotification * _Nullable x) {
        @strongify(self);
        self.carStateIsRemedy = [[[SystemConfig.currentConfig.pollingIsRemedy valueForKey:[CTMediator getVehicleModel]] valueForKey:@"isRemedy"] boolValue];
    }];
    
    self.isSleepModeDisposable = [RACObserve(XPBleKeyCarStates.instance, sleepModeState) subscribeNext:^(id  _Nullable x) {
        @strongify(self);
        XPBLECarSleepModeState sleepState = (XPBLECarSleepModeState)[x intValue];
        if (XPBLECarSleepModeStateActiveNotAvailable != sleepState) {
            self.isSleepMode = (XPBLECarSleepModeStateActive == sleepState);
            [self judgePollingIsPaused];
        }
    }];
    
    [self.bleEventTool startBleEventObserver];
    [self.bleLocationTool startBleLocationResultObserver];
}

