@implementation XPBluetoothManager


#pragma mark - Singleton

+ (instancetype)manager {
    static XPBluetoothManager *__instance = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        __instance = [[XPBluetoothManager alloc] init];
    });
    
    return __instance;
}

#pragma mark - Initialization

- (void)dealloc {
    [[NSNotificationCenter defaultCenter] removeObserver:self];
}

- (instancetype)init {
    self = [super init];
    if (self) {
        _bluetoothManagerThread = [[NSThread alloc] initWithTarget:self
                                                          selector:@selector(bluetoothManagerThreadEntryPoint:)
                                                            object:@"com.xiaopeng.bluetooth"];
        [_bluetoothManagerThread start];
        _connectInfos = [[YYThreadSafeDictionary alloc] init];
    }
    
    return self;
}

- (void)initBabyBluetoothIfNeed {
    self.baby;//初始化BabyBluetooth，以设置状态监听等
}

- (void)bluetoothManagerThreadEntryPoint:(NSString*)threadName {
    @autoreleasepool {
        [[NSThread currentThread] setName:threadName];
        NSRunLoop *runLoop = [NSRunLoop currentRunLoop];
        [runLoop addPort:[NSMachPort port] forMode:NSDefaultRunLoopMode];
        [runLoop run];
    }
}

- (void)performBlock:(void (^)(void))block {
    [self performSelector:@selector(doBlock:)
                 onThread:self.bluetoothManagerThread
               withObject:[block copy]
            waitUntilDone:NO
                    modes:@[NSRunLoopCommonModes]];
}

- (void)doBlock:(void (^)(void))block {
    if (block) {
        block();
    }
}

- (void)clearCarBLEInfo
{
    DLogTagInfo( kBluetoothTag, @"清理车辆蓝牙缓存信息" );
    _scanUUIDs = nil;
    
    [self.connectInfos removeAllObjects];
}

- (void)cancelAndClear {
    DLogTagInfo( kBluetoothTag, @"取消所有在途连接，终止扫描，并清理所有BLE信息" );
    if (nil != _baby)
    {
        [_baby cancelAllPeripheralsConnection];
        [_baby cancelScan];
        _baby.stop(0);
    }
    
    [self clearCarBLEInfo];
}

