- (NSString*)description {
    return [NSString stringWithFormat:@"%@[%@蓝牙](peripheralName=%@,serviceUUIDs=%@,characteristicsUUIDs=%@,peripheral=%@,advertisementData=%@,instance=%p)",
            NSStringFromClass(self.class),
            self.positionName,
            self.peripheralName,
            self.serviceUUIDs,
            self.characteristicsUUIDs,
            self.peripheral,
            self.advertisementData,
            self];
}

