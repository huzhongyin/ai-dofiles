}

#pragma mark -
- (XPBluetoothConnectInfo*)findConnectInfo:(CBPeripheral *)peripheral
{
    XPBluetoothConnectInfo * info = nil;
    NSOrderedSet<XPBluetoothConnectInfo*>* set = [NSOrderedSet orderedSetWithArray:[self.connectInfos allValues]];
    for (XPBluetoothConnectInfo* connectInfo in set) {
        if ([connectInfo.peripheral.identifier.UUIDString isEqualToString:peripheral.identifier.UUIDString]) {
            info = connectInfo;
            break;
        }
    }
    
    return info;
}

- (void)setBabyDelegates {
    @weakify(self);
    [_baby setBlockOnCentralManagerDidUpdateState:^(CBCentralManager *central) {
        @strongify(self)
        XPBluetoothCentralState oldState = self.centralState;
        switch (central.state) {
            case CBManagerStateResetting:
                DLogTagInfo( kBluetoothTag, @"蓝牙功能打开失败，设备重置" );
                self.centralState = XPBlueToothCentralResetting;
                OSMemoryBarrier();
                break;
            case CBManagerStateUnsupported:
                DLogTagInfo( kBluetoothTag, @"蓝牙功能打开失败，不支持蓝牙" );
                self.centralState = XPBlueToothCentralUnsupported;
                OSMemoryBarrier();
                break;
            case CBManagerStateUnauthorized:
                DLogTagInfo( kBluetoothTag, @"蓝牙功能打开失败，未授权" );
                self.centralState = XPBlueToothCentralUnauthorized;
                OSMemoryBarrier();
                break;
            case CBManagerStatePoweredOff:
                DLogTagInfo( kBluetoothTag, @"蓝牙功能打开失败，蓝牙关闭" );
                self.centralState = XPBlueToothCentralPoweredOff;
                OSMemoryBarrier();
                break;
            case CBManagerStatePoweredOn:
                DLogTagInfo( kBluetoothTag, @"蓝牙功能打开成功，设备打开成功" );
                self.centralState = XPBlueToothCentralPoweredOn;
                OSMemoryBarrier();
                break;
            default:
                DLogTagInfo( kBluetoothTag, @"蓝牙功能打开失败，设备为未知状态" );
                self.centralState = XPBlueToothCentralUnknown;
                break;
        }
        
        if (self.centralState != XPBlueToothCentralPoweredOn) {
            [self.baby cancelAllPeripheralsConnection];
        }
        if (XPBlueToothCentralPoweredOn != self.centralState && XPBlueToothCentralPoweredOn == oldState) {
            [self.disconnectSubject sendNext:nil];
        }
    }];
    
    //扫描外设
    [_baby setBlockOnDiscoverToPeripherals:^(CBCentralManager *central, CBPeripheral *peripheral, NSDictionary *advertisementData, NSNumber *RSSI) {
        @strongify(self);
        [self performBlock:^{
            NSString* localName = [advertisementData objectForKey:CBAdvertisementDataLocalNameKey];
            NSOrderedSet* set = [NSOrderedSet orderedSetWithArray:[self.connectInfos allKeys]];
            DLogTagInfo( kBluetoothTag, @"蓝牙找到一个设备，设备名：“%@”,advertisementData=%@" ,peripheral.name,advertisementData);
            if ([set containsObject:localName]) {
                XPBluetoothConnectInfo* connectInfo = [self.connectInfos objectForKey:localName];
                connectInfo.peripheral = peripheral;
                connectInfo.advertisementData = advertisementData;
                DLogTagInfo( kBluetoothTag, @"蓝牙找到一个设备，设备名：%@,是目标设备,终止扫描,开始连接[%@蓝牙],advertisementData=%@" ,peripheral.name,connectInfo.positionName,advertisementData);
            } else {
                DLogTagInfo( kBluetoothTag, @"蓝牙找到一个设备，设备：%@,不是目标设备,跳过" ,peripheral);
            }
        }];
    }];
    
    //连接外设
    [_baby setBlockOnConnected:^(CBCentralManager *central, CBPeripheral *peripheral) {
        @strongify(self);
        [self performBlock:^{
            DLogTagInfo( kBluetoothTag, @"%@蓝牙连接设备“%@”成功", [self findConnectInfo:peripheral].positionName, peripheral);
            NSMutableDictionary* info = [NSMutableDictionary dictionaryWithCapacity:3];
            NSOrderedSet<XPBluetoothConnectInfo*>* set = [NSOrderedSet orderedSetWithArray:[self.connectInfos allValues]];
            for (XPBluetoothConnectInfo* connectInfo in set) {
                if ([connectInfo.peripheral.identifier.UUIDString isEqualToString:peripheral.identifier.UUIDString]) {
                    [info setObject:connectInfo.peripheralName forKey:@"peripheralName"];
                    break;
                }
            }
            if (nil!=peripheral) {
                [info setObject:peripheral forKey:@"peripheral"];
                if (0!=peripheral.identifier.UUIDString.length) {
                    [info setObject:peripheral.identifier.UUIDString forKey:@"peripheralUUID"];
                }
            }
            [self.connectSubject sendNext:[NSDictionary dictionaryWithDictionary:info]];
        }];
    }];
    
    [_baby setBlockOnFailToConnect:^(CBCentralManager *central, CBPeripheral *peripheral, NSError *error) {
        @strongify(self);
        [self performBlock:^{
            NSOrderedSet<XPBluetoothConnectInfo*>* set = [NSOrderedSet orderedSetWithArray:[self.connectInfos allValues]];
            for (XPBluetoothConnectInfo* connectInfo in set) {
                if ([connectInfo.peripheral.identifier.UUIDString isEqualToString:peripheral.identifier.UUIDString]) {
                    break;
                }
            }
            DLogTagInfo( kBluetoothTag, @"%@蓝牙连接设备“%@”失败,error=%@", [self findConnectInfo:peripheral].positionName, peripheral, error);
            NSMutableDictionary* info = [NSMutableDictionary dictionaryWithCapacity:3];
            if (nil!=error) {
                [info setObject:error forKey:@"error"];
            }
            if (0!=peripheral.identifier.UUIDString.length) {
                [info setObject:peripheral.identifier.UUIDString forKey:@"peripheralUUID"];
            }
            if (0!=peripheral.services.count) {
                NSMutableOrderedSet* servicesUUIDs = [NSMutableOrderedSet orderedSetWithCapacity:peripheral.services.count];
                NSMutableOrderedSet* characteristicUUIDs = [NSMutableOrderedSet orderedSetWithCapacity:10];
                for (CBService* service in peripheral.services) {
                    [servicesUUIDs addObject:service.UUID.UUIDString];
                    for (CBCharacteristic* characteristic in service.characteristics) {
                        [characteristicUUIDs addObject:characteristic.UUID.UUIDString];
                    }
                }
                if (0!=servicesUUIDs.count) {
                    [info setObject:[NSArray arrayWithArray:servicesUUIDs.array] forKey:@"servicesUUIDs"];
                }
                if (0!=characteristicUUIDs.count) {
                    [info setObject:[NSArray arrayWithArray:characteristicUUIDs.array] forKey:@"characteristicUUIDs"];
                }
            }
            [self.connectSubject sendNext:[NSDictionary dictionaryWithDictionary:info]];
        }];
    }];
    
    [_baby setBlockOnDisconnect:^(CBCentralManager *central, CBPeripheral *peripheral, NSError *error) {
        @strongify(self);
        if (nil!=error) {
            DLogTagError(kBluetoothTag, @"与%@蓝牙设备%@断开连接,error = %@", [self findConnectInfo:peripheral].positionName, peripheral, error);
        } else {
            DLogTagInfo(kBluetoothTag, @"与%@蓝牙设备%@连接断开成功", [self findConnectInfo:peripheral].positionName, peripheral);
        }
        [self performBlock:^{
            NSOrderedSet<XPBluetoothConnectInfo*>* set = [NSOrderedSet orderedSetWithArray:[self.connectInfos allValues]];
            for (XPBluetoothConnectInfo* connectInfo in set) {
                if ([connectInfo.peripheral.identifier.UUIDString isEqualToString:peripheral.identifier.UUIDString]) {
                    break;
                }
            }
            NSMutableDictionary* info = [NSMutableDictionary dictionaryWithCapacity:3];
            if (nil!=error) {
                [info setObject:error forKey:@"error"];
            }
            if (0!=peripheral.identifier.UUIDString.length) {
                [info setObject:peripheral.identifier.UUIDString forKey:@"peripheralUUID"];
            }
            [self.disconnectSubject sendNext:[NSDictionary dictionaryWithDictionary:info]];
        }];
    }];
    
    //发现服务
    [_baby setBlockOnDiscoverServices:^(CBPeripheral *peripheral, NSError *error) {
        @strongify(self);
        [self performBlock:^{
            NSArray* services = [peripheral.services.rac_sequence map:^id _Nullable(CBService * _Nullable service) {
                return service.UUID.UUIDString;
            }].array;
            
            DLogTagInfo( kBluetoothTag, @"%@蓝牙设备%@发现服务：%@", [self findConnectInfo:peripheral].positionName, peripheral, services);
            
            NSDictionary* info = @{
                                   @"peripheralUUID":peripheral.identifier.UUIDString,
                                   @"services":services
                                   };
            [self.discoveryServiceSubject sendNext:info];
        }];
    }];
    
    //发现特征
    [_baby setBlockOnDiscoverCharacteristics:^(CBPeripheral *peripheral, CBService *service, NSError *error) {
        @strongify(self);
        [self performBlock:^{
            if (![service.UUID.UUIDString isEqualToString:XP_BLEKEY_SERVICE_UUID]) {
                return;
            }
            NSMutableArray* characteristics = [NSMutableArray arrayWithCapacity:service.characteristics.count];
            NSMutableOrderedSet* characteristicsUUIDs = [NSMutableOrderedSet orderedSetWithCapacity:service.characteristics.count];
            for (CBCharacteristic *characteristic in service.characteristics) {
                NSArray* list = @[characteristic.UUID.UUIDString,CBCharacteristicPropertiesToString(characteristic.properties)];
                [characteristicsUUIDs addObject:characteristic.UUID.UUIDString];
                [characteristics addObject:list];
            }
            DLogTagInfo( kBluetoothTag, @"%@蓝牙设备“%@”-服务“%@”中发现特征：%@", [self findConnectInfo:peripheral].positionName,peripheral,service.UUID,characteristics);
            NSDictionary* info = @{
                                   @"peripheralUUID":peripheral.identifier.UUIDString,
                                   @"serviceUUID":service.UUID.UUIDString,
                                   @"characteristics":characteristicsUUIDs
                                   };
            [self.discoveryCharacteristicSubject sendNext:info];
        }];
    }];
    
    //发现描述
    [_baby setBlockOnDiscoverDescriptorsForCharacteristic:^(CBPeripheral *peripheral, CBCharacteristic *characteristic, NSError *error) {
        @strongify(self);
        [self performBlock:^{
            NSMutableArray* descriptors = [NSMutableArray arrayWithCapacity:characteristic.descriptors.count];
            for (CBDescriptor *d in characteristic.descriptors) {
                [descriptors addObject:d.UUID.UUIDString];
            }
            DLogTagInfo( kBluetoothTag, @"%@蓝牙设备“%@”-特征“%@”中发现描述：%@", [self findConnectInfo:peripheral].positionName,peripheral,[characteristic.UUID UUIDString],descriptors);
        }];
    }];
    
    [_baby setBlockOnReadValueForCharacteristic:^(CBPeripheral *peripheral, CBCharacteristic *characteristic, NSError *error) {
        @strongify(self);
        [self performBlock:^{
            DLogTagInfo(kBluetoothTag,@"%@蓝牙读取回调 peripheral:%@,characteristic:%@ and new value:%@,error;%@",[self findConnectInfo:peripheral].positionName,peripheral,[characteristic.UUID UUIDString], characteristic.value,error);
            NSMutableDictionary* info = [NSMutableDictionary dictionaryWithCapacity:3];
            if (nil!=error) {
                [info setObject:error forKey:@"error"];
            }
            if (0!=characteristic.UUID.UUIDString.length) {
                [info setObject:characteristic.UUID.UUIDString forKey:@"characteristicUUID"];
            }
            if (0!=peripheral.identifier.UUIDString.length) {
                [info setObject:peripheral.identifier.UUIDString forKey:@"peripheralUUID"];
            }
            
            if (nil!=characteristic.value) {
                NSData* data = [NSData dataWithData:characteristic.value];
                [info setObject:data forKey:@"data"];
            }
            [self.readSubject sendNext:[NSDictionary dictionaryWithDictionary:info]];
        }];
    }];
    
    [_baby setBlockOnDidWriteValueForCharacteristic:^(CBPeripheral *peripheral,CBCharacteristic *characteristic, NSError *error) {
        @strongify(self);
        [self performBlock:^{
            DLogTagInfo(kBluetoothTag,@"%@蓝牙写入回调 characteristic:%@ and new value:%@,error:%@",[self findConnectInfo:peripheral].positionName,[characteristic.UUID UUIDString], characteristic.value,error);
            NSMutableDictionary* info = [NSMutableDictionary dictionaryWithCapacity:3];
            if (nil!=error) {
                [info setObject:error forKey:@"error"];
            }
            if (0!=peripheral.identifier.UUIDString.length) {
                [info setObject:peripheral.identifier.UUIDString forKey:@"peripheralUUID"];
            }
            if (0!=characteristic.UUID.UUIDString.length) {
                [info setObject:characteristic.UUID.UUIDString forKey:@"characteristicUUID"];
            }
            
            if (nil!=characteristic.value) {
                NSData* data = [NSData dataWithData:characteristic.value];
                [info setObject:data forKey:@"data"];
            }
            [self.sendSubject sendNext:[NSDictionary dictionaryWithDictionary:info]];
        }];
    }];
    
    [_baby setBlockOnDidUpdateName:^(CBPeripheral *peripheral) {
        @strongify(self);
        DLogTagInfo(kBluetoothTag,@"%@蓝牙外设名字更新，UUID=%@，name=%@",[self findConnectInfo:peripheral].positionName,peripheral.identifier, peripheral.name);
    }];
}

- (void)notify:(CBPeripheral *)peripheral
characteristic:(CBCharacteristic *)characteristic {
    @weakify(self);
    [_baby notify:peripheral
   characteristic:characteristic
            block:^(CBPeripheral *peripheral, CBCharacteristic *characteristics, NSError *error) {
        
                NSData* rec_data = [NSData dataWithData:characteristics.value];
                NSString * rec_hexString = [rec_data hexString];
                DLogTagInfo(kBluetoothTag, @"%@接收到蓝牙原始数据：data=%@,peripheral=%@,characteristics=%@,error=%@", [self findConnectInfo:peripheral].positionName, rec_hexString, peripheral, [characteristics.UUID UUIDString], error);
        
                @strongify(self);
                [self performBlock:^{
                    __CHECK(CBPeripheralStateConnected == peripheral.state);
                    NSData* data = [NSData dataWithData:characteristics.value];
                    NSMutableDictionary* info = [NSMutableDictionary dictionaryWithCapacity:3];
                    [info setObject:peripheral.identifier.UUIDString forKey:@"peripheralUUID"];
                    
                    if (0!=characteristics.UUID.UUIDString.length) {
                        [info setObject:characteristics.UUID.UUIDString forKey:@"characteristicUUID"];
                    }
                    
                    if (error==nil) {
                        [info setObject:data forKey:@"data"];
                    } else {
                        [info setObject:error forKey:@"error"];
                    }
                    
                    [self.notifySubject sendNext:[NSDictionary dictionaryWithDictionary:info]];
                }];
    }];
}

- (void)cancelNotifyWithUUID:(NSString*)uuid peripheral:(CBPeripheral*)peripheral {
    CBCharacteristic *characteristic = [self characteristicWithUUID:uuid peripheral:peripheral];
    if (characteristic) {
        [_baby cancelNotify:peripheral characteristic:characteristic];
    }
}



- (XPBluetoothConnectInfo *)mactchItemWithPeripheralName:(NSString *)peripheralName advertisementData:(NSDictionary *)advertisementData
{
    NSString* localName = [advertisementData objectForKey:CBAdvertisementDataLocalNameKey];

    NSArray< XPBluetoothConnectInfo* >* list = [NSArray arrayWithArray:self.connectInfos.allValues];

    XPBluetoothConnectInfo * found = nil;
    for (XPBluetoothConnectInfo* item in list) {
        if ([item.peripheralName isEqualToString:localName]
            || [item.peripheralName isEqualToString:peripheralName])
        {
            found = item;
            break;
        }
    }
    
    return found;
}

- (NSArray<NSString *> *)deviceSSIDs
{
    NSMutableArray * SSIDs = [NSMutableArray arrayWithCapacity:10];
  
    NSArray< XPBluetoothConnectInfo* >* list = [NSArray arrayWithArray:self.connectInfos.allValues];

    for (XPBluetoothConnectInfo* item in list) {
        if (item.peripheralName.length > 0)
        {
            [SSIDs addObject:item.peripheralName];
        }
    }
    
    return SSIDs;
}

- (void)setBabyFilters {
    @weakify(self);
    [_baby setFilterOnDiscoverPeripherals:^BOOL(NSString *peripheralName, NSDictionary *advertisementData, NSNumber *RSSI) {
        @strongify(self);
        
        XPBluetoothConnectInfo* item = [self mactchItemWithPeripheralName:peripheralName advertisementData:advertisementData];
        if (nil == item)
        {
            DLogTagInfo(kBluetoothTag, @"<M发现过滤>名称不符合要求，设备名称和LocalName都不在设备列表中[%@], 跳过 peripheralName:%@, localName:%@, advertisementData: %@", [[self deviceSSIDs] componentsJoinedByString:@", "], peripheralName, [advertisementData objectForKey:CBAdvertisementDataLocalNameKey],  advertisementData);
            return NO;
        }
        
        DLogTagInfo(kBluetoothTag, @"<M发现过滤>名称符合要求，进一步检测参数，[%@]蓝牙 peripheralName:%@, localName:%@, advertisementData: %@", item.positionName, peripheralName, [advertisementData objectForKey:CBAdvertisementDataLocalNameKey],  advertisementData);

        return [item discoverFilter:peripheralName advertisementData:advertisementData RSSI:RSSI];
    }];
    [_baby setFilterOnConnectToPeripherals:^BOOL(NSString *peripheralName, NSDictionary *advertisementData, NSNumber *RSSI) {
        @strongify(self);
        
        XPBluetoothConnectInfo* item = [self mactchItemWithPeripheralName:peripheralName advertisementData:advertisementData];
        if (nil == item)
        {
            DLogTagInfo(kBluetoothTag, @"<M连接过滤>不符合要求，设备名称和LocalName都不在设备列表中[%@], 跳过 peripheralName:%@, localName:%@, advertisementData: %@", [[self deviceSSIDs] componentsJoinedByString:@", "], peripheralName, [advertisementData objectForKey:CBAdvertisementDataLocalNameKey], advertisementData);
            return NO;
        }
        
        DLogTagInfo(kBluetoothTag, @"<M连接过滤>名称符合要求，进一步检测参数，[%@] peripheralName:%@, localName:%@, advertisementData: %@", item.positionName, peripheralName, [advertisementData objectForKey:CBAdvertisementDataLocalNameKey],  advertisementData);

        return [item connectFilter:peripheralName advertisementData:advertisementData RSSI:RSSI];
    }];
}

- (CBCharacteristic *)characteristicWithUUID:(NSString*)uuid peripheral:(CBPeripheral*)peripheral {
    for (CBService *service in peripheral.services) {
        for (CBCharacteristic *characteristic in service.characteristics) {
            if ([characteristic.UUID.UUIDString isEqualToString:uuid]) {
                return characteristic;
            }
        }
    }
    return nil;
}

- (BOOL)safeCheckCentralState:(const XPBluetoothCentralState)state {
    return OSAtomicCompareAndSwap64Barrier(state, state, &_centralState);
}

