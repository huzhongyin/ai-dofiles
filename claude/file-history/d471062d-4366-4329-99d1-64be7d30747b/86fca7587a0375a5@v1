- (BabyBluetooth *)baby {
    if(!_baby) {
        _baby = [BabyBluetooth shareBabyBluetooth];
        [self.KVOController observe:[_baby centralManager]
                            keyPath:@"isScanning"
                            options:(NSKeyValueObservingOptionNew|NSKeyValueObservingOptionInitial)
