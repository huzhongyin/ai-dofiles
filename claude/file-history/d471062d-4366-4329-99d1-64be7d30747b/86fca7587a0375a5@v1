- (void)connectToPeripheral:(CBPeripheral *)peripheral connectInfo:(XPBluetoothConnectInfo *)connectInfo {
    DLogTagInfo( kBluetoothTag, @"%@蓝牙 直接连接蓝牙设备:connectInfo=%@, peripheral:%@",  connectInfo.positionName, connectInfo, peripheral);
    NSArray* tempServiceUUIDs = connectInfo.serviceUUIDs;
    NSArray* tempCharacteristicsUUIDs = connectInfo.characteristicsUUIDs;
    if (nil == tempServiceUUIDs || 0 == tempServiceUUIDs.count) {
        tempServiceUUIDs = [NSArray array];
    }
    
    if (nil == tempCharacteristicsUUIDs || 0 == tempCharacteristicsUUIDs.count) {
        tempCharacteristicsUUIDs = [NSArray array];
    }

    DLogTagInfo( kBluetoothTag, @"%@蓝牙 [%@]缓存设备直接设定发现参数为 discoverServices=%@,discoverCharacteristics=%@", connectInfo.positionName, connectInfo.peripheralName, [tempServiceUUIDs description],[tempCharacteristicsUUIDs description]);
    [self.baby setBabyOptionsWithScanForPeripheralsWithOptions:nil
                                  connectPeripheralWithOptions:nil
                                scanForPeripheralsWithServices:nil
                                          discoverWithServices:tempServiceUUIDs
                                   discoverWithCharacteristics:tempCharacteristicsUUIDs];
    
    self.baby.having(peripheral).then
    .connectToPeripherals()
    .discoverServices()
    .discoverCharacteristics()
    .discoverDescriptorsForCharacteristic()
    .begin();
}

- (CBPeripheral*)retrievePeripheralsWithIdentifiers:(NSUUID*)uuid {
    if (self.centralState != XPBlueToothCentralPoweredOn) {
         DLogTagInfo( kBluetoothTag, @"蓝牙不是power on状态，不能获取缓存对象 当前状态：%@", NSStringFromXPBluetoothCentralState(self.centralState));

         return nil;
    }

    __CHECK_RET(0!=uuid.UUIDString.length, nil);
    NSArray* array = [[self.baby centralManager] retrievePeripheralsWithIdentifiers:[NSArray arrayWithObject:uuid]];
    if (array.count == 0) {
        DLogTagInfo(kBluetoothTag, @"<PA>未获取到系统保存的蓝牙句柄: %@", [uuid UUIDString]);
    }
    else {
        DLogTagInfo(kBluetoothTag, @"<PA>已获取到系统保存的蓝牙句柄: %@ retrievePeripherals: %@", [uuid UUIDString], array);
    }
    __CHECK_RET(0!=array.count, nil);
    return [array firstObject];
}

- (void)connect:(XPBluetoothConnectInfo*)connectInfo {
    if (self.centralState != XPBlueToothCentralPoweredOn) {
         DLogTagInfo( kBluetoothTag, @"蓝牙不是power on状态，取消连接，并初始化baby触发系统蓝牙权限弹窗 当前状态：%@", NSStringFromXPBluetoothCentralState(self.centralState));
         [self baby];

         return;
    }
    
    CBPeripheral * peripheral = connectInfo.peripheral;
    
    @weakify(self);
    [self performBlock:^{
        @strongify(self);
        DLogTagInfo( kBluetoothTag, @"尝试连接:%@", connectInfo);
        if (![self.connectInfos objectForKey:[connectInfo peripheralName]]) {
            DLogTagInfo( kBluetoothTag, @"由于是初次连接，故将连接信息记录到本地:%@" ,connectInfo);
            [self.connectInfos setObject:connectInfo forKey:[connectInfo peripheralName]];
        }
        if (nil != peripheral) {
            DLogTagInfo( kBluetoothTag, @"连接信息中设备信息不为空,跳过扫描,直接连接蓝牙设备:%@" ,connectInfo);
            [self connectToPeripheral:peripheral connectInfo:connectInfo];
        } else {
            DLogTagInfo( kBluetoothTag, @"连接信息中设备信息为空,进入扫描:%@" ,connectInfo);
            [self connect:connectInfo.peripheralName serviceUUIDs:connectInfo.serviceUUIDs characteristicsUUIDs:connectInfo.characteristicsUUIDs];
        }
    }];
}

- (NSString *)UUIDFromBleName:(NSString *)name
{
    NSInteger cutlen = name.length;
    if (cutlen > 8)
    {
        cutlen = 8;
    }
    NSString * uuid = [name substringFromIndex:name.length - cutlen];
    return uuid;
}

- (CBUUID *)CBUUIDFromBleName:(NSString *)name
{
    if (0 == [name length])
    {
        DLogTagWarn(kBluetoothTag, @"^^^车端蓝牙SSID名称为空:%@", name);
        return nil;
    }
    
    CBUUID * uuid = nil;
    @try {
        uuid = [CBUUID UUIDWithString:[self UUIDFromBleName:name]];
    } @catch (NSException *exception) {
        DLogTagWarn(kBluetoothTag, @"^^^车端蓝牙SSID名称转CBUUID出现异常 name:%@ UUIDFromBleName:%@", name, [self UUIDFromBleName:name]);
    } @finally {
    }
    return uuid;
}

- (BOOL)isExistsScanUUID:(NSString *)uuidStr
{
    __block BOOL exists = NO;
    [_scanUUIDs enumerateObjectsUsingBlock:^(CBUUID * _Nonnull obj, NSUInteger idx, BOOL * _Nonnull stop) {
        if ([[obj UUIDString] isEqualToString:uuidStr])
        {
            exists = YES;
            *stop = YES;
        }
    }];
    
    return exists;
}

- (void)connect:(NSString *)peripheralName serviceUUIDs:(NSArray<CBUUID*>*)serviceUUIDs characteristicsUUIDs:(NSArray<CBUUID*>*)characteristicsUUIDs {
    DLogTagInfo( kBluetoothTag, @"扫描连接名为%@，serviceUUIDs包含%@，characteristicsUUIDs包含%@ 的设备" ,peripheralName,[serviceUUIDs description],[characteristicsUUIDs description]);
    NSArray* tempServiceUUIDs = serviceUUIDs;
    NSArray* tempCharacteristicsUUIDs = characteristicsUUIDs;
    if (nil == tempServiceUUIDs || 0 == tempServiceUUIDs.count) {
        tempServiceUUIDs = [NSArray array];
    }
    
    if (nil == tempCharacteristicsUUIDs || 0 == tempCharacteristicsUUIDs.count) {
        tempCharacteristicsUUIDs = [NSArray array];
    }

    // 目前暂时再这里累积记录需扫描的 UUIDs，将来需要优化（改动将会很大）
    if (_useScanUUIDs)
    {
        if (nil == _scanUUIDs)
        {
            _scanUUIDs = [NSMutableArray arrayWithCapacity:4];
        }
        
        CBUUID * uuid = [self CBUUIDFromBleName:peripheralName];
        if (uuid && ![self isExistsScanUUID:uuid.UUIDString])
        {
            [_scanUUIDs addObject:uuid];
        }
    }
    else
    {
        if (nil != _scanUUIDs)
        {
            _scanUUIDs = nil;
        }
    }
    
    DLogTagInfo( kBluetoothTag, @"[%@]新设备设定扫描参数为 scanServiceUUIDs=%@, discoverServices=%@, discoverCharacteristics=%@", peripheralName, [_scanUUIDs description], [tempServiceUUIDs description], [tempCharacteristicsUUIDs description]);
    [self.baby setBabyOptionsWithScanForPeripheralsWithOptions:nil
                                  connectPeripheralWithOptions:nil
                                scanForPeripheralsWithServices:_scanUUIDs
                                          discoverWithServices:tempServiceUUIDs
                                   discoverWithCharacteristics:tempCharacteristicsUUIDs];
    self.baby.scanForPeripherals()
    .connectToPeripherals()
    .discoverServices()
    .discoverCharacteristics()
    .discoverDescriptorsForCharacteristic()
    .begin();
}

- (void)send:(NSData*)data UUID:(NSString*)uuid peripheral:(CBPeripheral*)peripheral {
    __CHECK(0!=data.length);
    __CHECK(CBPeripheralStateConnected == peripheral.state);
    @weakify(self);
    [self performBlock:^{
        @strongify(self);
        DLogTagInfo( kBluetoothTag, @"%@蓝牙 尝试发送数据包（%@）给设备%@,uuid=%@",[self findConnectInfo:peripheral].positionName,[data hexString],peripheral,uuid);
        CBCharacteristic *characteristic = [self characteristicWithUUID:uuid peripheral:peripheral];
        if (nil == characteristic) {
            DLogTagInfo( kBluetoothTag, @"%@蓝牙 尝试读设备特征（%@）,uuid=%@:由于找不到对应特征，故发送失败",[self findConnectInfo:peripheral].positionName,peripheral,uuid);
        } else {
            if (0==(characteristic.properties&CBCharacteristicPropertyWrite)&&
                0==(characteristic.properties&CBCharacteristicPropertyWriteWithoutResponse)) {
                DLogTagInfo( kBluetoothTag, @"%@蓝牙 由于特征%@没有写权限%@，故发送失败",[self findConnectInfo:peripheral].positionName,[characteristic.UUID UUIDString],CBCharacteristicPropertiesToString(characteristic.properties));
                characteristic = nil;
            } else {
                DLogTagInfo( kBluetoothTag, @"%@蓝牙 执行写入数据给设备%@,characteristic:%@",[self findConnectInfo:peripheral].positionName,peripheral,characteristic);
                [peripheral writeValue:data forCharacteristic:characteristic type:CBCharacteristicWriteWithResponse];
            }
        }
    }];
}

- (void)notifyWithUUID:(NSString*)uuid peripheral:(CBPeripheral*)peripheral {
    @weakify(self);
    __CHECK(CBPeripheralStateConnected == peripheral.state);
    [self performBlock:^{
        @strongify(self);
        DLogTagInfo( kBluetoothTag, @"%@蓝牙 尝试订阅设备特征（%@）,uuid=%@",[self findConnectInfo:peripheral].positionName,peripheral,uuid);
        CBCharacteristic *characteristic = [self characteristicWithUUID:uuid peripheral:peripheral];
        if (nil == characteristic) {
            DLogTagInfo( kBluetoothTag, @"%@蓝牙  尝试读设备特征（%@）,uuid=%@:由于找不到对应特征，故订阅失败",[self findConnectInfo:peripheral].positionName,peripheral,uuid);
        } else {
            const BOOL canBeNotifiy = (characteristic.properties&CBCharacteristicPropertyNotify)|| (characteristic.properties&CBCharacteristicPropertyIndicate);
            if (canBeNotifiy) {
                DLogTagInfo(kBluetoothTag, @"%@蓝牙 订阅设备%@的%@属性",[self findConnectInfo:peripheral].positionName,peripheral,[characteristic.UUID UUIDString]);
                [self notify:peripheral characteristic:characteristic];
            } else {
                DLogTagInfo(kBluetoothTag, @"%@蓝牙 由于特征%@没有订阅权限%@，故订阅失败",[self findConnectInfo:peripheral].positionName,[characteristic.UUID UUIDString],CBCharacteristicPropertiesToString(characteristic.properties));
                characteristic = nil;
            }
        }
    }];
}

- (void)onScanStateUpdate:(NSDictionary*)update {
    DLogTagInfo( kBluetoothTag, @"蓝牙模块扫描状态更新，新状态为：%@" ,[self.baby centralManager].isScanning?@"正在扫描":@"不在扫描");
    self.isScanning = [self.baby centralManager].isScanning;
}

- (void)requestValueWithUUID:(NSString*)uuid peripheral:(CBPeripheral*)peripheral {
    @weakify(self);
    __CHECK(CBPeripheralStateConnected == peripheral.state);
    [self performBlock:^{
        @strongify(self);
        DLogTagInfo( kBluetoothTag, @"%@蓝牙 尝试读设备特征（%@）,uuid=%@",[self findConnectInfo:peripheral].positionName,peripheral,uuid);
        CBCharacteristic *characteristic = [self characteristicWithUUID:uuid peripheral:peripheral];
        if (nil == characteristic) {
            DLogTagInfo( kBluetoothTag, @"%@蓝牙 尝试读设备特征（%@）,uuid=%@:由于找不到对应特征，故读失败",[self findConnectInfo:peripheral].positionName,peripheral,uuid);
        } else {
            if (0==(characteristic.properties&CBCharacteristicPropertyRead)) {
                DLogTagInfo( kBluetoothTag, @"%@蓝牙 由于特征%@没有读取权限%@，故读失败",[self findConnectInfo:peripheral].positionName,[characteristic.UUID UUIDString],CBCharacteristicPropertiesToString(characteristic.properties));
                characteristic = nil;
            } else {
                [peripheral readValueForCharacteristic:characteristic];
            }
        }
    }];
}

- (void)disconnect:(CBPeripheral*)peripheral {
    DLogTagInfo( kBluetoothTag, @"%@蓝牙 断开与设备%@的蓝牙连接",[self findConnectInfo:peripheral].positionName,peripheral);
    @weakify(self);
    [self performBlock:^{
        @strongify(self);
        if (nil!=peripheral && peripheral.state == CBPeripheralStateConnected) {
            [_baby cancelPeripheralConnection:peripheral];
        } else {
            DLogTagInfo( kBluetoothTag, @"%@蓝牙 不是connected状态，不调用cancel", [self findConnectInfo:peripheral].positionName);
        }
    }];
    
}

- (void)forceDisconnect:(CBPeripheral*)peripheral {
    DLogTagInfo( kBluetoothTag, @"%@蓝牙 断开与设备%@的蓝牙连接",[self findConnectInfo:peripheral].positionName,peripheral);
    @weakify(self);
    [self performBlock:^{
        @strongify(self);
        if (nil!=peripheral) {
            [_baby cancelPeripheralConnection:peripheral];
        } else {
            DLogTagInfo( kBluetoothTag, @"peripheral为空，不调用cancel");
        }
    }];
    
}

- (void)cancelScan {
    DLogTagInfo( kBluetoothTag, @"停止设备扫描");
    [_baby cancelScan];
}

- (BOOL)peripheralIsConnected:(CBPeripheral *)peripheral {
    if (!peripheral) {
        return NO;
    }
    if (peripheral.state == CBPeripheralStateConnected) {
        DLogTagInfo( kBluetoothTag, @"%@蓝牙已是连接状态，不需要连接:peripheral=%@",[self findConnectInfo:peripheral].positionName,peripheral);
        return YES;
    } else {
        return NO;
    }
}

