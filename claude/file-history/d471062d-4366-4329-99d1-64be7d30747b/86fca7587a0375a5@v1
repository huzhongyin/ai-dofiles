@implementation XPBluetoothConnectInfo

- (instancetype)init {
    self = [super init];
    if (self) {
        _lock = dispatch_semaphore_create(1);
        _serviceUUIDs = [NSArray array];
        _characteristicsUUIDs = [NSArray array];
    }
    
    return self;
}

- (void)setupPeripheral:(CBPeripheral*)peripheral {
    dispatch_semaphore_wait(_lock, DISPATCH_TIME_FOREVER);
    _peripheral = peripheral;
    dispatch_semaphore_signal(_lock);
}

- (CBPeripheral *)getPeripheral {
    CBPeripheral* retval = nil;
    dispatch_semaphore_wait(_lock, DISPATCH_TIME_FOREVER);
    retval = _peripheral;
    dispatch_semaphore_signal(_lock);
    return retval;
}


