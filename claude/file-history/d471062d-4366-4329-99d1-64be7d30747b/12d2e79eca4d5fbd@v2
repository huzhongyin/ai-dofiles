static NSInteger const PrivacyPermissionTypeLocationDistanceFilter = 10; //`Positioning accuracy` -> 定位精度
@interface PrivacyPermission()<CLLocationManagerDelegate,CBCentralManagerDelegate>

@property (nonatomic,strong)CLLocationManager *locationManager;
@property (nonatomic,copy) void(^completion)(BOOL granted,PrivacyPermissionAuthorizationStatus status);
@property (nonatomic,assign) BOOL autoShowAlert;
@property (nonatomic,strong) CBCentralManager *centralManager;
// 权限状态缓存，key: @(PrivacyPermissionType), value: @(PrivacyPermissionAuthorizationStatus)
@property (nonatomic, strong) NSMutableDictionary<NSNumber *, NSNumber *> *statusCache;
// 缓存读写专用并发队列（读并发、写互斥）
@property (nonatomic, strong) dispatch_queue_t cacheQueue;

@end

@implementation PrivacyPermission

+ (instancetype)sharedInstance {
    static PrivacyPermission *mannage = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        mannage = [PrivacyPermission new];
    });
    return mannage;
}

- (instancetype)init {
    if (self = [super init]) {
        _statusCache = [NSMutableDictionary dictionary];
        _cacheQueue = dispatch_queue_create("com.xpeng.privacypermission.cache", DISPATCH_QUEUE_CONCURRENT);
        // App 回到前台时刷新权限缓存（用户可能在系统设置中修改了权限）
        [[NSNotificationCenter defaultCenter] addObserver:self
                                                 selector:@selector(refreshCachedAuthorizationStatuses)
                                                     name:UIApplicationDidBecomeActiveNotification
                                                   object:nil];
    }
    return self;
}

#pragma mark - Cache Read/Write

- (PrivacyPermissionAuthorizationStatus)cachedStatusForType:(PrivacyPermissionType)type found:(BOOL *)found {
    __block PrivacyPermissionAuthorizationStatus status = PrivacyPermissionAuthorizationStatusRestricted;
    __block BOOL hasCache = NO;
    dispatch_sync(self.cacheQueue, ^{
        NSNumber *cached = self.statusCache[@(type)];
        if (cached) {
            status = (PrivacyPermissionAuthorizationStatus)cached.unsignedIntegerValue;
            hasCache = YES;
        }
    });
    if (found) *found = hasCache;
    return status;
}

- (void)setCachedStatus:(PrivacyPermissionAuthorizationStatus)status forType:(PrivacyPermissionType)type {
    dispatch_barrier_async(self.cacheQueue, ^{
        self.statusCache[@(type)] = @(status);
    });
}

- (void)dealloc {
    [[NSNotificationCenter defaultCenter] removeObserver:self];
}

- (CBCentralManager *)centralManager {
    if(!_centralManager) {
        _centralManager = [[CBCentralManager alloc] initWithDelegate:self
                                                               queue:dispatch_get_main_queue()
                                                             options:@{CBCentralManagerOptionShowPowerAlertKey:@(NO)}];
    }
    
    return _centralManager;
}

- (NSString *)permissionName:(PrivacyPermissionType)permissionType {
    switch (permissionType) {
        case PrivacyPermissionTypePhoto:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_PHOTO_NAME,nil);
        case PrivacyPermissionTypeCamera:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_CAMERA_NAME,nil);
        case PrivacyPermissionTypeMicrophone:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_MICROPHONE_NAME,nil);
        case PrivacyPermissionTypeLocation:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_LOCATION_NAME,nil);
        case PrivacyPermissionTypeAccuracy:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_ACCURACY_NAME,nil);
        case PrivacyPermissionTypeBluetooth:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_BLUETOOTH_NAME,nil);
        case PrivacyPermissionTypeEvent:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_EVENT_NAME,nil);
        case PrivacyPermissionTypeContact:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_CONTACT_NAME,nil);
        case PrivacyPermissionTypeBackgroundRefresh:
            return XP_PERMISSION_LOCALIZED_STRING(PERMISSION_BACKGROUND_REFRESH_NAME,nil);
    }
}

- (void)authorizationStatusWithType:(PrivacyPermissionType)type
                         completion:(void(^)(PrivacyPermissionAuthorizationStatus status))completion {
    @weakify(self)
    dispatch_async(dispatch_get_global_queue(DISPATCH_QUEUE_PRIORITY_DEFAULT, 0), ^{
        @strongify(self)
        PrivacyPermissionAuthorizationStatus status = [self queryAuthorizationStatus:type];
        [self setCachedStatus:status forType:type];
        dispatch_async(dispatch_get_main_queue(), ^{
            if (completion) {
                completion(status);
            }
        });
    });
}

- (PrivacyPermissionAuthorizationStatus)authorizationStatus:(PrivacyPermissionType)type {
    // 优先返回缓存值，避免主线程同步 IPC
    BOOL found = NO;
    PrivacyPermissionAuthorizationStatus cached = [self cachedStatusForType:type found:&found];
    if (found) {
        return cached;
    }
    // 无缓存时执行实际查询并写入缓存
    PrivacyPermissionAuthorizationStatus status = [self queryAuthorizationStatus:type];
    [self setCachedStatus:status forType:type];
    return status;
}

/// 实际查询系统权限状态（可能触发 IPC，不应在主线程调用）
- (PrivacyPermissionAuthorizationStatus)queryAuthorizationStatus:(PrivacyPermissionType)type {
    switch (type) {
        case PrivacyPermissionTypePhoto: {
            PHAuthorizationStatus status = [PHPhotoLibrary authorizationStatus];
            switch (status) {
                case PHAuthorizationStatusDenied:         return PrivacyPermissionAuthorizationStatusDenied;
                case PHAuthorizationStatusNotDetermined:  return PrivacyPermissionAuthorizationStatusNotDetermined;
                case PHAuthorizationStatusRestricted:     return PrivacyPermissionAuthorizationStatusRestricted;
                case PHAuthorizationStatusAuthorized:     return PrivacyPermissionAuthorizationStatusAuthorized;
                default: break;
            }
        } break;

        case PrivacyPermissionTypeCamera: {
#if TARGET_IPHONE_SIMULATOR
            NSLog(@"模拟器不支持摄像头");
            return PrivacyPermissionAuthorizationStatusNotDetermined;
#endif
            AVAuthorizationStatus status = [AVCaptureDevice authorizationStatusForMediaType:AVMediaTypeVideo];
            switch (status) {
                case AVAuthorizationStatusNotDetermined: return PrivacyPermissionAuthorizationStatusNotDetermined;
                case AVAuthorizationStatusRestricted:    return PrivacyPermissionAuthorizationStatusRestricted;
                case AVAuthorizationStatusDenied:        return PrivacyPermissionAuthorizationStatusDenied;
                case AVAuthorizationStatusAuthorized:    return PrivacyPermissionAuthorizationStatusAuthorized;
                default: break;
            }
        } break;

        case PrivacyPermissionTypeMicrophone: {
            AVAuthorizationStatus status = [AVCaptureDevice authorizationStatusForMediaType:AVMediaTypeAudio];
            switch (status) {
                case AVAuthorizationStatusNotDetermined: return PrivacyPermissionAuthorizationStatusNotDetermined;
                case AVAuthorizationStatusRestricted:    return PrivacyPermissionAuthorizationStatusRestricted;
                case AVAuthorizationStatusDenied:        return PrivacyPermissionAuthorizationStatusDenied;
                case AVAuthorizationStatusAuthorized:    return PrivacyPermissionAuthorizationStatusAuthorized;
                default: break;
            }
        } break;

        case PrivacyPermissionTypeLocation: {
            // ✅ 修复：复用单例 locationManager，不再每次 alloc init（避免主线程 IPC）
            CLAuthorizationStatus status;
            if (@available(iOS 14.0, *)) {
                if (!self.locationManager) {
                    self.locationManager = [[CLLocationManager alloc] init];
                    self.locationManager.delegate = self;
                }
                status = self.locationManager.authorizationStatus;
            } else {
                status = [CLLocationManager authorizationStatus];
            }
            switch (status) {
                case kCLAuthorizationStatusAuthorizedAlways:    return PrivacyPermissionAuthorizationStatusLocationAlways;
                case kCLAuthorizationStatusAuthorizedWhenInUse: return PrivacyPermissionAuthorizationStatusLocationWhenInUse;
                case kCLAuthorizationStatusDenied:              return PrivacyPermissionAuthorizationStatusDenied;
                case kCLAuthorizationStatusNotDetermined:       return PrivacyPermissionAuthorizationStatusNotDetermined;
                case kCLAuthorizationStatusRestricted:          return PrivacyPermissionAuthorizationStatusRestricted;
                default: break;
            }
        } break;

        case PrivacyPermissionTypeAccuracy: {
            // ✅ 修复：复用单例 locationManager，不再每次 alloc init（避免主线程 IPC）
            if (@available(iOS 14.0, *)) {
                if (!self.locationManager) {
                    self.locationManager = [[CLLocationManager alloc] init];
                    self.locationManager.delegate = self;
                }
                CLAccuracyAuthorization accuracy = self.locationManager.accuracyAuthorization;
                return (accuracy == CLAccuracyAuthorizationFullAccuracy)
                    ? PrivacyPermissionAuthorizationStatusAuthorized
                    : PrivacyPermissionAuthorizationStatusDenied;
            } else {
                return PrivacyPermissionAuthorizationStatusAuthorized;
            }
        } break;

        case PrivacyPermissionTypeBluetooth: {
            CBManagerState state = [self.centralManager state];
            if (state == CBManagerStateUnsupported || state == CBManagerStateUnauthorized || state == CBManagerStateUnknown) {
                return PrivacyPermissionAuthorizationStatusDenied;
            } else {
                return PrivacyPermissionAuthorizationStatusAuthorized;
            }
        } break;

        case PrivacyPermissionTypeEvent: {
            EKAuthorizationStatus status = [EKEventStore authorizationStatusForEntityType:EKEntityTypeEvent];
            switch (status) {
                case EKAuthorizationStatusNotDetermined: return PrivacyPermissionAuthorizationStatusNotDetermined;
                case EKAuthorizationStatusRestricted:    return PrivacyPermissionAuthorizationStatusRestricted;
                case EKAuthorizationStatusDenied:        return PrivacyPermissionAuthorizationStatusDenied;
                case EKAuthorizationStatusAuthorized:    return PrivacyPermissionAuthorizationStatusAuthorized;
                default: break;
            }
        } break;

        case PrivacyPermissionTypeContact: {
            CNAuthorizationStatus status = [CNContactStore authorizationStatusForEntityType:CNEntityTypeContacts];
            switch (status) {
                case CNAuthorizationStatusNotDetermined: return PrivacyPermissionAuthorizationStatusNotDetermined;
                case CNAuthorizationStatusRestricted:    return PrivacyPermissionAuthorizationStatusRestricted;
                case CNAuthorizationStatusDenied:        return PrivacyPermissionAuthorizationStatusDenied;
                case CNAuthorizationStatusAuthorized:    return PrivacyPermissionAuthorizationStatusAuthorized;
                default: break;
            }
        } break;

        case PrivacyPermissionTypeBackgroundRefresh: {
            UIBackgroundRefreshStatus status = [[UIApplication sharedApplication] backgroundRefreshStatus];
            switch (status) {
                case UIBackgroundRefreshStatusDenied:     return PrivacyPermissionAuthorizationStatusDenied;
                case UIBackgroundRefreshStatusRestricted: return PrivacyPermissionAuthorizationStatusRestricted;
                case UIBackgroundRefreshStatusAvailable:  return PrivacyPermissionAuthorizationStatusAuthorized;
                default: break;
            }
        } break;

        default: break;
    }
    return PrivacyPermissionAuthorizationStatusRestricted;
}

- (void)accessPrivacyPermission:(PrivacyPermissionType)type completion:(void(^)(BOOL granted,PrivacyPermissionAuthorizationStatus status))completion {
    [self accessPrivacyPermission:type autoShowAlert:YES completion:completion];
}

- (void)accessPrivacyPermission:(PrivacyPermissionType)type autoShowAlert:(BOOL)autoShowAlert completion:(void(^)(BOOL granted,PrivacyPermissionAuthorizationStatus status))completion {
    DLogTagInfo(@"PHPhotoLibrary", @"相册权限Debug");
    _autoShowAlert = autoShowAlert;
    _completion = completion;
    PrivacyPermissionAuthorizationStatus authorizationStatus = [self authorizationStatus:type];
    if(authorizationStatus != PrivacyPermissionAuthorizationStatusNotDetermined) {//不是未进行授权情况
        if (authorizationStatus == PrivacyPermissionAuthorizationStatusDenied && _autoShowAlert) {
            [self displayReEnableAlert:type];
        }
        BOOL grantedState = (authorizationStatus == PrivacyPermissionAuthorizationStatusAuthorized
                             || authorizationStatus == PrivacyPermissionAuthorizationStatusLocationAlways
                             || authorizationStatus == PrivacyPermissionAuthorizationStatusLocationWhenInUse);
        _completion ? _completion(grantedState,authorizationStatus) : nil;
        return;
    }
    switch (type) {
        case PrivacyPermissionTypePhoto: {
            [PHPhotoLibrary requestAuthorization:^(PHAuthorizationStatus status) {
                dispatch_async(dispatch_get_main_queue(), ^{
                    if (status == PHAuthorizationStatusDenied) {
                        _autoShowAlert ? [self displayReEnableAlert:type] : nil;
                        _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusDenied) : nil;
                    } else if (status == PHAuthorizationStatusNotDetermined) {
                        _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusNotDetermined) : nil;
                    } else if (status == PHAuthorizationStatusRestricted) {
                        _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusRestricted) : nil;
                    } else if (status == PHAuthorizationStatusAuthorized) {
                        _completion ? _completion(YES,PrivacyPermissionAuthorizationStatusAuthorized) : nil;
                    }
                });
            }];
        }
            break;
            
        case PrivacyPermissionTypeCamera: {
#if TARGET_IPHONE_SIMULATOR
            NSLog(@"模拟器不支持摄像头");
            return;
#endif
            [AVCaptureDevice requestAccessForMediaType:AVMediaTypeVideo completionHandler:^(BOOL granted) {
                dispatch_async(dispatch_get_main_queue(), ^{
                    AVAuthorizationStatus status = [AVCaptureDevice authorizationStatusForMediaType:AVMediaTypeVideo];
                    if (granted) {
                        _completion ?  _completion(YES,PrivacyPermissionAuthorizationStatusAuthorized) : nil;
                    } else {
                        if (status == AVAuthorizationStatusDenied) {
                            _autoShowAlert ? [self displayReEnableAlert:type] : nil;
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusDenied) : nil;
                        } else if (status == AVAuthorizationStatusNotDetermined) {
                            _completion ?  _completion(NO,PrivacyPermissionAuthorizationStatusNotDetermined) : nil;
                        } else if (status == AVAuthorizationStatusRestricted) {
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusRestricted) : nil;
                        }
                    }
                });
            }];
        }
            break;
            
        case PrivacyPermissionTypeMicrophone: {
            [AVCaptureDevice requestAccessForMediaType:AVMediaTypeAudio completionHandler:^(BOOL granted) {
                AVAuthorizationStatus status = [AVCaptureDevice authorizationStatusForMediaType:AVMediaTypeAudio];
                dispatch_async(dispatch_get_main_queue(), ^{
                    if (granted) {
                        _completion ? _completion(YES,PrivacyPermissionAuthorizationStatusAuthorized) : nil;
                    } else {
                        if (status == AVAuthorizationStatusDenied) {
                            _autoShowAlert ? [self displayReEnableAlert:type] : nil;
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusDenied) : nil;
                        } else if (status == AVAuthorizationStatusNotDetermined) {
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusNotDetermined) : nil;
                        } else if (status == AVAuthorizationStatusRestricted) {
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusRestricted) : nil;
                        }
                    }
                });
            }];
        }
            break;
            
        case PrivacyPermissionTypeLocation: {
            if ([CLLocationManager locationServicesEnabled]) {
                CLLocationManager *locationManager = [[CLLocationManager alloc]init];
                [locationManager requestWhenInUseAuthorization];
                locationManager.desiredAccuracy = kCLLocationAccuracyBestForNavigation;
                locationManager.distanceFilter = PrivacyPermissionTypeLocationDistanceFilter;
                locationManager.delegate = self;
                _locationManager = locationManager;
                [locationManager startUpdatingLocation];
                DLogTagInfo( kChargeStationTag, @"定位权限请求 定位请求 请求使用期间允许权限：requestWhenInUseAuthorization 并开始定位服务 applicationState:%@", @([UIApplication sharedApplication].applicationState));
            }
        }
            break;
            
        case PrivacyPermissionTypeBluetooth: {
            CBManagerState state = [self.centralManager state];
            dispatch_async(dispatch_get_main_queue(), ^{
                if (state == CBManagerStateUnsupported || state == CBManagerStateUnauthorized || state == CBManagerStateUnknown) {
                    _autoShowAlert ? [self displayReEnableAlert:type] : nil;
                    _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusDenied) : nil;
                } else {
                    _completion ? _completion(YES,PrivacyPermissionAuthorizationStatusAuthorized) : nil;
                }
            });
        }
            break;
            
        case PrivacyPermissionTypeEvent: {
            EKEventStore *store = [[EKEventStore alloc] init];
            [store requestAccessToEntityType:EKEntityTypeEvent completion:^(BOOL granted, NSError * _Nullable error) {
                dispatch_async(dispatch_get_main_queue(), ^{
                    EKAuthorizationStatus status = [EKEventStore  authorizationStatusForEntityType:EKEntityTypeEvent];
                    if (granted) {
                        _completion ? _completion(YES,PrivacyPermissionAuthorizationStatusAuthorized) : nil;
                    } else {
                        if (status == EKAuthorizationStatusDenied) {
                            _autoShowAlert ? [self displayReEnableAlert:type] : nil;
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusDenied) : nil;
                        } else if (status == EKAuthorizationStatusNotDetermined) {
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusNotDetermined) : nil;
                        } else if (status == EKAuthorizationStatusRestricted) {
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusRestricted) : nil;
                        }
                    }
                });
            }];
        }
            break;
            
        case PrivacyPermissionTypeContact: {
            CNContactStore *contactStore = [[CNContactStore alloc] init];
            [contactStore requestAccessForEntityType:CNEntityTypeContacts completionHandler:^(BOOL granted, NSError * _Nullable error) {
                dispatch_async(dispatch_get_main_queue(), ^{
                    CNAuthorizationStatus status = [CNContactStore authorizationStatusForEntityType:CNEntityTypeContacts];
                    if (granted) {
                        _completion ? _completion(YES,PrivacyPermissionAuthorizationStatusAuthorized) : nil;
                    } else {
                        if (status == CNAuthorizationStatusDenied) {
                            _autoShowAlert ? [self displayReEnableAlert:type] : nil;
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusDenied) : nil;
                        }else if (status == CNAuthorizationStatusRestricted){
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusRestricted) : nil;
                        }else if (status == CNAuthorizationStatusNotDetermined){
                            _completion ? _completion(NO,PrivacyPermissionAuthorizationStatusNotDetermined) : nil;
                        }
                    }
                });
            }];
        }
            break;
            
        default:
            break;
    }
}

- (void)displayReEnableAlert:(PrivacyPermissionType)type {
    [self displayReEnableAlert:type Cancel:nil];
}

- (void)displayReEnableAlert:(PrivacyPermissionType)type Cancel:(void (^)(void))cancelBlock {
    dispatch_async(dispatch_get_main_queue(), ^{
        NSString *permission = [self permissionName:type];
        NSString *title = [NSString stringWithFormat:@"%@%@",XP_PERMISSION_LOCALIZED_STRING(PERMISSION_NO_ACCESS_TIP,nil), permission];
        NSDictionary *infoDictionary = [[NSBundle mainBundle] infoDictionary];
        NSString *appName = [infoDictionary objectForKey:@"CFBundleDisplayName"];
        NSString *message = [NSString stringWithFormat:@"%@ '%@-%@-%@'-\"%@\" %@",XP_PERMISSION_LOCALIZED_STRING(PERMISSION_OPEN_WELCOME,nil),XP_PERMISSION_LOCALIZED_STRING(PERMISSION_SETTING_TIP,nil), XP_PERMISSION_LOCALIZED_STRING(PERMISSION_PRIVACY_TIP,nil), permission,appName, XP_PERMISSION_LOCALIZED_STRING(PERMISSION_SETTING_GO_TIP,nil)];
        
        XPAlertController *alertVC = [XPAlertController alertControllerWithTitle:title
                                                                         message:message
                                                                  imageURLString:nil
                                                                      localImage:nil
                                                                   configuration:^(XPAlertControllerConfig * _Nonnull config) {
                                                                       config.titleLabel.font = kPingFangSCMediumFont(18);
                                                                       config.messageTextView.textAlignment = NSTextAlignmentLeft;
                                                                   }];
        XPAlertAction *cancelAction = [XPAlertAction actionWithTitle:XP_PERMISSION_LOCALIZED_STRING(PERMISSION_CANCEL_TIP,nil)
                                                                style:UIAlertActionStyleCancel
                                                       actionHandler:^(XPAlertAction * _Nonnull action) {
            cancelBlock ? cancelBlock() : nil;
        } configuration:nil];
        [alertVC addAction:cancelAction];

        XPAlertAction *confirmAction = [XPAlertAction actionWithTitle:XP_PERMISSION_LOCALIZED_STRING(PERMISSION_GO_SETTING_TIP,nil)
                                                                style:UIAlertActionStyleDefault
                                                        actionHandler:^(XPAlertAction * _Nonnull action) {
            [[UIApplication sharedApplication] openURL:[NSURL URLWithString:UIApplicationOpenSettingsURLString]];//打开系统设置
        } configuration:nil];
        [alertVC addAction:confirmAction];
        [[BBApp keyWindow].rootViewController presentViewController:alertVC animated:YES completion:nil];
    });
}

#pragma mark - Cache Refresh

- (void)refreshAuthorizationStatus:(PrivacyPermissionType)type
                        completion:(void(^)(PrivacyPermissionAuthorizationStatus status))completion {
    // 先清除旧缓存，强制重新查询
    dispatch_barrier_async(self.cacheQueue, ^{
        [self.statusCache removeObjectForKey:@(type)];
    });
    [self authorizationStatusWithType:type completion:completion];
}

- (void)refreshCachedAuthorizationStatuses {
    // 只刷新已被查询过（已在缓存中）的类型，避免无用 IPC
    __block NSArray<NSNumber *> *cachedTypes = nil;
    dispatch_sync(self.cacheQueue, ^{
        cachedTypes = [self.statusCache.allKeys copy];
    });
    for (NSNumber *typeNum in cachedTypes) {
        PrivacyPermissionType type = (PrivacyPermissionType)typeNum.unsignedIntegerValue;
        [self authorizationStatusWithType:type completion:nil];
    }
}

- (void)warmUpPermissionCache {
    // 预热 BLE 数字钥匙所需的三个权限
    NSArray *types = @[
        @(PrivacyPermissionTypeLocation),
        @(PrivacyPermissionTypeAccuracy),
        @(PrivacyPermissionTypeBackgroundRefresh),
    ];
    for (NSNumber *typeNum in types) {
        [self authorizationStatusWithType:(PrivacyPermissionType)typeNum.unsignedIntegerValue
                               completion:nil];
    }
}

#pragma mark - CLLocationManagerDelegate
- (void)locationManager:(CLLocationManager *)manager didUpdateLocations:(NSArray<CLLocation *> *)locations {
    [manager stopUpdatingLocation];
    manager.delegate = nil;
    _locationManager = nil;  // 释放授权请求用的实例，queryAuthorizationStatus: 会在需要时重建
    PrivacyPermissionAuthorizationStatus authorizationStatus = [self authorizationStatus:PrivacyPermissionTypeLocation];
    _completion ? _completion(true,authorizationStatus) : nil;
}

- (void)locationManager:(CLLocationManager *)manager didFailWithError:(NSError *)error {
    PrivacyPermissionAuthorizationStatus authorizationStatus = [self authorizationStatus:PrivacyPermissionTypeLocation];
    (authorizationStatus == PrivacyPermissionAuthorizationStatusDenied && _autoShowAlert) ? [self displayReEnableAlert:PrivacyPermissionTypeLocation] : nil;
    BOOL grantedState = (authorizationStatus == PrivacyPermissionAuthorizationStatusAuthorized
                         || authorizationStatus == PrivacyPermissionAuthorizationStatusLocationAlways
                         || authorizationStatus == PrivacyPermissionAuthorizationStatusLocationWhenInUse);
    _completion ? _completion(grantedState,authorizationStatus) : nil;
}

- (void)locationManagerDidChangeAuthorization:(CLLocationManager *)manager API_AVAILABLE(ios(14.0)) {
    // 权限实际发生变化，立即刷新 Location 和 Accuracy 缓存
    [self authorizationStatusWithType:PrivacyPermissionTypeLocation completion:nil];
    [self authorizationStatusWithType:PrivacyPermissionTypeAccuracy completion:nil];
}

// iOS 14 以下的权限变更回调
- (void)locationManager:(CLLocationManager *)manager didChangeAuthorizationStatus:(CLAuthorizationStatus)status {
    [self authorizationStatusWithType:PrivacyPermissionTypeLocation completion:nil];
}

