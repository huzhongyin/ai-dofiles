```objc
#pragma mark - Cache Read/Write

- (PrivacyPermissionAuthorizationStatus)cachedStatusForType:(PrivacyPermissionType)type found:(BOOL *)found {
    __block PrivacyPermissionAuthorizationStatus status = PrivacyPermissionAuthorizationStatusRestricted;
    __block BOOL hasCache = NO;
    dispatch_sync(self.cacheQueue, ^{
        NSNumber *cached = self.statusCache[@(type)];
        if (cached) {
            status = (PrivacyPermissionAuthorizationStatus)cached.unsignedIntegerValue;
            hasCache = YES;
        }
    });
    if (found) *found = hasCache;
    return status;
}

- (void)setCachedStatus:(PrivacyPermissionAuthorizationStatus)status forType:(PrivacyPermissionType)type {
    dispatch_barrier_async(self.cacheQueue, ^{
        self.statusCache[@(type)] = @(status);
    });
}
```

