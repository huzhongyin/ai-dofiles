#!/bin/bash
# xp-spec-framework bootstrap script
# Usage: ./bootstrap.sh /path/to/your-project

set -e

PROJECT_DIR="${1:-.}"
FRAMEWORK_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ ! -d "$PROJECT_DIR" ]; then
  echo "Error: Directory $PROJECT_DIR does not exist"
  exit 1
fi

echo "🚀 Initializing xp-spec-framework in: $PROJECT_DIR"

# Create directory structure
echo "📁 Creating directory structure..."
mkdir -p "$PROJECT_DIR/.ai-knowledge/specs"
mkdir -p "$PROJECT_DIR/.ai-knowledge/knowledge-points"
mkdir -p "$PROJECT_DIR/.ai-knowledge/pitfalls"
mkdir -p "$PROJECT_DIR/.ai-knowledge/modules"
mkdir -p "$PROJECT_DIR/.claude/skills"
mkdir -p "$PROJECT_DIR/.claude/rules"

# Copy skills
echo "🔧 Copying skills..."
for skill_dir in "$FRAMEWORK_DIR"/skills/*/; do
  skill_name=$(basename "$skill_dir")
  mkdir -p "$PROJECT_DIR/.claude/skills/$skill_name"
  cp "$skill_dir/SKILL.md" "$PROJECT_DIR/.claude/skills/$skill_name/SKILL.md"
  echo "  ✓ $skill_name"
done

# Copy templates
echo "📄 Copying templates..."
for template in "$FRAMEWORK_DIR"/templates/*.md; do
  cp "$template" "$PROJECT_DIR/.ai-knowledge/specs/$(basename "$template")"
  echo "  ✓ $(basename "$template")"
done

# Copy project config example
echo "⚙️  Copying project config template..."
cp "$FRAMEWORK_DIR/project-config.example.yml" "$PROJECT_DIR/project-config.yml"

# Create empty module registry
if [ ! -f "$PROJECT_DIR/.ai-knowledge/module-registry.md" ]; then
  echo "📋 Creating empty module registry..."
  cat > "$PROJECT_DIR/.ai-knowledge/module-registry.md" << 'REGISTRY'
# Module Registry

> Single Source of Truth for all registered modules.
> Format: each entry is a YAML block. Skills scan all ```yaml module blocks.

## Registered Modules

<!-- scaffold:begin -->

<!-- Add your modules here using the YAML block format -->
<!-- See schemas/module-registry-format.md for field definitions -->

<!-- scaffold:end -->
REGISTRY
fi

# Create empty constitution
if [ ! -f "$PROJECT_DIR/.ai-knowledge/specs/constitution.md" ]; then
  echo "📜 Creating project constitution placeholder..."
  cp "$FRAMEWORK_DIR/templates/template-constitution.md" "$PROJECT_DIR/.ai-knowledge/specs/constitution.md"
fi

echo ""
echo "✅ Framework initialized successfully!"
echo ""
echo "Next steps:"
echo "  1. Edit project-config.yml with your project info"
echo "  2. Edit .ai-knowledge/specs/constitution.md with your project constraints"
echo "  3. Register your modules in .ai-knowledge/module-registry.md"
echo "  4. Create deps.yml for each module that has dependencies"
echo ""
echo "See methodology/ docs for detailed guidance."
