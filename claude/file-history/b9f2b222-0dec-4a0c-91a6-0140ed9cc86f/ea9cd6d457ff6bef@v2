## AI辅助配置

```yaml
ai_assist_config:
  enabled: true
  max_suggestions_per_request: 10
  cache_suggestions: true
  cache_ttl_seconds: 600       # 建议缓存10分钟

  suggestion_types:
    code_completion:      {enabled: true, priority: 1}
    refactoring:          {enabled: true, priority: 2}
    best_practices:       {enabled: true, priority: 3}
    architecture_guidance:{enabled: true, priority: 4}
    security_recommendations: {enabled: true, priority: 5}

  module_specific_guidance:
    XPVehicleSDK:
      focus_areas: ["thread_safety", "error_handling", "performance"]
      forbidden_patterns: ["ui_operations_on_background_thread"]
      required_patterns: ["xp_prefix_naming", "error_callbacks"]

    "XPBusiness_*":
      focus_areas: ["mvvm_compliance", "network_handling", "ui_responsiveness"]
      architecture_patterns: ["MVVM", "Observer"]
      networking_guidelines: ["timeout_configuration", "retry_logic"]

    "XPBase_*":
      focus_areas: ["reusability", "documentation", "api_design"]
      design_principles: ["single_responsibility", "interface_segregation"]

  quality_metrics:
    suggestion_relevance_threshold: 0.8   # 相关性阈值
    false_positive_rate_threshold: 0.1    # 误报率上限
    response_time_sla_ms: 500             # 响应时间SLA
```

