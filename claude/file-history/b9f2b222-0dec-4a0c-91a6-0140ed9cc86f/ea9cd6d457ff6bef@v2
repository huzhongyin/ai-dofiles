## 集成配置

```yaml
integration_config:
  claude_code:
    enabled: true
    hooks:
      pre_tool_use: true       # 编辑前权限检查
      post_tool_use: true      # 编辑后标准验证
      session_start: false     # 会话启动不自动扫描
    auto_validation: true
    auto_suggestions: true

  git_integration:
    enabled: true
    pre_commit_hooks: ["standards_validation", "permission_check"]
    commit_message_templates: true
    branch_protection: ["main", "develop"]

  ide_integration:
    xcode:
      enabled: true
      build_phase_scripts: true
      analyzer_integration: true

  ci_cd:
    enabled: true
    validation_on_pr: true        # PR时强制验证
    auto_fix_on_merge: false      # 合并时不自动修复（需人工确认）
    notification_channels: ["slack", "email"]

  feishu_sync:
    enabled: true
    sync_interval_hours: 24       # 每天同步一次飞书文档
    auto_update_standards: true   # 自动更新标准规则
    document_ids: []              # 填入飞书文档ID
```

