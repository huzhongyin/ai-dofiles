```cpp
// C++ 内存管理
class BleDataProcessor {
public:
    // ✅ 配对的分配和释放
    uint8_t* allocateBuffer(size_t size);
    void releaseBuffer(uint8_t* buffer);

    // ✅ 单一出口原则
    ParseResult parseData(const uint8_t* data, size_t length) {
        ParseResult result;
        uint8_t* tempBuffer = nullptr;

        // 入口检查可以多个return
        if (!data || length == 0) {
            result.error = INVALID_PARAM;
            return result;
        }

        // 主逻辑只有一个出口
        tempBuffer = allocateBuffer(length);
        if (tempBuffer) {
            // 处理逻辑...
            result.success = true;
        } else {
            result.error = MEMORY_ERROR;
        }

        // 统一清理和返回
        if (tempBuffer) {
            releaseBuffer(tempBuffer);
        }
        return result;
    }
};
```

