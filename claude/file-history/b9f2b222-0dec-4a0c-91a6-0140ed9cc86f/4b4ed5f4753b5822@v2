## 📚 重点规范速查

### 车控业务模式
```swift
// ✅ 标准车控指令模式
func sendCommand(command: VehicleCommand,
                success: @escaping () -> Void,
                failed: @escaping (VehicleError) -> Void) {

    vehicleManager.execute(command) { result in
        switch result {
        case .success:
            DispatchQueue.main.async { success() }
        case .failure(let error):
            DispatchQueue.main.async { failed(error) }
        }
    }
}

// ✅ 车型能力判断模式
if vehicle.function.supportHVACClean {
    showHVACCleanButton()
} else {
    hideHVACCleanButton()
}

// ❌ 避免硬编码车型判断
// if vehicle.type == .f30 { ... }
```

