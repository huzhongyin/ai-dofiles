    # 配置 SwiftFormat 规则
    cat > .swiftformat << 'EOF'
# 小鹏 iOS SwiftFormat 配置

--swiftversion 5.5

# 缩进
--indent 4
--indentcase false
--indentstrings true

# 空格
--commas always
--semicolons never
--operators infix
--ranges spaced

# 大括号
--allman false
--wraparguments preserve
--closingparen balanced

# 其他
--header ignore
--disable unusedArguments
EOF

    # 配置 SwiftLint 规则（可选）
    if [ -f .swiftlint.yml ]; then
        echo "SwiftLint 配置已存在，跳过创建"
    else
        cat > .swiftlint.yml << 'EOF'
# 小鹏 iOS SwiftLint 配置

disabled_rules:
  - trailing_whitespace
  - vertical_whitespace

opt_in_rules:
  - closure_end_indentation
  - closure_spacing
  - empty_count
  - force_unwrapping
  - implicit_return
  - redundant_nil_coalescing

included:
  - Sources
  - XPVehicleSDK
  - XPCarControlCore

excluded:
  - Pods
  - Build
  - DerivedData

line_length:
  warning: 120
  error: 150

identifier_name:
  min_length: 1
  max_length: 50

type_name:
  min_length: 3
  max_length: 40

custom_rules:
  xiaopeng_objc_prefix:
    name: "XP前缀规则"
    regex: '@objc\([^X][^P]\w*\)'
    message: "导出给OC的类必须使用XP前缀"
    severity: error

  weak_delegate:
    name: "Delegate必须是weak"
    regex: '(var|let)\s+\w*[Dd]elegate\s*:\s*\w+\??\s*='
    message: "delegate属性必须声明为weak"
    severity: warning
EOF
    fi

    echo "✅ 项目配置完成"
}

# ================================
# 5. 配置 Git Hooks
# ================================
setup_git_hooks() {
    echo "🔗 配置 Git Hooks..."

    # 创建 pre-commit hook
    mkdir -p .git/hooks

    cat > .git/hooks/pre-commit << 'EOF'
#!/bin/bash
# 小鹏 iOS 代码提交前检查

echo "🔍 执行小鹏 iOS 规范检查..."

# 1. SwiftFormat 检查
if command -v swiftformat &> /dev/null; then
    echo "📝 检查代码格式..."
    swiftformat --lint Sources/ XPVehicleSDK/ XPCarControlCore/

    if [ $? -ne 0 ]; then
        echo "❌ 代码格式不符合规范，请运行 swiftformat 修复"
        exit 1
    fi
fi

# 2. SwiftLint 检查
if command -v swiftlint &> /dev/null; then
    echo "🧹 运行 SwiftLint 检查..."
    swiftlint --strict

    if [ $? -ne 0 ]; then
        echo "❌ SwiftLint 检查失败，请修复警告后重新提交"
        exit 1
    fi
fi

# 3. 自定义小鹏规范检查
echo "🚗 检查小鹏特有规范..."

# 检查是否有未添加 XP 前缀的 @objc 导出
objc_exports=$(git diff --cached --name-only | xargs grep -l "@objc(" | head -20)
if [ -n "$objc_exports" ]; then
    for file in $objc_exports; do
        if grep -q "@objc([^X][^P]" "$file"; then
            echo "❌ 文件 $file 中的 @objc 导出缺少 XP 前缀"
            exit 1
        fi
    done
fi

# 检查是否有未使用 weak 的 delegate
delegate_files=$(git diff --cached --name-only | xargs grep -l "delegate.*:" | head -20)
if [ -n "$delegate_files" ]; then
    for file in $delegate_files; do
        if grep -q "var.*delegate.*:" "$file" && ! grep -q "weak.*var.*delegate" "$file"; then
            echo "⚠️  文件 $file 中的 delegate 建议使用 weak 声明"
        fi
    done
fi

echo "✅ 代码规范检查通过"
exit 0
EOF

    chmod +x .git/hooks/pre-commit

    echo "✅ Git Hooks 配置完成"
}

