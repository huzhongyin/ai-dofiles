# 作者：小鹏iOS团队

set -e

echo "🚀 小鹏 iOS AI 开发规范配置开始..."

# ================================
# 1. 环境检查
# ================================
check_environment() {
    echo "🔍 检查开发环境..."

    # 检查 Xcode
    if ! command -v xcodebuild &> /dev/null; then
        echo "❌ 未安装 Xcode，请先安装 Xcode"
        exit 1
    fi

    # 检查 Homebrew
    if ! command -v brew &> /dev/null; then
        echo "❌ 未安装 Homebrew，请先安装：https://brew.sh/"
        exit 1
    fi

    # 检查 Claude Code
    if ! command -v claude &> /dev/null; then
        echo "❌ 未安装 Claude Code，请先安装"
        exit 1
    fi

    echo "✅ 环境检查通过"
}

# ================================
# 2. 安装必要工具
# ================================
install_tools() {
    echo "📦 安装开发工具..."

    # 安装 SwiftFormat
    if ! command -v swiftformat &> /dev/null; then
        echo "安装 SwiftFormat..."
        brew install swiftformat
    fi

    # 安装 SwiftLint（可选）
    if ! command -v swiftlint &> /dev/null; then
        echo "安装 SwiftLint..."
        brew install swiftlint
    fi

    echo "✅ 工具安装完成"
}

# ================================
# 3. 配置小鹏规范模板
