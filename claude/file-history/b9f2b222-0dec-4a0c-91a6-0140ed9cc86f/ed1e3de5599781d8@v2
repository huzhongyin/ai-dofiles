    mkdir -p .claude

    # 配置小鹏规范检查
    cat > .claude/settings.local.json << 'EOF'
{
  "xiaopengIOSStandards": {
    "enabled": true,
    "autoCheck": true,
    "strictMode": false,
    "rules": {
      "codeStyle": true,
      "naming": true,
      "memoryManagement": true,
      "architecture": true,
      "carControlPattern": true
    }
  },
  "templates": {
    "swift": "xiaopeng/swift-class",
    "vehicleCommand": "xiaopeng/vehicle-command"
  },
  "aiTools": {
    "claudeCode": {
      "primaryRole": "codeGeneration",
