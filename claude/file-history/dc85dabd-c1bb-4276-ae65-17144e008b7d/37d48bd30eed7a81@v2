- (RACCommand *)checkCommand{
    if(!_checkCommand){
        @weakify(self);
        _checkCommand = [[RACCommand alloc] initWithSignalBlock:^RACSignal * _Nonnull(id  _Nullable input) {
            @strongify(self);
            BOOL isResume = [input[@"resume"] boolValue];
            BOOL skipAlert = [input[@"skipAlert"] boolValue];
            NSInteger tryCount = isResume?0:2;
            
            //mona从哪里来都要询问远程
            if (CTMediator.isMona) {
                skipAlert = NO;
            }
            
            RACSignal *checkStateSignal = [[[self checkBleKeySignal] concat:[self checkRemoteSignalWithSkipAlert:skipAlert]] concat:[self checkBleStateSignalWithTimeout:isResume?5:2]];
            
            RACSignal *checkConnectSignal = [[[self checkNearbySignalWithTryCount:tryCount] concat:[self checkConnectSignalWithTryCount:tryCount]] concat:[self sendCommandSignalWithTryCount:tryCount]];
            
            if(CTMediator.isMona){
                checkConnectSignal = [[self monaCheckConnectSignalWithTryCount:tryCount] concat:[self sendMonaCommandSignalWithTryCount:tryCount tryDelete:NO]];
            }
            RACSignal *resultSignal = [[[RACSignal return:@(XPKeyCheckProgressDefault)] concat:checkStateSignal] concat:checkConnectSignal];
            if(isResume){
                resultSignal = [[[[RACSignal return:@(XPKeyCheckProgressDefault)] concat:checkStateSignal] concat:@[
                    @(XPKeyCheckProgressResetBleChecking),
                    @(XPKeyCheckProgressResetBleChecked),
                    @(XPKeyCheckProgressRestartChecking),
                    @(XPKeyCheckProgressRestartChecked),
                ].rac_sequence.signal] concat:checkConnectSignal];
            }
            
            resultSignal = [resultSignal catch:^RACSignal * _Nonnull(NSError * _Nonnull error) {
                @strongify(self);
                if(error.code == XPKeyCheckErrorCodeRemoteStarted || error.code == XPKeyCheckErrorCodeRemoteLocked){
                    self.isRemoteComplete = YES;
                    return RACSignal.empty;
                }
                return [RACSignal error:error];
            }];
            
            return [resultSignal takeUntil:self.rac_willDeallocSignal error:[NSError errorWithDomain:XPKeyCheckErrorDomain code:XPKeyCheckErrorCodeCancel userInfo:@{}]];
        }];
    }
    return _checkCommand;
}

- (RACSignal<NSNumber *> *)checkBleKeySignal{
    @weakify(self);
    return [[RACSignal createSignal:^RACDisposable * _Nullable(id<RACSubscriber>  _Nonnull subscriber) {
        @strongify(self);
        [subscriber sendNext:@(XPKeyCheckProgressBleStateChecking)];
        
        if([self existValidBlePrivateKey]){
            [subscriber sendCompleted];
        }else{
            [subscriber sendError:[NSError errorWithDomain:XPKeyCheckErrorDomain code:XPKeyCheckErrorCodeNoKey userInfo:@{NSLocalizedDescriptionKey: @"创建手机钥匙", NSLocalizedRecoverySuggestionErrorKey: @"未创建手机钥匙，请先创建手机钥匙以正常使用"}]];
        }
        return nil;
    }] catch:^RACSignal * _Nonnull(NSError * _Nonnull error) {
        @strongify(self);
        [XPStatisticsMgr sendEvent:XP_MOBILE_KEY_CHECK_FAIL_NO_KEY module:XP_MOBILE_KEY_CHECK_MODULE data:@{@"sessionid": @(self.sessionId)}];
        
        return [[self alertControllerSignalWithTitle:error.localizedDescription message:error.localizedRecoverySuggestion buttonTitles:@[@"退出", @"创建"]] flattenMap:^__kindof RACSignal * _Nullable(id  _Nullable value) {
            @strongify(self);
            if([value integerValue] == 0){
                [self.navigationController popViewControllerAnimated:YES];
                return [RACSignal error:error];
            }
            [XPStatisticsMgr sendEvent:XP_MOBILE_KEY_CHECK_TRY_CREATE_KEY module:XP_MOBILE_KEY_CHECK_MODULE data:@{@"sessionid": @(self.sessionId)}];
            return [self showCreateKeySignalWithNeedDelete:NO];
        }];
    }];
}


